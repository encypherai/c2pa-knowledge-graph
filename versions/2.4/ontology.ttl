c2pa:bmffExclusionsMap.exact a owl:DatatypeProperty ;
    rdfs:label "exact"@en ;
    rdfs:comment "If true, flags must be an exact match (default true). Only for FullBox when flags is specified."@en ;
    rdfs:domain c2pa:bmffExclusionsMap ;
    rdfs:range xsd:boolean .

c2pa:bmffExclusionsMap.flags a owl:DatatypeProperty ;
    rdfs:label "flags"@en ;
    rdfs:comment "24-bit flags (3-byte byte string, e.g. Base64-encoded with b64' prefix in JSON). Only for FullBox when version is specified."@en ;
    rdfs:domain c2pa:bmffExclusionsMap ;
    rdfs:range xsd:string .

c2pa:bmffExclusionsMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "Length that a leafmost box must have to be excluded"@en ;
    rdfs:domain c2pa:bmffExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:bmffExclusionsMap.version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "Version that must be set in a leafmost FullBox for the box to be excluded"@en ;
    rdfs:domain c2pa:bmffExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:bmffMerkleMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "Hash algorithm for this Merkle tree; if absent, from enclosing structure"@en ;
    rdfs:domain c2pa:bmffMerkleMap ;
    rdfs:range xsd:string .

c2pa:bmffMerkleMap.fixedBlockSize a owl:DatatypeProperty ;
    rdfs:label "fixedBlockSize"@en ;
    rdfs:comment "Size in bytes of a leaf node (non-fragmented MP4, piecewise mdat validation)"@en ;
    rdfs:domain c2pa:bmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:bmffMerkleMap.hashes a owl:DatatypeProperty ;
    rdfs:label "hashes"@en ;
    rdfs:comment "Ordered array representing a single row of the Merkle tree (e.g. Base64 in JSON)"@en ;
    rdfs:domain c2pa:bmffMerkleMap ;
    rdfs:range xsd:string .

c2pa:bmffMerkleMap.initHash a owl:DatatypeProperty ;
    rdfs:label "initHash"@en ;
    rdfs:comment "Hash of init segment or bytes before first moof (fragmented MP4); absent for non-fragmented"@en ;
    rdfs:domain c2pa:bmffMerkleMap ;
    rdfs:range xsd:string .

c2pa:boxExclusionsMap.boxIndex a owl:DatatypeProperty ;
    rdfs:label "boxIndex"@en ;
    rdfs:comment "0-based index into the names array in the box-hash-map; can be omitted if the number of boxes is one"@en ;
    rdfs:domain c2pa:boxExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:boxHashMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "Hash algorithm for this box; if absent, from enclosing structure"@en ;
    rdfs:domain c2pa:boxHashMap ;
    rdfs:range xsd:string .

c2pa:boxHashMap.excluded a owl:DatatypeProperty ;
    rdfs:label "excluded"@en ;
    rdfs:comment "If true, a validator can ignore this box (and associated hash) during validation"@en ;
    rdfs:domain c2pa:boxHashMap ;
    rdfs:range xsd:boolean .

c2pa:boxHashMap.names a owl:DatatypeProperty ;
    rdfs:label "names"@en ;
    rdfs:comment "Box identifiers in order of appearance"@en ;
    rdfs:domain c2pa:boxHashMap ;
    rdfs:range xsd:string .

c2pa:boxHashMap.pad a owl:DatatypeProperty ;
    rdfs:label "pad"@en ;
    rdfs:comment "Zero-filled byte string used for filling up space (typically Base64-encoded with b64' prefix in JSON)"@en ;
    rdfs:domain c2pa:boxHashMap ;
    rdfs:range xsd:string .

c2pa:boxHashMap.pad2 a owl:DatatypeProperty ;
    rdfs:label "pad2"@en ;
    rdfs:comment "Zero-filled byte string used for filling up space (typically Base64-encoded with b64' prefix in JSON)"@en ;
    rdfs:domain c2pa:boxHashMap ;
    rdfs:range xsd:string .

c2pa:claim.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "Cryptographic hash algorithm for data hash assertions in this claim (C2PA data hash algorithm identifier registry)"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range xsd:string .

c2pa:claim.alg_soft a owl:DatatypeProperty ;
    rdfs:label "alg_soft"@en ;
    rdfs:comment "Algorithm for soft binding assertions in this claim (C2PA soft binding algorithm identifier registry)"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range xsd:string .

c2pa:claim.created_assertions a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "created_assertions"@en ;
    rdfs:comment "Hashed URI references to created assertions"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range xsd:string,
        c2pa:hashedUriMap ;
    c2pa:relationshipType "has_many" .

c2pa:claim.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "Name of the asset (Dublin Core)"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range xsd:string .

c2pa:claim.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "Additional information about the assertion (DEPRECATED)"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range c2pa:assertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:claim.specVersion a owl:DatatypeProperty ;
    rdfs:label "specVersion"@en ;
    rdfs:comment "The version of the specification used to produce this claim (SemVer)"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range xsd:string .

c2pa:claimV1.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "Cryptographic hash algorithm for data hash assertions in this claim (C2PA data hash algorithm identifier registry)"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string .

c2pa:claimV1.alg_soft a owl:DatatypeProperty ;
    rdfs:label "alg_soft"@en ;
    rdfs:comment "Algorithm for soft binding assertions in this claim (C2PA soft binding algorithm identifier registry)"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string .

c2pa:claimV1.assertions a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "assertions"@en ;
    rdfs:comment "Hashed URI references to assertions in this claim"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string,
        c2pa:hashedUriMap ;
    c2pa:relationshipType "has_many" .

c2pa:claimV1.claim_generator_info a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "claim_generator_info"@en ;
    rdfs:comment "Detailed information about the claim generator (one or more generator-info maps)"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string,
        c2pa:softwareAgent ;
    c2pa:relationshipType "has_many" .

c2pa:claimV1.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "Name of the asset (Dublin Core)"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string .

c2pa:claimV1.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range c2pa:assertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:distinguishedName.2_5_4_97 a owl:DatatypeProperty ;
    rdfs:label "2.5.4.97"@en ;
    rdfs:comment "Organization identifier OID"@en ;
    rdfs:domain c2pa:distinguishedName ;
    rdfs:range xsd:string .

c2pa:distinguishedName.C a owl:DatatypeProperty ;
    rdfs:label "C"@en ;
    rdfs:comment "Country"@en ;
    rdfs:domain c2pa:distinguishedName ;
    rdfs:range xsd:string .

c2pa:distinguishedName.CN a owl:DatatypeProperty ;
    rdfs:label "CN"@en ;
    rdfs:comment "Common name"@en ;
    rdfs:domain c2pa:distinguishedName ;
    rdfs:range xsd:string .

c2pa:distinguishedName.E a owl:DatatypeProperty ;
    rdfs:label "E"@en ;
    rdfs:comment "Email address"@en ;
    rdfs:domain c2pa:distinguishedName ;
    rdfs:range xsd:string .

c2pa:distinguishedName.L a owl:DatatypeProperty ;
    rdfs:label "L"@en ;
    rdfs:comment "Locality"@en ;
    rdfs:domain c2pa:distinguishedName ;
    rdfs:range xsd:string .

c2pa:distinguishedName.O a owl:DatatypeProperty ;
    rdfs:label "O"@en ;
    rdfs:comment "Organization"@en ;
    rdfs:domain c2pa:distinguishedName ;
    rdfs:range xsd:string .

c2pa:distinguishedName.OU a owl:DatatypeProperty ;
    rdfs:label "OU"@en ;
    rdfs:comment "Organizational unit"@en ;
    rdfs:domain c2pa:distinguishedName ;
    rdfs:range xsd:string .

c2pa:distinguishedName.ST a owl:DatatypeProperty ;
    rdfs:label "ST"@en ;
    rdfs:comment "State or province"@en ;
    rdfs:domain c2pa:distinguishedName ;
    rdfs:range xsd:string .

c2pa:hashBmffAssertion.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "Hash algorithm; if absent, from enclosing structure (C2PA hash algorithm identifier list)"@en ;
    rdfs:domain c2pa:hashBmffAssertion ;
    rdfs:range xsd:string .

c2pa:hashBmffAssertion.exclusions a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "exclusions"@en ;
    rdfs:comment "Box(es) to exclude from the hash"@en ;
    rdfs:domain c2pa:hashBmffAssertion ;
    rdfs:range xsd:string,
        c2pa:bmffExclusionsMap ;
    c2pa:relationshipType "has_many" .

c2pa:hashBmffAssertion.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "Hash of BMFF/segment excluding exclusions (e.g. Base64 in JSON)"@en ;
    rdfs:domain c2pa:hashBmffAssertion ;
    rdfs:range xsd:string .

c2pa:hashBmffAssertion.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
