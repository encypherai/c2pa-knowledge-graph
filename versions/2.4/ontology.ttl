            owl:onProperty c2pa:thumbnailAssertion.thumbnailType ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:thumbnailAssertion.mimeType ] .

c2pa:ActionReason a owl:Class ;
    rdfs:label "ActionReason"@en ;
    c2pa:extensible true .

c2pa:ActionsMapV2 a owl:Class ;
    rdfs:label "ActionsMapV2"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
