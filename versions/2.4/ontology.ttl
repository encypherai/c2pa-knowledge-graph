    rdfs:domain c2pa:hashBmffAssertion ;
    rdfs:range xsd:string .

c2pa:hashBmffAssertion.sequenceNumber a owl:DatatypeProperty ;
    rdfs:label "sequenceNumber"@en ;
    rdfs:comment "In a live video workflow, the monotonically increasing sequence number for each segment"@en ;
    rdfs:domain c2pa:hashBmffAssertion ;
    rdfs:range xsd:integer .

c2pa:hashBmffAssertion.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "Unused and deprecated"@en ;
    rdfs:domain c2pa:hashBmffAssertion ;
    rdfs:range xsd:anyURI .

c2pa:hashBoxesAssertion.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "Cryptographic hash algorithm (C2PA hash algorithm identifier). If absent, taken from enclosing structure."@en ;
    rdfs:domain c2pa:hashBoxesAssertion ;
    rdfs:range xsd:string .

c2pa:hashBoxesAssertion.boxes a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "boxes"@en ;
    rdfs:comment "Array of box-hash-map entries"@en ;
    rdfs:domain c2pa:hashBoxesAssertion ;
    rdfs:range xsd:string,
        c2pa:boxHashMap ;
    c2pa:relationshipType "has_many" .

c2pa:hashDataAssertion.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "Hash algorithm"@en ;
    rdfs:domain c2pa:hashDataAssertion ;
    rdfs:range xsd:string .

c2pa:hashDataAssertion.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Name of the hashed data"@en ;
