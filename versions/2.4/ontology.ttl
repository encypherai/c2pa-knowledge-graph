    rdfs:comment "Media type of the ingredient (format-string)"@en ;
    rdfs:domain c2pa:ingredientAssertionV3 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV3.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "Name of the ingredient (Dublin Core)"@en ;
    rdfs:domain c2pa:ingredientAssertionV3 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV3.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Additional description of the ingredient"@en ;
    rdfs:domain c2pa:ingredientAssertionV3 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV3.informationalURI a owl:DatatypeProperty ;
    rdfs:label "informationalURI"@en ;
    rdfs:comment "URI to an informational page about the ingredient or its data (v3 camelCase)"@en ;
    rdfs:domain c2pa:ingredientAssertionV3 ;
