        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:TrainingMiningMap.c2pa_ai_training ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:TrainingMiningMap.c2pa_ai_inference ] ;
    owl:sameAs c2pa:training-mining-map .

c2pa:UnhashedExtUriMap a owl:Class ;
    rdfs:label "UnhashedExtUriMap"@en ;
    rdfs:comment "The data structure used to store a reference to an external URI WITHOUT a hash. This might include, for example, http/https reference or URI reference to a smart contract under CAIP-10 convention"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:UnhashedExtUriMap.dc_format ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:UnhashedExtUriMap.url ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:UnhashedExtUriMap.url ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:UnhashedExtUriMap.size ] ;
    owl:sameAs c2pa:unhashed-ext-uri-map .

c2pa:UnitChoice a owl:Class ;
    rdfs:label "UnitChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:UnitChoice.m c2pa:UnitChoice.mm c2pa:UnitChoice.pixel c2pa:UnitChoice.percent ) ] .

c2pa:ValidationResultsMap a owl:Class ;
    rdfs:label "ValidationResultsMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ValidationResultsMap.activeManifest ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ValidationResultsMap.specVersion ],
        [ a owl:Restriction ;
