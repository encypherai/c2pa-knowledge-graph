c2pa:ActionItemsMap.action a owl:ObjectProperty ;
    rdfs:label "action"@en ;
    rdfs:comment "Timestamp of when the action occurred."@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range c2pa:ActionChoice .

c2pa:ActionsMap a owl:Class ;
    rdfs:label "ActionsMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ActionsMap.metadata ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ActionsMap.actions ] ;
    owl:sameAs c2pa:actions-map .

c2pa:BmffMerkleMap.localId a owl:DatatypeProperty ;
    rdfs:label "localId"@en ;
    rdfs:comment "A local id indicating which 'mdat' box this entry pertains to.  This may not be globally unique"@en ;
    rdfs:domain c2pa:BmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:BmffMerkleMap.location a owl:DatatypeProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "Zero-based index into the leaf-most Merkle tree row corresponding to this 'mdat' box or portion of this 'mdat' box"@en ;
    rdfs:domain c2pa:BmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:BmffMerkleMap.uniqueId a owl:DatatypeProperty ;
    rdfs:label "uniqueId"@en ;
    rdfs:domain c2pa:BmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:ClaimMap.claim_generator a owl:DatatypeProperty ;
    rdfs:label "claim_generator"@en ;
    rdfs:comment "A User-Agent string formatted as per http://tools.ietf.org/html/rfc7231#section-5.5.3, for including the name and version of the claims generator that created the claim"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "uniquely identifies a specific version of an asset"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.signature a owl:DatatypeProperty ;
    rdfs:label "signature"@en ;
    rdfs:comment "JUMBF URI reference to the signature of this claim"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:CloudDataMap.content_type a owl:DatatypeProperty ;
    rdfs:label "content_type"@en ;
    rdfs:comment "media/MIME type for the data"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range xsd:string .

c2pa:CloudDataMap.label a owl:DatatypeProperty ;
    rdfs:label "label"@en ;
    rdfs:comment "label for the cloud-based assertion (eg.c2pa.actions)"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range xsd:string .

c2pa:CloudDataMap.location a owl:ObjectProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "a file or http(s) URL to where the bytes that are being hashed can be found"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range c2pa:HashedExtUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:CloudDataMap.size a owl:ObjectProperty ;
    rdfs:label "size"@en ;
    rdfs:comment "Number of bytes of data"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range c2pa:SizeType .

<https://c2pa.org/ontology/CommonSchema.@container> a owl:ObjectProperty ;
    rdfs:label "@container"@en ;
    rdfs:comment "Used to set the default container type for a term"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range c2pa:ContainerGroupChoice .

<https://c2pa.org/ontology/CommonSchema.@id> a owl:DatatypeProperty ;
    rdfs:label "@id"@en ;
    rdfs:comment "Used to uniquely identify things that are being described in the document with IRIs or blank node identifiers"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range xsd:anyURI .

<https://c2pa.org/ontology/CommonSchema.@language> a owl:ObjectProperty ;
    rdfs:label "@language"@en ;
    rdfs:comment "Used to specify the language for a particular string value or the default language of a JSON-LD document"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range c2pa:LanguageTypeChoice .

<https://c2pa.org/ontology/CommonSchema.@type> a owl:ObjectProperty ;
    rdfs:label "@type"@en ;
    rdfs:comment "Used to set the data type of a node or typed value"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range c2pa:TypeTypeChoice .

<https://c2pa.org/ontology/CommonSchema.@value> a owl:ObjectProperty ;
    rdfs:label "@value"@en ;
    rdfs:comment "Used to specify the data that is associated with a particular property in the graph"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range c2pa:ValueTypeChoice .

c2pa:ContextSchema a owl:Class ;
    rdfs:label "ContextSchema"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://c2pa.org/ontology/ContextSchema.@context> ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://c2pa.org/ontology/ContextSchema.@context> ] ;
    owl:sameAs c2pa:context-schema .

<https://c2pa.org/ontology/ContextSchema.@context> a owl:ObjectProperty ;
    rdfs:label "@context"@en ;
    rdfs:comment "Used to express an ordered set of data"@en ;
    rdfs:domain c2pa:ContextSchema ;
    rdfs:range c2pa:ContextTypeChoice ;
    c2pa:relationshipType "has_one" .

c2pa:DataHashMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "byte string of the hash value"@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:DataHashMap.pad a owl:DatatypeProperty ;
    rdfs:label "pad"@en ;
    rdfs:comment "zero-filled byte string used for filling up space"@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:DataMap.offset a owl:DatatypeProperty ;
    rdfs:label "offset"@en ;
    rdfs:comment "Each entry in a map is a Merkle tree rows and the associated data required to enable validation of a single"@en ;
    rdfs:domain c2pa:DataMap ;
    rdfs:range xsd:integer .

c2pa:DataMap.value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:domain c2pa:DataMap ;
    rdfs:range xsd:base64Binary .

c2pa:DepthMeasChoice a owl:Class ;
    rdfs:label "DepthMeasChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:DepthMeasChoice.OpticalAxis c2pa:DepthMeasChoice.OpticRay ) ] .

c2pa:DepthmapGdepthMap.GDepth_Data a owl:ObjectProperty ;
    rdfs:label "GDepth:Data"@en ;
    rdfs:comment "The base64 encoded depth image. Please see GDepth encoding page at developers.google.com. The depthmap will be stretched-to-fit the corresponding color image"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:Base64StringType .

c2pa:DepthmapGdepthMap.GDepth_Far a owl:DatatypeProperty ;
    rdfs:label "GDepth:Far"@en ;
    rdfs:comment "The far value of the depthmap in depth units"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:decimal .

c2pa:DepthmapGdepthMap.GDepth_Format a owl:ObjectProperty ;
    rdfs:label "GDepth:Format"@en ;
    rdfs:comment "The format that describes how to convert the depthmap data into a valid float-point depthmap. Current valid values are 'RangeInverse' and 'RangeLinear'"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:FormatType .

c2pa:DepthmapGdepthMap.GDepth_Mime a owl:ObjectProperty ;
    rdfs:label "GDepth:Mime"@en ;
    rdfs:comment "The mime type for the base64 string describing the depth image content, e.g. 'image/jpeg' or 'image/png'\","@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:MimeType .

c2pa:DepthmapGdepthMap.GDepth_Near a owl:DatatypeProperty ;
    rdfs:label "GDepth:Near"@en ;
    rdfs:comment "The near value of the depthmap in depth units"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:decimal .

c2pa:ExclusionRangeMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "Number of bytes of data to exclude"@en ;
    rdfs:domain c2pa:ExclusionRangeMap ;
    rdfs:range xsd:integer .

c2pa:ExclusionRangeMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "Starting byte of the range"@en ;
    rdfs:domain c2pa:ExclusionRangeMap ;
    rdfs:range xsd:integer .

c2pa:ExclusionsMap.xpath a owl:DatatypeProperty ;
    rdfs:label "xpath"@en ;
    rdfs:comment "Location of box(es) to exclude from the hash starting from the root node as an xpath formatted string of version https://www.w3.org/TR/xpath-10/ with highly constrained syntax."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range xsd:string .

c2pa:FormatChoice a owl:Class ;
    rdfs:label "FormatChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:FormatChoice.RangeInverse c2pa:FormatChoice.RangeLinear ) ] .

c2pa:GeneratorHintsMap a owl:Class ;
    rdfs:label "GeneratorHintsMap"@en ;
    owl:sameAs c2pa:generator-hints-map .

c2pa:HashedExtUriMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute all hashes in this claim, taken from the C2PA hash algorithm identifier list. Unlike alg fields in other types, this field is mandatory here."@en ;
    rdfs:domain c2pa:HashedExtUriMap ;
    rdfs:range xsd:string .

c2pa:HashedExtUriMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "byte string containing the hash value"@en ;
    rdfs:domain c2pa:HashedExtUriMap ;
    rdfs:range xsd:base64Binary .

c2pa:HashedExtUriMap.url a owl:ObjectProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "http/https URI reference"@en ;
    rdfs:domain c2pa:HashedExtUriMap ;
    rdfs:range c2pa:UrlRegexpType .

c2pa:HashedUriMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "byte string containing the hash value"@en ;
    rdfs:domain c2pa:HashedUriMap ;
    rdfs:range xsd:base64Binary .

c2pa:HashedUriMap.url a owl:ObjectProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "JUMBF URI reference"@en ;
    rdfs:domain c2pa:HashedUriMap ;
    rdfs:range c2pa:UrlRegexpType .

c2pa:IngredientMap.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "Media Type of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range xsd:string .

c2pa:IngredientMap.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "name of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range xsd:string .

c2pa:IngredientMap.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "unique identifier, such as the value of the ingredient's `xmpMM:InstanceID`"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range xsd:string .

c2pa:IngredientMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMap.relationship a owl:ObjectProperty ;
    rdfs:label "relationship"@en ;
    rdfs:comment "The relationship of this ingredient to the asset it is an ingredient of."@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:RelationChoice .

c2pa:JsonldSchemaMap.common a owl:ObjectProperty ;
    rdfs:label "common"@en ;
    rdfs:comment "Used to define common things"@en ;
    rdfs:domain c2pa:JsonldSchemaMap ;
    rdfs:range c2pa:CommonSchema ;
    c2pa:relationshipType "has_one" .

c2pa:JsonldSchemaMap.context a owl:ObjectProperty ;
    rdfs:label "context"@en ;
    rdfs:comment "Used to define the short-hand names that are used throughout a JSON-LD document"@en ;
    rdfs:domain c2pa:JsonldSchemaMap ;
    rdfs:range c2pa:ContextSchema ;
    c2pa:relationshipType "has_one" .

c2pa:JsonldSchemaMap.graph a owl:ObjectProperty ;
    rdfs:label "graph"@en ;
    rdfs:comment "Used to express a graph"@en ;
    rdfs:domain c2pa:JsonldSchemaMap ;
    rdfs:range c2pa:GraphType ;
    c2pa:relationshipType "has_one" .

c2pa:MerkleMap.count a owl:DatatypeProperty ;
    rdfs:label "count"@en ;
    rdfs:comment "Number of leaf nodes in the Merkle tree.  Null nodes are not included in this count."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:integer .

c2pa:MerkleMap.localId a owl:DatatypeProperty ;
    rdfs:label "localId"@en ;
    rdfs:comment "Local id used to differentiate across multiple 'mdat' boxes within a single file to determine which Merkle tree should be used to validate that 'mdat' box."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:integer .

c2pa:MerkleMap.uniqueId a owl:DatatypeProperty ;
    rdfs:label "uniqueId"@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:integer .

c2pa:MimeChoice a owl:Class ;
    rdfs:label "MimeChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:MimeChoice.image_jpeg c2pa:MimeChoice.image_png ) ] .

c2pa:RatingMap.value a owl:ObjectProperty ;
    rdfs:label "value"@en ;
    rdfs:domain c2pa:RatingMap ;
    rdfs:range c2pa:IntRange .

<https://c2pa.org/ontology/SchemaOrgThingSchema.@context> a owl:DatatypeProperty ;
    rdfs:label "@context"@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range xsd:string .

c2pa:SchemaOrgThingSchema.additionalType a owl:DatatypeProperty ;
    rdfs:label "additionalType"@en ;
    rdfs:comment "An additional type for the item, typically used for adding more specific types from external vocabularies in microdata syntax. This is a relationship between something and a class that the thing is in. In RDFa syntax, it is better to use the native RDFa syntax - the 'typeof' attribute - for multiple types. Schema.org tools may have only weaker understanding of extra types, in particular those defined externally.\""@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range xsd:anyURI .

c2pa:SchemaOrgThingSchema.alternateName a owl:ObjectProperty ;
    rdfs:label "alternateName"@en ;
    rdfs:comment "An alias for the item"@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range c2pa:Tsrt .

c2pa:SchemaOrgThingSchema.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "A Description for the item"@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range xsd:string .

c2pa:SchemaOrgThingSchema.disambiguatingDescription a owl:DatatypeProperty ;
    rdfs:label "disambiguatingDescription"@en ;
    rdfs:comment "\"image\": $image-type-choice, ; An image of the item. This can be a URL or a fully described ImageObject."@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range xsd:string .

c2pa:SchemaOrgThingSchema.image a owl:ObjectProperty ;
    rdfs:label "image"@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range c2pa:ImageTypeChoice ;
    c2pa:relationshipType "has_one" .

c2pa:SchemaOrgThingSchema.mainEntityOfPage a owl:ObjectProperty ;
    rdfs:label "mainEntityOfPage"@en ;
    rdfs:comment "Indicates a page (or other CreativeWork) for which this thing is the main entity being described. See background notes for details. Inverse property mainEntity."@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range c2pa:EntityTypeChoice ;
    c2pa:relationshipType "has_one" .

c2pa:SchemaOrgThingSchema.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "the name of the action"@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range xsd:string .

c2pa:SchemaOrgThingSchema.potentialAction a owl:ObjectProperty ;
    rdfs:label "potentialAction"@en ;
    rdfs:comment "Indicates a potential Action, which describes an idealized action in which this thing would play an 'object' role"@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema .

c2pa:SchemaOrgThingSchema.sameAs a owl:DatatypeProperty ;
    rdfs:label "sameAs"@en ;
    rdfs:comment "URL of a reference Web page that unambiguously indicates the item's identity. E.g. the URL of the item's Wikipedia page, Freebase page, or official website.\""@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range xsd:anyURI .

c2pa:SchemaOrgThingSchema.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "url of the item"@en ;
    rdfs:domain c2pa:SchemaOrgThingSchema ;
    rdfs:range xsd:anyURI .

c2pa:SoftBindingBlockMap.scope a owl:ObjectProperty ;
    rdfs:label "scope"@en ;
    rdfs:comment "CBOR byte string describing, in algorithm specific format,"@en ;
    rdfs:domain c2pa:SoftBindingBlockMap ;
    rdfs:range c2pa:SoftBindingScopeMap ;
    c2pa:relationshipType "has_one" .

c2pa:SoftBindingBlockMap.value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:domain c2pa:SoftBindingBlockMap ;
    rdfs:range xsd:base64Binary .

c2pa:SoftBindingMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the soft binding algorithm and version of that algorithm used"@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range xsd:string .

c2pa:SoftBindingMap.pad a owl:DatatypeProperty ;
    rdfs:label "pad"@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range xsd:base64Binary .

c2pa:SoftBindingTimespanMap.end a owl:DatatypeProperty ;
    rdfs:label "end"@en ;
    rdfs:comment "End of the time range (as milliseconds from media start) over which the soft binding value has been computed."@en ;
    rdfs:domain c2pa:SoftBindingTimespanMap ;
    rdfs:range xsd:integer .

c2pa:SoftBindingTimespanMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:domain c2pa:SoftBindingTimespanMap ;
    rdfs:range xsd:integer .

c2pa:SourceMap.type a owl:ObjectProperty ;
    rdfs:label "type"@en ;
    rdfs:domain c2pa:SourceMap ;
    rdfs:range c2pa:SourceType .

c2pa:StatusMap.code a owl:ObjectProperty ;
    rdfs:label "code"@en ;
    rdfs:domain c2pa:StatusMap ;
    rdfs:range c2pa:StatusCode .

c2pa:SubsetMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "(optional) Length that a leafmost box must have to exclude from the hash."@en ;
    rdfs:domain c2pa:SubsetMap ;
    rdfs:range xsd:integer .

c2pa:SubsetMap.offset a owl:DatatypeProperty ;
    rdfs:label "offset"@en ;
    rdfs:comment "Each entry in a map is a Merkle tree rows and the associated data required to enable validation of a single"@en ;
    rdfs:domain c2pa:SubsetMap ;
    rdfs:range xsd:integer .

c2pa:Tsttoken a owl:Class ;
    rdfs:label "Tsttoken"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:Tsttoken.val ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:Tsttoken.val ] ;
    owl:sameAs c2pa:tstToken .

c2pa:Tsttoken.val a owl:DatatypeProperty ;
    rdfs:label "val"@en ;
    rdfs:domain c2pa:Tsttoken ;
    rdfs:range xsd:base64Binary .

c2pa:UnitChoice a owl:Class ;
    rdfs:label "UnitChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:UnitChoice.m c2pa:UnitChoice.mm ) ] .

c2pa:DataMap a owl:Class ;
    rdfs:label "DataMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DataMap.value ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DataMap.offset ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DataMap.value ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DataMap.offset ] ;
    owl:sameAs c2pa:data-map .

c2pa:ExclusionRangeMap a owl:Class ;
    rdfs:label "ExclusionRangeMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ExclusionRangeMap.length ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ExclusionRangeMap.start ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ExclusionRangeMap.length ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ExclusionRangeMap.start ] ;
    owl:sameAs c2pa:EXCLUSION_RANGE-map .

c2pa:JsonldSchemaMap a owl:Class ;
    rdfs:label "JsonldSchemaMap"@en ;
    rdfs:comment "Schema for JSON-LD CDDL"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:JsonldSchemaMap.graph ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:JsonldSchemaMap.context ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:JsonldSchemaMap.common ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:JsonldSchemaMap.graph ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:JsonldSchemaMap.common ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:JsonldSchemaMap.context ] ;
    owl:sameAs c2pa:jsonld-schema-map .

c2pa:ParametersMap a owl:Class ;
    rdfs:label "ParametersMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ParametersMap.description ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ParametersMap.ingredient ] ;
    owl:sameAs c2pa:parameters-map .

c2pa:RelationChoice a owl:Class ;
    rdfs:label "RelationChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:RelationChoice.parentOf c2pa:RelationChoice.componentOf ) ] .

c2pa:SoftBindingBlockMap a owl:Class ;
    rdfs:label "SoftBindingBlockMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingBlockMap.scope ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingBlockMap.value ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingBlockMap.value ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingBlockMap.scope ] ;
    owl:sameAs c2pa:soft-binding-block-map .

c2pa:SoftBindingScopeMap a owl:Class ;
    rdfs:label "SoftBindingScopeMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingScopeMap.timespan ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingScopeMap.extent ] ;
    owl:sameAs c2pa:soft-binding-scope-map .

c2pa:SoftBindingTimespanMap a owl:Class ;
    rdfs:label "SoftBindingTimespanMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingTimespanMap.end ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingTimespanMap.start ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingTimespanMap.start ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SoftBindingTimespanMap.end ] ;
    owl:sameAs c2pa:soft-binding-timespan-map .

c2pa:SubsetMap a owl:Class ;
    rdfs:label "SubsetMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SubsetMap.offset ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SubsetMap.length ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SubsetMap.offset ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SubsetMap.length ] ;
    owl:sameAs c2pa:subset-map .

c2pa:ActorMap a owl:Class ;
    rdfs:label "ActorMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ActorMap.identifier ] ;
    owl:sameAs c2pa:actor-map .

c2pa:BmffMerkleMap a owl:Class ;
    rdfs:label "BmffMerkleMap"@en ;
    rdfs:comment "The data structure used to store sufficient information to validate a single 'mdat' box or a portion of an 'mdat' box when a Merkle tree is used\","@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:BmffMerkleMap.location ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:BmffMerkleMap.uniqueId ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:BmffMerkleMap.uniqueId ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:BmffMerkleMap.localId ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:BmffMerkleMap.localId ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:BmffMerkleMap.location ] ;
    owl:sameAs c2pa:bmff-merkle-map .

c2pa:HashedExtUriMap a owl:Class ;
    rdfs:label "HashedExtUriMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedExtUriMap.url ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedExtUriMap.hash ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedExtUriMap.url ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedExtUriMap.alg ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedExtUriMap.alg ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedExtUriMap.hash ] ;
