c2pa:StatusCodesMap.failure a owl:ObjectProperty ;
    rdfs:label "failure"@en ;
    rdfs:comment "an array of validation failure codes. May be empty."@en ;
    rdfs:domain c2pa:StatusCodesMap ;
    rdfs:range c2pa:StatusMap ;
    c2pa:relationshipType "has_many" .

c2pa:StatusCodesMap.informational a owl:ObjectProperty ;
    rdfs:label "informational"@en ;
    rdfs:comment "an array of validation informational codes. May be empty."@en ;
    rdfs:domain c2pa:StatusCodesMap ;
    rdfs:range c2pa:StatusMap ;
    c2pa:relationshipType "has_many" .

c2pa:StatusCodesMap.success a owl:ObjectProperty ;
    rdfs:label "success"@en ;
    rdfs:comment "DEPRECATED. Does the code reflect success (true) or failure (false)"@en ;
    rdfs:domain c2pa:StatusCodesMap ;
    rdfs:range c2pa:StatusMap ;
    c2pa:relationshipType "has_many" .

c2pa:UnhashedExtUriMap.data_types a owl:ObjectProperty ;
    rdfs:label "data_types"@en ;
    rdfs:comment "additional information about the data's type"@en ;
    rdfs:domain c2pa:UnhashedExtUriMap ;
    rdfs:range c2pa:AssetTypeMap ;
    c2pa:relationshipType "has_many" .

c2pa:UriHashedDataMap.data_types a owl:ObjectProperty ;
    rdfs:label "data_types"@en ;
    rdfs:comment "additional information about the data's type"@en ;
    rdfs:domain c2pa:UriHashedDataMap ;
    rdfs:range c2pa:AssetTypeMap ;
    c2pa:relationshipType "has_many" .

c2pa:ValidationResultsMap.ingredientDeltas a owl:ObjectProperty ;
    rdfs:label "ingredientDeltas"@en ;
    rdfs:comment "List of any changes/deltas between the current and previous validation results for each ingredient's manifest. Present if the the ingredient is a C2PA asset."@en ;
    rdfs:domain c2pa:ValidationResultsMap ;
    rdfs:range c2pa:IngredientDeltaValidationResultMap ;
    c2pa:relationshipType "belongs_to" .

c2pa:actionItemV2.changes a owl:ObjectProperty ;
    rdfs:label "changes"@en ;
    rdfs:comment "Regions of interest of the resource that were changed"@en ;
    rdfs:domain c2pa:actionItemV2 ;
    rdfs:range c2pa:RegionMap ;
    c2pa:relationshipType "has_many" .

c2pa:actionItemV2.related a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "related"@en ;
    rdfs:comment "List of related actions"@en ;
    rdfs:domain c2pa:actionItemV2 ;
    rdfs:range xsd:string,
        c2pa:actionItemV2 ;
    c2pa:relationshipType "has_many" .

c2pa:actionsAssertionV2.softwareAgents a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "softwareAgents"@en ;
    rdfs:comment "List of software/hardware that performed the actions (generator-info maps)"@en ;
    rdfs:domain c2pa:actionsAssertionV2 ;
    rdfs:range xsd:string,
        c2pa:softwareAgent ;
    c2pa:relationshipType "has_many" .

c2pa:actionsAssertionV2.templates a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "templates"@en ;
    rdfs:comment "List of templates for the actions"@en ;
    rdfs:domain c2pa:actionsAssertionV2 ;
    rdfs:range xsd:string,
        c2pa:actionTemplateV2 ;
    c2pa:relationshipType "has_many" .

c2pa:assertionMetadataMap.localizations a owl:ObjectProperty ;
    rdfs:label "localizations"@en ;
    rdfs:comment "Localizations for strings in the assertion"@en ;
    rdfs:domain c2pa:assertionMetadataMap ;
    rdfs:range c2pa:LocalizationDataEntry ;
    c2pa:relationshipType "has_many" .

c2pa:assertionMetadataMap.reviewRatings a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "reviewRatings"@en ;
    rdfs:comment "Ratings given to the assertion"@en ;
    rdfs:domain c2pa:assertionMetadataMap ;
    rdfs:range xsd:string,
        c2pa:ratingMap ;
    c2pa:relationshipType "has_many" .

c2pa:bmffExclusionsMap.data a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "data"@en ;
    rdfs:comment "Data at relative byte offset that must match for box to be excluded"@en ;
    rdfs:domain c2pa:bmffExclusionsMap ;
    rdfs:range xsd:string,
        c2pa:bmffDataMap ;
    c2pa:relationshipType "has_many" .

c2pa:bmffExclusionsMap.subset a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "subset"@en ;
    rdfs:comment "Portion of the excluded box that is excluded from the hash"@en ;
    rdfs:domain c2pa:bmffExclusionsMap ;
    rdfs:range xsd:string,
        c2pa:bmffSubsetMap ;
    c2pa:relationshipType "has_many" .

c2pa:bmffMerkleMap.variableBlockSizes a owl:DatatypeProperty ;
    rdfs:label "variableBlockSizes"@en ;
    rdfs:comment "Size in bytes of each leaf node (non-fragmented MP4); length equals count"@en ;
    rdfs:domain c2pa:bmffMerkleMap ;
    rdfs:range xsd:string .

c2pa:boxHashMap.exclusions a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "exclusions"@en ;
    rdfs:comment "Hash exclusion ranges; ranges have monotonically increasing start values and do not overlap"@en ;
    rdfs:domain c2pa:boxHashMap ;
    rdfs:range xsd:string,
        c2pa:boxExclusionsMap ;
    c2pa:relationshipType "has_many" .

c2pa:claim.gathered_assertions a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "gathered_assertions"@en ;
    rdfs:comment "Hashed URI references to gathered assertions"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range xsd:string,
        c2pa:hashedUriMap ;
    c2pa:relationshipType "has_many" .

c2pa:claim.redacted_assertions a owl:DatatypeProperty ;
    rdfs:label "redacted_assertions"@en ;
    rdfs:comment "JUMBF URI references to the assertions of ingredient manifests being redacted"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range xsd:string .

c2pa:claimV1.redacted_assertions a owl:DatatypeProperty ;
    rdfs:label "redacted_assertions"@en ;
    rdfs:comment "JUMBF URI references to redacted ingredient manifest assertions"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string .

c2pa:hashBmffAssertion.merkle a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "merkle"@en ;
    rdfs:comment "Merkle tree rows for verification of mdat box(es) or fragment files"@en ;
    rdfs:domain c2pa:hashBmffAssertion ;
    rdfs:range xsd:string,
        c2pa:bmffMerkleMap ;
    c2pa:relationshipType "has_many" .

c2pa:hashDataAssertion.exclusions a owl:DatatypeProperty ;
    rdfs:label "exclusions"@en ;
    rdfs:domain c2pa:hashDataAssertion ;
    rdfs:range xsd:string .

c2pa:hashedExtUriMap.data_types a owl:DatatypeProperty ;
    rdfs:label "data_types"@en ;
    rdfs:comment "Additional information about the data's type (optional)"@en ;
    rdfs:domain c2pa:hashedExtUriMap ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV1.validationStatus a owl:DatatypeProperty ;
    rdfs:label "validationStatus"@en ;
    rdfs:comment "Validation status of the ingredient"@en ;
    rdfs:domain c2pa:ingredientAssertionV1 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV2.data_types a owl:DatatypeProperty ;
    rdfs:label "data_types"@en ;
    rdfs:comment "Additional information about the data's type"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV2.validationStatus a owl:DatatypeProperty ;
    rdfs:label "validationStatus"@en ;
    rdfs:comment "Validation status of the ingredient"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV3.dataTypes a owl:DatatypeProperty ;
    rdfs:label "dataTypes"@en ;
    rdfs:comment "Additional information about the data's type (v3 camelCase)"@en ;
    rdfs:domain c2pa:ingredientAssertionV3 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV3.softBindingAlgorithmsMatched a owl:DatatypeProperty ;
    rdfs:label "softBindingAlgorithmsMatched"@en ;
    rdfs:comment "Array of algorithm names used for discovering the active manifest"@en ;
    rdfs:domain c2pa:ingredientAssertionV3 ;
    rdfs:range xsd:string .

c2pa:manifest.ingredientDeltas a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "ingredientDeltas"@en ;
    rdfs:comment "Validation deltas for this manifest's ingredient assertions. Present when ingredients are C2PA assets."@en ;
    rdfs:domain c2pa:manifest ;
    rdfs:range xsd:string,
        c2pa:ingredientDeltaValidationResult ;
    c2pa:relationshipType "belongs_to" .

c2pa:parametersMapV2.ingredients a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "ingredients"@en ;
    rdfs:comment "List of hashed JUMBF URIs to ingredient (v2 or v3) assertion(s) this action acts on"@en ;
    rdfs:domain c2pa:parametersMapV2 ;
    rdfs:range xsd:string,
        c2pa:hashedUriMap ;
    c2pa:relationshipType "belongs_to" .

c2pa:validationResults.ingredientDeltas a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "ingredientDeltas"@en ;
    rdfs:comment "Validation deltas per ingredient assertion. Present when the ingredient is a C2PA asset."@en ;
    rdfs:domain c2pa:validationResults ;
    rdfs:range xsd:string,
        c2pa:ingredientDeltaValidationResult ;
    c2pa:relationshipType "belongs_to" .

c2pa:ActionCommonMapV2.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Additional description of the action"@en ;
    rdfs:domain c2pa:ActionCommonMapV2 ;
    rdfs:range xsd:string .

c2pa:ActionCommonMapV2.digitalSourceType a owl:DatatypeProperty ;
    rdfs:label "digitalSourceType"@en ;
    rdfs:comment "One of the defined source types at https://cv.iptc.org/newscodes/digitalsourcetype/"@en ;
    rdfs:domain c2pa:ActionCommonMapV2 ;
    rdfs:range xsd:string .

c2pa:ActionCommonMapV2.softwareAgent a owl:ObjectProperty ;
    rdfs:label "softwareAgent"@en ;
    rdfs:comment "The software agent that performed the action."@en ;
    rdfs:domain c2pa:ActionCommonMapV2 ;
    rdfs:range c2pa:GeneratorInfoMap ;
    c2pa:relationshipType "has_one" .

c2pa:ActionCommonMapV2.softwareAgentIndex a owl:DatatypeProperty ;
    rdfs:label "softwareAgentIndex"@en ;
    rdfs:comment "0-based index into the softwareAgents array in the actions-map-2"@en ;
    rdfs:domain c2pa:ActionCommonMapV2 ;
    rdfs:range xsd:integer .

c2pa:ActionItemMapV2.parameters a owl:ObjectProperty ;
    rdfs:label "parameters"@en ;
    rdfs:comment "Additional parameters of the action. These will often vary by the type of action"@en ;
    rdfs:domain c2pa:ActionItemMapV2 ;
    rdfs:range c2pa:ParametersMapV2 ;
    c2pa:relationshipType "has_one" .

c2pa:ActionItemMapV2.reason a owl:ObjectProperty ;
    rdfs:label "reason"@en ;
    rdfs:comment "the reason why this action was performed, required when the action is `c2pa.redacted`"@en ;
    rdfs:domain c2pa:ActionItemMapV2 ;
    rdfs:range c2pa:ActionReason .

c2pa:ActionItemMapV2.when a owl:DatatypeProperty ;
    rdfs:label "when"@en ;
    rdfs:comment "time-stamp of when the action occurred."@en ;
    rdfs:domain c2pa:ActionItemMapV2 ;
    rdfs:range xsd:dateTime .

c2pa:ActionItemsMap.changed a owl:DatatypeProperty ;
    rdfs:label "changed"@en ;
    rdfs:comment "A semicolon-delimited list of the parts of the resource that were changed since the previous event history. If not present, presumed to be undefined. When tracking changes and the scope of the changed components is unknown, it can be assumed that anything could have changed."@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range xsd:string .

c2pa:ActionItemsMap.digitalSourceType a owl:DatatypeProperty ;
    rdfs:label "digitalSourceType"@en ;
    rdfs:comment "One of the defined source types at https://cv.iptc.org/newscodes/digitalsourcetype/"@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range xsd:string .

c2pa:ActionItemsMap.instanceID a owl:ObjectProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "The value of the xmpMM:InstanceID property for the modified (output) resource"@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range c2pa:Buuid .

c2pa:ActionItemsMap.parameters a owl:ObjectProperty ;
    rdfs:label "parameters"@en ;
    rdfs:comment "Additional parameters of the action. These will often vary by the type of action"@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range c2pa:ParametersMap ;
    c2pa:relationshipType "has_one" .

c2pa:ActionItemsMap.softwareAgent a owl:DatatypeProperty ;
    rdfs:label "softwareAgent"@en ;
    rdfs:comment "The software agent that performed the action."@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range xsd:string .

c2pa:ActionItemsMap.when a owl:DatatypeProperty ;
    rdfs:label "when"@en ;
    rdfs:comment "time-stamp of when the action occurred."@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range xsd:dateTime .

c2pa:ActionTemplateMapV2.icon a owl:ObjectProperty ;
    rdfs:label "icon"@en ;
    rdfs:comment "hashed_uri reference to an embedded data assertion"@en ;
    rdfs:domain c2pa:ActionTemplateMapV2 ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:ActionTemplateMapV2.templateParameters a owl:ObjectProperty ;
    rdfs:label "templateParameters"@en ;
    rdfs:comment "Additional parameters of the template."@en ;
    rdfs:domain c2pa:ActionTemplateMapV2 ;
    rdfs:range c2pa:ParametersCommonMapV2 .

c2pa:ActionsMap.actions a owl:ObjectProperty ;
    rdfs:label "actions"@en ;
    rdfs:comment "list of actions"@en ;
    rdfs:domain c2pa:ActionsMap ;
    rdfs:range c2pa:ActionItemsMap ;
    c2pa:relationshipType "has_many" .

c2pa:ActionsMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:ActionsMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:ActionsMapV2.actions a owl:ObjectProperty ;
    rdfs:label "actions"@en ;
    rdfs:comment "list of actions"@en ;
    rdfs:domain c2pa:ActionsMapV2 ;
    rdfs:range c2pa:ActionItemMapV2 ;
    c2pa:relationshipType "has_many" .

c2pa:ActionsMapV2.allActionsIncluded a owl:DatatypeProperty ;
    rdfs:label "allActionsIncluded"@en ;
    rdfs:comment "If true, indicates that all actions performed are included in an actions assertion"@en ;
    rdfs:domain c2pa:ActionsMapV2 ;
    rdfs:range xsd:boolean .

c2pa:ActionsMapV2.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:ActionsMapV2 ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:AraReferenceBlockMap.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:domain c2pa:AraReferenceBlockMap ;
    rdfs:range xsd:string .

c2pa:AssertionMetadataMap.dataSource a owl:ObjectProperty ;
    rdfs:label "dataSource"@en ;
    rdfs:comment "A description of the source of the assertion data, selected from a predefined list"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range c2pa:SourceMap ;
    c2pa:relationshipType "has_one" .

c2pa:AssertionMetadataMap.dateTime a owl:DatatypeProperty ;
    rdfs:label "dateTime"@en ;
    rdfs:comment "The RFC 3339 date-time string when the assertion was created/generated"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range xsd:dateTime .

c2pa:AssertionMetadataMap.processEnd a owl:DatatypeProperty ;
    rdfs:label "processEnd"@en ;
    rdfs:comment "RFC 3339 date-time when the process ended (advisory, not a trusted timestamp)"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range xsd:dateTime .

c2pa:AssertionMetadataMap.processStart a owl:DatatypeProperty ;
    rdfs:label "processStart"@en ;
    rdfs:comment "RFC 3339 date-time when the process began (advisory, not a trusted timestamp)"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range xsd:dateTime .

c2pa:AssertionMetadataMap.reference a owl:ObjectProperty ;
    rdfs:label "reference"@en ;
    rdfs:comment "hashed_uri reference to another assertion that this review is about"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:AssertionMetadataMap.regionOfInterest a owl:ObjectProperty ;
    rdfs:label "regionOfInterest"@en ;
    rdfs:comment "describes a region of the asset where this assertion is relevant"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range c2pa:RegionMap ;
    c2pa:relationshipType "has_one" .

c2pa:AssetRefMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:domain c2pa:AssetRefMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:AssetRefMap.references a owl:ObjectProperty ;
    rdfs:label "references"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:AssetRefMap ;
    rdfs:range c2pa:AraReferenceBlockMap ;
    c2pa:relationshipType "has_many" .

c2pa:AssetTypeMap.version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "The version of the asset type, if applicable. This is a SemVer formatted string."@en ;
    rdfs:domain c2pa:AssetTypeMap ;
    rdfs:range xsd:string .

c2pa:AssetTypes.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "IANA media type of the asset"@en ;
    rdfs:domain c2pa:AssetTypes ;
    rdfs:range xsd:string .

c2pa:AssetTypes.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:AssetTypes ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:BmffHashMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hashes in this Merkle tree, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken from the `alg` value of the enclosing structure as defined by that structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range xsd:string .

c2pa:BmffHashMap.exclusions a owl:ObjectProperty ;
    rdfs:label "exclusions"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute this hash, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken from an enclosing structure as defined by that structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range c2pa:ExclusionsMap ;
    c2pa:relationshipType "has_many" .

c2pa:BmffHashMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "For non-fragmented MP4, this is the hash of the entire BMFF file excluding boxes listed in the exclusions array.  For fragmented MP4 (live or VOD), this field is the hash of the segment excluding boxes listed in the exclusions array."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:BmffHashMap.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "optional) a human-readable description of what this hash covers."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range xsd:string .

c2pa:BmffHashMap.sequenceNumber a owl:DatatypeProperty ;
    rdfs:label "sequenceNumber"@en ;
    rdfs:comment "in a live video workflow, the monotonically increasing sequence number for each segment"@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range xsd:integer .

c2pa:BmffHashMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "Unused and deprecated."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range xsd:anyURI .

c2pa:BoxExclusionsMap.boxIndex a owl:DatatypeProperty ;
    rdfs:label "boxIndex"@en ;
    rdfs:comment "0-based index into the names array in the box-hash-map. Can be omitted if the number of box is one."@en ;
    rdfs:domain c2pa:BoxExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:BoxHashMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hash in this assertion, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken the `alg` value of the enclosing structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:BoxHashMap ;
    rdfs:range xsd:string .

c2pa:BoxHashMap.excluded a owl:DatatypeProperty ;
    rdfs:label "excluded"@en ;
    rdfs:comment "A boolean value indicating whether a validator can ignore this box ( & associated hash) during validation. If this field is absent, the box is hashed and the values compared."@en ;
    rdfs:domain c2pa:BoxHashMap ;
    rdfs:range xsd:boolean .

c2pa:BoxHashMap.names a owl:ObjectProperty ;
    rdfs:label "names"@en ;
    rdfs:comment "An array of strings representing the box identifiers in order of appearance (e.g., `APP0`, `IHDR`)"@en ;
    rdfs:domain c2pa:BoxHashMap ;
    rdfs:range c2pa:BoxName .

c2pa:BoxHashMap.pad a owl:DatatypeProperty ;
    rdfs:label "pad"@en ;
    rdfs:comment "zero-filled byte string used for filling up space"@en ;
    rdfs:domain c2pa:BoxHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:BoxHashMap.pad2 a owl:DatatypeProperty ;
    rdfs:label "pad2"@en ;
    rdfs:comment "zero-filled byte string used for filling up space"@en ;
    rdfs:domain c2pa:BoxHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:BoxMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hash in this assertion, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken the `alg` value of the enclosing structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:BoxMap ;
    rdfs:range xsd:string .

c2pa:BoxMap.boxes a owl:ObjectProperty ;
    rdfs:label "boxes"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hash in this assertion, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken the `alg` value of the enclosing structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:BoxMap ;
    rdfs:range c2pa:BoxHashMap ;
    c2pa:relationshipType "has_many" .

c2pa:CertificateStatusMap a owl:Class ;
    rdfs:label "CertificateStatusMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CertificateStatusMap.ocspVals ] ;
    owl:sameAs c2pa:certificate-status-map .

c2pa:CertificateStatusMap.ocspVals a owl:DatatypeProperty ;
    rdfs:label "ocspVals"@en ;
    rdfs:domain c2pa:CertificateStatusMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute all data hash assertions listed in this claim unless otherwise overridden, taken from the C2PA data hash algorithm identifier registry. This provides the value for the 'alg' field in data-hash and hashed-uri structures contained in this claim"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.alg_soft a owl:DatatypeProperty ;
    rdfs:label "alg_soft"@en ;
    rdfs:comment "A string identifying the algorithm used to compute all soft binding assertions listed in this claim unless otherwise overridden, taken from the C2PA soft binding algorithm identifier registry.\""@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.assertions a owl:ObjectProperty ;
    rdfs:label "assertions"@en ;
    rdfs:comment "media type of the asset"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_many" .

c2pa:ClaimMap.claim_generator_info a owl:ObjectProperty ;
    rdfs:label "claim_generator_info"@en ;
    rdfs:comment "JUMBF URI reference to the signature of this claim"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range c2pa:GeneratorInfoMap ;
    c2pa:relationshipType "has_many" .

c2pa:ClaimMap.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "name of the asset"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:ClaimMapV2.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute all data hash assertions listed in this claim unless otherwise overridden, taken from the C2PA data hash algorithm identifier registry. This provides the value for the 'alg' field in data-hash and hashed-uri structures contained in this claim"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range xsd:string .

c2pa:ClaimMapV2.alg_soft a owl:DatatypeProperty ;
    rdfs:label "alg_soft"@en ;
    rdfs:comment "A string identifying the algorithm used to compute all soft binding assertions listed in this claim unless otherwise overridden, taken from the C2PA soft binding algorithm identifier registry.\""@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range xsd:string .

c2pa:ClaimMapV2.created_assertions a owl:ObjectProperty ;
    rdfs:label "created_assertions"@en ;
    rdfs:comment "name of the asset (metadata assertion preferred)"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_many" .

c2pa:ClaimMapV2.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "name of the asset"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range xsd:string .

c2pa:ClaimMapV2.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:ClaimMapV2.specVersion a owl:DatatypeProperty ;
    rdfs:label "specVersion"@en ;
    rdfs:comment "The version of the specification used to produce this claim (SemVer)"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range xsd:string ;
    owl:deprecated true .

c2pa:CloudDataMap.content_type a owl:DatatypeProperty ;
    rdfs:label "content_type"@en ;
    rdfs:comment "media/MIME type for the data"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range xsd:string ;
    c2pa:pattern "^[-\\\\w.]+/[-+\\\\w.]+$" .

c2pa:CloudDataMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:CollectionDataHashMap.uris a owl:ObjectProperty ;
    rdfs:label "uris"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hash on each entry of the `uris` array, taken from the C2PA hash algorithm identifier list."@en ;
    rdfs:domain c2pa:CollectionDataHashMap ;
    rdfs:range c2pa:UriHashedDataMap ;
    c2pa:relationshipType "has_many" .

c2pa:CollectionDataHashMap.zip_central_directory_hash a owl:DatatypeProperty ;
    rdfs:label "zip_central_directory_hash"@en ;
    rdfs:comment "The data structure used to store a reference to a URI and its hash."@en ;
    rdfs:domain c2pa:CollectionDataHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:ContentCredentialsJSONcrJSONDocumentSchema.manifests a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "manifests"@en ;
    rdfs:comment "Array of C2PA manifests embedded in the asset"@en ;
    rdfs:domain c2pa:ContentCredentialsJSONcrJSONDocumentSchema ;
    rdfs:range xsd:string,
        c2pa:manifest ;
    c2pa:relationshipType "has_many" .

c2pa:ContextTypeChoice a owl:Class ;
    rdfs:label "ContextTypeChoice"@en ;
    owl:sameAs <https://c2pa.org/ontology/$context-type-choice> ;
    c2pa:extensible true .

c2pa:DataHashMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hash in this assertion, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken the `alg` value of the enclosing structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:string .

c2pa:DataHashMap.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "(optional) a human-readable description of what this hash cover"@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:string .

c2pa:DataHashMap.pad2 a owl:DatatypeProperty ;
    rdfs:label "pad2"@en ;
    rdfs:comment "zero-filled byte string used for filling up space"@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:DataHashMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "Unused and deprecated."@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:anyURI .

c2pa:DepthMeasChoice.OpticRay a owl:NamedIndividual,
        c2pa:DepthMeasChoice ;
    rdfs:label "OpticRay"@en .

c2pa:DepthMeasChoice.OpticalAxis a owl:NamedIndividual,
        c2pa:DepthMeasChoice ;
    rdfs:label "OpticalAxis"@en .

c2pa:DepthmapGdepthMap.GDepth_Confidence a owl:ObjectProperty ;
    rdfs:label "GDepth:Confidence"@en ;
    rdfs:comment "The base64 encoded confidence image. See GDepth encoding page at developers.google.com. The confidence map should have the same size as the depthmap"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:Base64StringType .

c2pa:DepthmapGdepthMap.GDepth_ConfidenceMime a owl:ObjectProperty ;
    rdfs:label "GDepth:ConfidenceMime"@en ;
    rdfs:comment "The mime type for the base64 string describing the confidence image content, e.g. 'image/png'.\","@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:ConfidenceMimeType .

c2pa:DepthmapGdepthMap.GDepth_ImageHeight a owl:DatatypeProperty ;
    rdfs:label "GDepth:ImageHeight"@en ;
    rdfs:comment "The height in pixels of the original color image associated to this depthmap. This is NOT the depthmap height. If present, apps must update this property when scaling, cropping or rotating the color image. Clients use this property to verify the integrity of the depthmap w.r.t. the color image"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:decimal .

c2pa:DepthmapGdepthMap.GDepth_ImageWidth a owl:DatatypeProperty ;
    rdfs:label "GDepth:ImageWidth"@en ;
    rdfs:comment "The width in pixels of the original color image associated to this depthmap. This is NOT the depthmap width. If present, apps must update this property when scaling, cropping or rotating the color image. Clients use this property to verify the integrity of the depthmap w.r.t. the color image"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:decimal .

c2pa:DepthmapGdepthMap.GDepth_Manufacturer a owl:DatatypeProperty ;
    rdfs:label "GDepth:Manufacturer"@en ;
    rdfs:comment "The manufacturer of the device that created this depthmap"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:string .

c2pa:DepthmapGdepthMap.GDepth_MeasureType a owl:ObjectProperty ;
    rdfs:label "GDepth:MeasureType"@en ;
    rdfs:comment "The type of depth measurement. Current valid values are 'OpticalAxis' and 'OpticRay"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:DepthMeasType .

c2pa:DepthmapGdepthMap.GDepth_Model a owl:DatatypeProperty ;
    rdfs:label "GDepth:Model"@en ;
    rdfs:comment "The model of the device that created this depthmap"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:string .

c2pa:DepthmapGdepthMap.GDepth_Software a owl:DatatypeProperty ;
    rdfs:label "GDepth:Software"@en ;
    rdfs:comment "The software that created this depthmap"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:string .

c2pa:DepthmapGdepthMap.GDepth_Units a owl:ObjectProperty ;
    rdfs:label "GDepth:Units"@en ;
    rdfs:comment "The units of the depthmap, e.g. 'm' for meters or 'mm' for millimeters"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:UnitType .

c2pa:DepthmapGdepthMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:EndorsementTargetMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:EndorsementTargetMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:EnvironmentalSustainabilityMap.carbon_kgco2e a owl:ObjectProperty ;
    rdfs:label "carbon_kgco2e"@en ;
    rdfs:domain c2pa:EnvironmentalSustainabilityMap ;
    rdfs:range c2pa:EnvironmentalSustainabilityMeasurementMap ;
    c2pa:relationshipType "has_one" .

c2pa:EnvironmentalSustainabilityMap.energy_kwh a owl:ObjectProperty ;
    rdfs:label "energy_kwh"@en ;
    rdfs:comment "allow for any other custom use case"@en ;
    rdfs:domain c2pa:EnvironmentalSustainabilityMap ;
    rdfs:range c2pa:EnvironmentalSustainabilityMeasurementMap ;
    c2pa:relationshipType "has_one" .

c2pa:EnvironmentalSustainabilityMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:domain c2pa:EnvironmentalSustainabilityMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:EnvironmentalSustainabilityMap.water_litres a owl:ObjectProperty ;
    rdfs:label "water_litres"@en ;
    rdfs:domain c2pa:EnvironmentalSustainabilityMap ;
    rdfs:range c2pa:EnvironmentalSustainabilityMeasurementMap ;
    c2pa:relationshipType "has_one" .

c2pa:EnvironmentalSustainabilityMeasurementMap.measurementMethod a owl:ObjectProperty ;
    rdfs:label "measurementMethod"@en ;
    rdfs:domain c2pa:EnvironmentalSustainabilityMeasurementMap ;
    rdfs:range c2pa:SustainabilityMeasurementMethod .

c2pa:ExclusionsMap.exact a owl:DatatypeProperty ;
    rdfs:label "exact"@en ;
    rdfs:comment "(optional) indicates that flags must be an exact match.  If not specified, defaults to true.  Only specified for a box that inherits from FullBox and when flags is also specified."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range xsd:boolean .

c2pa:ExclusionsMap.flags a owl:ObjectProperty ;
    rdfs:label "flags"@en ;
    rdfs:comment "(optional) byte string of exactly 3 bytes.  The 24-bit flags that must be set in a leafmost box for the box to be excluded from the hash.  Only specified for a box that inherits from FullBox."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range c2pa:FlagT .

c2pa:ExclusionsMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "(optional) Length that a leafmost box must have to exclude from the hash."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:ExclusionsMap.version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "(optional) Version that must be set in a leafmost box for the box to be excluded from the hash.  Only specified for a box that inherits from FullBox."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:ExternalReferenceMap.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "human-readable description of the referenced data"@en ;
    rdfs:domain c2pa:ExternalReferenceMap ;
    rdfs:range xsd:string .

c2pa:ExternalReferenceMap.label a owl:DatatypeProperty ;
    rdfs:label "label"@en ;
    rdfs:comment "label for the referenced assertion, if relevant (e.g., c2pa.metadata)"@en ;
    rdfs:domain c2pa:ExternalReferenceMap ;
    rdfs:range xsd:string .

c2pa:ExternalReferenceMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:ExternalReferenceMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:FontDesignerMap.contribution a owl:DatatypeProperty ;
    rdfs:label "contribution"@en ;
    rdfs:comment "A description of what the designer contributed to the font. For example, 'All the Latin and Arabic characters'."@en ;
    rdfs:domain c2pa:FontDesignerMap ;
    rdfs:range xsd:string .

c2pa:FontDesignerMap.endDate a owl:DatatypeProperty ;
    rdfs:label "endDate"@en ;
    rdfs:comment "When the designer ended contributions to the font design."@en ;
    rdfs:domain c2pa:FontDesignerMap ;
    rdfs:range xsd:dateTime .

c2pa:FontDesignerMap.foundry a owl:ObjectProperty ;
    rdfs:label "foundry"@en ;
    rdfs:comment "The name of the foundry with which the designer was associated when contributing to the font design."@en ;
    rdfs:domain c2pa:FontDesignerMap ;
    rdfs:range c2pa:FontEntityMap ;
    c2pa:relationshipType "has_one" .

c2pa:FontDesignerMap.startDate a owl:DatatypeProperty ;
    rdfs:label "startDate"@en ;
    rdfs:comment "\"When the designer started to contribute to the font design."@en ;
    rdfs:domain c2pa:FontDesignerMap ;
    rdfs:range xsd:dateTime .

c2pa:FontEntityMap.url a owl:ObjectProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "A URL for additional information about this person or foundry."@en ;
    rdfs:domain c2pa:FontEntityMap ;
    rdfs:range c2pa:ExtUrlType .

c2pa:FontFormatChoice.OpenType a owl:NamedIndividual,
        c2pa:FontFormatChoice ;
    rdfs:label "OpenType"@en .

c2pa:FontFormatChoice.TrueType a owl:NamedIndividual,
        c2pa:FontFormatChoice ;
    rdfs:label "TrueType"@en .

c2pa:FontInfoMap.copyrightHolder a owl:ObjectProperty ;
    rdfs:label "copyrightHolder"@en ;
    rdfs:comment "The entity that holds the copyright to the font."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:FontEntityMap ;
    c2pa:relationshipType "has_one" .

c2pa:FontInfoMap.designFoundry a owl:ObjectProperty ;
    rdfs:label "designFoundry"@en ;
    rdfs:comment "The foundry that designed the font."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:FontEntityMap ;
    c2pa:relationshipType "has_one" .

c2pa:FontInfoMap.identifier a owl:DatatypeProperty ;
    rdfs:label "identifier"@en ;
    rdfs:comment "Internal identier of font for foundry or vendor use."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range xsd:string .

c2pa:FontInfoMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:FontInfoMap.releaseDate a owl:DatatypeProperty ;
    rdfs:label "releaseDate"@en ;
    rdfs:comment "The date this version of the font was released or published."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range xsd:dateTime .

c2pa:FontInfoMap.sourceFoundry a owl:ObjectProperty ;
    rdfs:label "sourceFoundry"@en ;
    rdfs:comment "The foundry that distributes the font."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:FontEntityMap ;
    c2pa:relationshipType "has_one" .

c2pa:FontInfoMap.version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "The version of the font in SemVer format."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range xsd:string .

c2pa:FontInfoMap.versionUrl a owl:ObjectProperty ;
    rdfs:label "versionUrl"@en ;
    rdfs:comment "A URL to the release notes associated with this version of the font."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:ExtUrlType .

c2pa:FontParameterCreatedFromVariableFontMap.italic a owl:DatatypeProperty ;
    rdfs:label "italic"@en ;
    rdfs:comment "Get the italic(ital) version of the font."@en ;
    rdfs:domain c2pa:FontParameterCreatedFromVariableFontMap ;
    rdfs:range xsd:boolean .

c2pa:FontParameterCreatedFromVariableFontMap.optical_size a owl:DatatypeProperty ;
    rdfs:label "optical-size"@en ;
    rdfs:comment "The optical size(opsz) of the font, typically you want to match the font size requested."@en ;
    rdfs:domain c2pa:FontParameterCreatedFromVariableFontMap ;
    rdfs:range rdfs:Literal .

c2pa:FontParameterCreatedFromVariableFontMap.slant a owl:ObjectProperty ;
    rdfs:label "slant"@en ;
    rdfs:comment "The slant(slnt) angle of the font."@en ;
    rdfs:domain c2pa:FontParameterCreatedFromVariableFontMap ;
    rdfs:range c2pa:FontSlantRange .

c2pa:FontParameterCreatedFromVariableFontMap.weight a owl:ObjectProperty ;
    rdfs:label "weight"@en ;
    rdfs:comment "Weight(wght) or thickness of the font to be instantiated."@en ;
    rdfs:domain c2pa:FontParameterCreatedFromVariableFontMap ;
    rdfs:range c2pa:FontWeightRange .

c2pa:FontParameterCreatedFromVariableFontMap.width a owl:ObjectProperty ;
    rdfs:label "width"@en ;
    rdfs:comment "Width(wdth) or narrowness of the letterforms of font to be instantiated."@en ;
    rdfs:domain c2pa:FontParameterCreatedFromVariableFontMap ;
    rdfs:range c2pa:FontWidthRange .

c2pa:FontParameterUnicodeRangesMap a owl:Class ;
    rdfs:label "FontParameterUnicodeRangesMap"@en ;
    rdfs:comment "Font parameter used by font.subset, font.charactersAdded, font.charactersDeleted, and font.charactersModified."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:FontParameterUnicodeRangesMap.ranges ] ;
    owl:sameAs c2pa:font-parameter-unicode-ranges-map .

c2pa:FontParameterUnicodeRangesMap.ranges a owl:ObjectProperty ;
    rdfs:label "ranges"@en ;
    rdfs:comment "Array of unicode ranges"@en ;
    rdfs:domain c2pa:FontParameterUnicodeRangesMap ;
    rdfs:range c2pa:FontUnicodeRangeMap ;
    c2pa:relationshipType "has_many" .

