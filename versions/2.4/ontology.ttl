            owl:onProperty c2pa:EnvironmentalSustainabilityMap.energy_kwh ] ;
    owl:sameAs c2pa:environmental-sustainability-map .

c2pa:ExternalReferenceMap a owl:Class ;
    rdfs:label "ExternalReferenceMap"@en ;
    rdfs:comment "Assertion that references assertion data stored externally by URI (no hash)"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
