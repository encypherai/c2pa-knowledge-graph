c2pa:FontParameterCreatedFromVariableFontMap a owl:Class ;
    rdfs:label "FontParameterCreatedFromVariableFontMap"@en ;
    rdfs:comment "Font parameters used when creating an instance of a font from a variable font. The different 'variation axis` for the fonts are detailed here.  The tag names for the different axes are in parenthesis in the comments for each parameter."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:FontParameterCreatedFromVariableFontMap.optical_size ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:FontParameterCreatedFromVariableFontMap.italic ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:FontParameterCreatedFromVariableFontMap.width ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:FontParameterCreatedFromVariableFontMap.weight ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:FontParameterCreatedFromVariableFontMap.slant ] ;
    owl:sameAs c2pa:font-parameter-created-from-variable-font-map .

c2pa:StatusCodesMap a owl:Class ;
