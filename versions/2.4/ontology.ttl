c2pa:PartHashMap a owl:Class ;
    rdfs:label "PartHashMap"@en ;
    rdfs:comment "Part hash entry. CDDL: multi-asset-hash.cddl part-hash-map."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
