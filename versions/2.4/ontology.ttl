c2pa:SegmentInfoMap a owl:Class ;
    rdfs:label "SegmentInfoMap"@en ;
    rdfs:comment "The protected header contains the signature algorithm ('alg') and optionally the \"claimed time of signing\" ('iat'). The unprotected header contains the the identifier of the session key ('kid'). The payload is set to the CBOR serialized `segment-info-map`."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SegmentInfoMap.bmffHash ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SegmentInfoMap.sequenceNumber ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SegmentInfoMap.manifestId ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SegmentInfoMap.bmffHash ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SegmentInfoMap.manifestUri ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SegmentInfoMap.sequenceNumber ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SegmentInfoMap.manifestId ] ;
    owl:sameAs c2pa:segment-info-map .

c2pa:ShapeChoice a owl:Class ;
