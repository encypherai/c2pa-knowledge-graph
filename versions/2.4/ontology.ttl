c2pa:AssetTypes.types a owl:ObjectProperty ;
    rdfs:label "types"@en ;
    rdfs:comment "a collection of types related to the asset"@en ;
    rdfs:domain c2pa:AssetTypes ;
    rdfs:range c2pa:AssetTypeMap ;
    c2pa:relationshipType "has_many" .

c2pa:BmffHashMap.merkle a owl:ObjectProperty ;
    rdfs:label "merkle"@en ;
    rdfs:comment "A set of Merkle tree rows and the associated data required to enable verification of a single 'mdat' box, multiple 'mdat' boxes, and/or individual fragment files within the asset."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range c2pa:MerkleMap ;
    c2pa:relationshipType "has_many" .

c2pa:BmffMerkleMap.hashes a owl:DatatypeProperty ;
    rdfs:label "hashes"@en ;
    rdfs:comment "An ordered array representing the set of additional hashes required to reach a hash in the Merkle tree specified in the manifest from leaf-most (peer of this node) to root-most (child of node in manifest).  Note that this array may not be present, e.g. if the manifest itself contains the leaf-most row of the Merkle tree.  Null hashes are not included in this array.  The algorithm used is determined using the `alg` field from the corresponding entry in the `merkle` field array in the BMFF hash structure."@en ;
    rdfs:domain c2pa:BmffMerkleMap ;
    rdfs:range xsd:string .

c2pa:BoxHashMap.exclusions a owl:ObjectProperty ;
    rdfs:label "exclusions"@en ;
    rdfs:comment "An array of hash exclusion ranges. Ranges have monotonically increasing `start` values, and no two ranges may overlap."@en ;
    rdfs:domain c2pa:BoxHashMap ;
    rdfs:range c2pa:BoxExclusionsMap ;
    c2pa:relationshipType "has_many" .

c2pa:ClaimMap.redacted_assertions a owl:DatatypeProperty ;
    rdfs:label "redacted_assertions"@en ;
    rdfs:comment "List of JUMBF URI references to the assertions of ingredient manifests being redacted"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMapV2.gathered_assertions a owl:ObjectProperty ;
    rdfs:label "gathered_assertions"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_many" .

c2pa:ClaimMapV2.redacted_assertions a owl:DatatypeProperty ;
    rdfs:label "redacted_assertions"@en ;
    rdfs:comment "List of JUMBF URI references to the assertions of ingredient manifests being redacted"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range xsd:string .

c2pa:CredentialType a owl:Class ;
    rdfs:label "CredentialType"@en ;
    c2pa:extensible true .

c2pa:DataBoxMap.data_types a owl:ObjectProperty ;
    rdfs:label "data_types"@en ;
    rdfs:comment "additional information about the data's type"@en ;
    rdfs:domain c2pa:DataBoxMap ;
    rdfs:range c2pa:AssetTypeMap ;
    c2pa:relationshipType "has_many" .

c2pa:DataHashMap.exclusions a owl:ObjectProperty ;
    rdfs:label "exclusions"@en ;
    rdfs:comment "Ranges have monotonically increasing `start` values, and no two ranges may overlap."@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range c2pa:ExclusionRangeMap ;
    c2pa:relationshipType "has_many" .

c2pa:ExclusionsMap.data a owl:ObjectProperty ;
    rdfs:label "data"@en ;
    rdfs:comment "(optional) The data in the leafmost box at the specified relative byte offset must be identical to the specified data for the box to be excluded from the hash."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range c2pa:DataMap ;
    c2pa:relationshipType "has_many" .

c2pa:ExclusionsMap.subset a owl:ObjectProperty ;
    rdfs:label "subset"@en ;
    rdfs:comment "(optional) Only this portion of the excluded box is excluded from the hash.  Each entry in the array must have a monotonically increasing relative byte offset.  No subset within the array may overlap.  The last entry may have a length of zero; this indicates that the remainder of the box from that relative byte offset onward is excluded.  A relative byte offset or relative byte offset plus length that exceeds the length of the box is allowed; bytes beyond the end of the box are never hashed."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range c2pa:SubsetMap ;
    c2pa:relationshipType "has_many" .

c2pa:FontInfoMap.copyrightYears a owl:ObjectProperty ;
    rdfs:label "copyrightYears"@en ;
    rdfs:comment "The years for which the holder asserts copyright."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:FontCopyrightYearRange .

c2pa:FontInfoMap.designers a owl:ObjectProperty ;
    rdfs:label "designers"@en ;
    rdfs:comment "The individuals that designed the font."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:FontDesignerMap ;
    c2pa:relationshipType "has_many" .

c2pa:GraphTypeChoice a owl:Class ;
    rdfs:label "GraphTypeChoice"@en ;
    owl:sameAs <https://c2pa.org/ontology/$graph-type-choice> ;
    c2pa:extensible true .

c2pa:HashedExtUriMap.data_types a owl:ObjectProperty ;
    rdfs:label "data_types"@en ;
    rdfs:comment "additional information about the data's type"@en ;
    rdfs:domain c2pa:HashedExtUriMap ;
    rdfs:range c2pa:AssetTypeMap ;
    c2pa:relationshipType "has_many" .

c2pa:IngredientMap.validationStatus a owl:ObjectProperty ;
    rdfs:label "validationStatus"@en ;
    rdfs:comment "validation status of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:StatusMap ;
    c2pa:relationshipType "has_many" .

c2pa:IngredientMapV2.data_types a owl:ObjectProperty ;
    rdfs:label "data_types"@en ;
    rdfs:comment "additional information about the data's type to the ingredient V2 structure."@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range c2pa:AssetTypeMap ;
    c2pa:relationshipType "has_many" .

c2pa:IngredientMapV2.validationStatus a owl:ObjectProperty ;
    rdfs:label "validationStatus"@en ;
    rdfs:comment "validation status of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range c2pa:StatusMap ;
    c2pa:relationshipType "has_many" .

c2pa:IngredientMapV3.dataTypes a owl:ObjectProperty ;
    rdfs:label "dataTypes"@en ;
    rdfs:comment "additional information about the data's type to the ingredient V3 structure"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range c2pa:AssetTypeMap ;
    c2pa:relationshipType "has_many" .

c2pa:IngredientMapV3.softBindingAlgorithmsMatched a owl:DatatypeProperty ;
    rdfs:label "softBindingAlgorithmsMatched"@en ;
    rdfs:comment "Array of algorithm names used for discovering the active manifest"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range xsd:string .

c2pa:MerkleMap.variableBlockSizes a owl:DatatypeProperty ;
    rdfs:label "variableBlockSizes"@en ;
    rdfs:comment "For non-fragmented MP4 assets where the mdat box is validated piecewise, this field can be present. Each entry in the array corresponds to the non-negative size in bytes of a given leaf node in the Merkle tree. The number of elements is equal to `count` and sum of the values is equal to size of payload of mdat. For fragmented MP4, this field is not present."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:string .

