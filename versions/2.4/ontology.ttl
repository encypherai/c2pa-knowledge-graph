    rdfs:domain c2pa:assertions ;
    rdfs:range c2pa:hashMultiAssetAssertion ;
    c2pa:relationshipType "has_one" .

c2pa:assertions.c2pa_ingredient a owl:ObjectProperty ;
    rdfs:label "c2pa.ingredient"@en ;
    rdfs:domain c2pa:assertions ;
    rdfs:range c2pa:ingredientAssertionV1 ;
    c2pa:relationshipType "belongs_to" .

c2pa:assertions.c2pa_ingredient_v2 a owl:ObjectProperty ;
