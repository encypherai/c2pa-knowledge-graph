c2pa:ClaimMap a owl:Class ;
    rdfs:label "ClaimMap"@en ;
    rdfs:comment "CDDL schema for a claim map in C2PA"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
