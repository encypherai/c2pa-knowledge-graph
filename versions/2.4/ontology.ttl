c2pa:hashedUriMap a owl:Class ;
    rdfs:label "hashedUriMap"@en ;
    rdfs:comment "Hashed URI reference (url and hash). CDDL: hashed-uri.cddl $hashed-uri-map."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:hashedUriMap.url ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:hashedUriMap.url ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:hashedUriMap.hash ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:hashedUriMap.alg ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:hashedUriMap.hash ] .

c2pa:HashedUriMap a owl:Class ;
    rdfs:label "HashedUriMap"@en ;
    rdfs:comment "Hashed URI reference (url and hash). CDDL: hashed-uri.cddl $hashed-uri-map."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedUriMap.hash ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedUriMap.alg ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedUriMap.url ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedUriMap.hash ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:HashedUriMap.url ] ;
    owl:sameAs <https://c2pa.org/ontology/$hashed-uri-map> ;
    c2pa:extensible true .

c2pa:AssetTypeChoice a owl:Class ;
    rdfs:label "AssetTypeChoice"@en ;
    c2pa:extensible true .

c2pa:ModelTypeChoice a owl:Class ;
    rdfs:label "ModelTypeChoice"@en ;
    c2pa:extensible true .

c2pa:FontWeightClass a owl:Class ;
    rdfs:label "FontWeightClass"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:FontWeightClass.Microline c2pa:FontWeightClass.Hairline c2pa:FontWeightClass.UltraThin c2pa:FontWeightClass.ExtraThin c2pa:FontWeightClass.Thin c2pa:FontWeightClass.UltraLight c2pa:FontWeightClass.ExtraLight c2pa:FontWeightClass.Light c2pa:FontWeightClass.SemiLight c2pa:FontWeightClass.Book c2pa:FontWeightClass.Normal c2pa:FontWeightClass.Regular c2pa:FontWeightClass.Medium c2pa:FontWeightClass.DemiBold c2pa:FontWeightClass.SemiBold c2pa:FontWeightClass.Bold c2pa:FontWeightClass.Heavy c2pa:FontWeightClass.ExtraBold c2pa:FontWeightClass.UltraBold c2pa:FontWeightClass.SemiBlack c2pa:FontWeightClass.Black c2pa:FontWeightClass.ExtraBlack c2pa:FontWeightClass.UltraBlack c2pa:FontWeightClass.MegaBlack ) ] .

c2pa:AssertionMetadataMap a owl:Class ;
    rdfs:label "AssertionMetadataMap"@en ;
    rdfs:comment "Additional information about an assertion. CDDL: assertion-metadata-common.cddl $assertion-metadata-map."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssertionMetadataMap.dateTime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssertionMetadataMap.processEnd ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssertionMetadataMap.processStart ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssertionMetadataMap.regionOfInterest ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssertionMetadataMap.dataSource ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssertionMetadataMap.reference ] ;
    owl:sameAs <https://c2pa.org/ontology/$assertion-metadata-map> ;
    c2pa:extensible true .

c2pa:ActionChoice a owl:Class ;
    rdfs:label "ActionChoice"@en ;
    c2pa:extensible true .

c2pa:StatusCode a owl:Class ;
    rdfs:label "StatusCode"@en ;
    c2pa:extensible true .

