c2pa:IngredientMap a owl:Class ;
    rdfs:label "IngredientMap"@en ;
    rdfs:comment "Assertion that describes an ingredient used in the asset"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:IngredientMap.dc_title ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:IngredientMap.dc_format ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:IngredientMap.documentID ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:IngredientMap.relationship ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:IngredientMap.relationship ],
        [ a owl:Restriction ;
