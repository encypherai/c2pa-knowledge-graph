    rdfs:label "ClaimMapV2"@en ;
    rdfs:comment "CDDL schema for a claim map in C2PA"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ClaimMapV2.metadata ],
        [ a owl:Restriction ;
