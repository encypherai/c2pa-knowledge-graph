            owl:onProperty c2pa:ExternalReferenceMap.location ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ExternalReferenceMap.location ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ExternalReferenceMap.label ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ExternalReferenceMap.metadata ] ;
    owl:sameAs c2pa:external-reference-map .

c2pa:HashedExternalReferenceMap a owl:Class ;
    rdfs:label "HashedExternalReferenceMap"@en ;
    rdfs:comment "Assertion that references externally-stored data by hashed URI"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
