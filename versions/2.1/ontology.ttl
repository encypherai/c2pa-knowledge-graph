c2pa:LanguageTypeChoice a owl:Class ;
    rdfs:label "LanguageTypeChoice"@en ;
    c2pa:extensible true .

c2pa:LocalizationDataEntry a owl:Class ;
    rdfs:label "LocalizationDataEntry"@en ;
    owl:sameAs <https://c2pa.org/ontology/$localization-data-entry> ;
    c2pa:extensible true .

c2pa:MerkleMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hashes in this Merkle tree, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken the `alg` value of the enclosing structure as defined by that structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:string .

c2pa:MerkleMap.fixedBlockSize a owl:DatatypeProperty ;
    rdfs:label "fixedBlockSize"@en ;
    rdfs:comment "For non-fragmented MP4 assets where the mdat box is validated piecewise, this field can be present. This field is the non-negative size in bytes of a given leaf node in the Merkle tree. For fragmented MP4, this field is not present."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:integer .

c2pa:MerkleMap.hashes a owl:DatatypeProperty ;
    rdfs:label "hashes"@en ;
    rdfs:comment "An ordered array representing a single row of the Merkle tree which may be the leaf-most row, root row, or any intermediate row.  The depth of the row is implied by (is computed from) the number of items in this array."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:string .

c2pa:MerkleMap.initHash a owl:DatatypeProperty ;
    rdfs:label "initHash"@en ;
    rdfs:comment "For fragmented MP4 assets which are split across multiple files, this field is required to be present and is the hash of the entire initialization segment file for chunks hashed by this Merkle tree excluding boxes listed in the exclusions array.  For fragmented MP4 assets which are stored as a single flat MP4 file, this field is required to be present and is the hash of all bytes preceding the first 'moof' box excluding boxes listed in the exclusions array.  For non-fragmented MP4, this field is required to be absent."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:base64Binary .

c2pa:MimeChoice.image_jpeg a owl:NamedIndividual,
        c2pa:MimeChoice ;
    rdfs:label "image/jpeg"@en .

c2pa:MimeChoice.image_png a owl:NamedIndividual,
        c2pa:MimeChoice ;
    rdfs:label "image/png"@en .

c2pa:NptTimeMap.end a owl:DatatypeProperty ;
    rdfs:label "end"@en ;
    rdfs:comment "end time (or end of asset if not present)."@en ;
    rdfs:domain c2pa:NptTimeMap ;
    rdfs:range xsd:string ;
    c2pa:pattern "^(?:(?:([01]?\\d|2[0-3]):)?([0-5]?\\d):)?([0-5]?\\d)(\\.(\\d{1,9}))?$" .

c2pa:NptTimeMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "start time (or beginning of asset if not present)."@en ;
    rdfs:domain c2pa:NptTimeMap ;
    rdfs:range xsd:string ;
    c2pa:pattern "^(?:(?:([01]?\\d|2[0-3]):)?([0-5]?\\d):)?([0-5]?\\d)(\\.(\\d{1,9}))?$" .

c2pa:NptTimeMap.type a owl:DatatypeProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "from a controlled list"@en ;
    rdfs:domain c2pa:NptTimeMap ;
    rdfs:range xsd:string .

c2pa:ParametersMap.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Additional description of the action"@en ;
    rdfs:domain c2pa:ParametersMap ;
    rdfs:range xsd:string .

c2pa:ParametersMap.ingredient a owl:ObjectProperty ;
    rdfs:label "ingredient"@en ;
    rdfs:comment "A hashed-uri to the ingredient assertion that this action acts on"@en ;
    rdfs:domain c2pa:ParametersMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "belongs_to" .

c2pa:ParametersMapV2.redacted a owl:DatatypeProperty ;
    rdfs:label "redacted"@en ;
    rdfs:comment "A JUMBF URI to the redacted assertion, required when the action is `c2pa.redacted`"@en ;
    rdfs:domain c2pa:ParametersMapV2 ;
    rdfs:range xsd:string .

c2pa:ParametersMapV2.sourceLanguage a owl:DatatypeProperty ;
    rdfs:label "sourceLanguage"@en ;
    rdfs:comment "BCP-47 code of the source language of a `c2pa.translated` action"@en ;
    rdfs:domain c2pa:ParametersMapV2 ;
    rdfs:range xsd:string .

c2pa:ParametersMapV2.targetLanguage a owl:DatatypeProperty ;
    rdfs:label "targetLanguage"@en ;
    rdfs:comment "BCP-47 code of the target language of a `c2pa.translated` action"@en ;
    rdfs:domain c2pa:ParametersMapV2 ;
    rdfs:range xsd:string .

