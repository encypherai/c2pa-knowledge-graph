        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:signature.timeStampInfo ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:signature.algorithm ] .

c2pa:softBindingMetadataMap a owl:Class ;
    rdfs:label "softBindingMetadataMap"@en ;
    rdfs:comment "Additional metadata for soft binding. CDDL: soft-binding.cddl soft-binding-metadata-map."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
