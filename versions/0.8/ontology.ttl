@prefix c2pa: <https://c2pa.org/ontology/> .
@prefix dc1: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

c2pa: a owl:Ontology ;
    rdfs:label "C2PA Ontology"@en ;
    dc1:date "2021-11-11"^^xsd:date ;
    rdfs:comment "OWL ontology generated from the C2PA specification source files. Entities, properties, and relationships are derived primarily from CDDL schemas, supplemented by JSON Schema and AsciiDoc documentation."@en ;
    owl:versionIRI <https://c2pa.org/ontology/v0.8/> ;
    owl:versionInfo "0.8" .

