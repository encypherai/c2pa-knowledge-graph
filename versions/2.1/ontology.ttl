c2pa:Rvals a owl:Class ;
    rdfs:label "Rvals"@en ;
    rdfs:comment "CBOR version of rVals and related structures based on JSON schema in https://www.etsi.org/deliver/etsi_ts/119100_119199/11918201/01.01.01_60/ts_11918201v010101p.pdf section 5.3.5.2"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:Rvals.ocspVals ] ;
    owl:sameAs c2pa:rVals .

c2pa:Rvals.ocspVals a owl:DatatypeProperty ;
    rdfs:label "ocspVals"@en ;
    rdfs:domain c2pa:Rvals ;
    rdfs:range xsd:string .

