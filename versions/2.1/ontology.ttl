        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssertionMetadataMap.dataSource ] ;
    owl:sameAs <https://c2pa.org/ontology/$assertion-metadata-map> ;
    c2pa:extensible true .

