    rdfs:range xsd:string .

c2pa:hashDataAssertion.pad2 a owl:DatatypeProperty ;
    rdfs:label "pad2"@en ;
    rdfs:comment "Secondary padding bytes"@en ;
    rdfs:domain c2pa:hashDataAssertion ;
    rdfs:range xsd:string .

c2pa:hashMultiAssetAssertion.parts a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "parts"@en ;
    rdfs:comment "Array of hashes for individual parts of the multi-part file"@en ;
    rdfs:domain c2pa:hashMultiAssetAssertion ;
    rdfs:range xsd:string,
        c2pa:partHashMap ;
