c2pa:RangeChoice a owl:Class ;
    rdfs:label "RangeChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:RangeChoice.spatial c2pa:RangeChoice.temporal c2pa:RangeChoice.frame c2pa:RangeChoice.textual c2pa:RangeChoice.identified ) ] .

