c2pa:RoleChoice a owl:Class ;
    rdfs:label "RoleChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:RoleChoice.c2pa_areaOfInterest c2pa:RoleChoice.c2pa_cropped c2pa:RoleChoice.c2pa_edited c2pa:RoleChoice.c2pa_placed c2pa:RoleChoice.c2pa_redacted c2pa:RoleChoice.c2pa_subjectArea c2pa:RoleChoice.c2pa_deleted c2pa:RoleChoice.c2pa_styled c2pa:RoleChoice.c2pa_watermarked ) ] .

