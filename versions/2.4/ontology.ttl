    owl:equivalentClass [ owl:oneOf ( c2pa:ShapeChoice.rectangle c2pa:ShapeChoice.circle c2pa:ShapeChoice.polygon ) ] .

c2pa:SoftBindingMetadataMap a owl:Class ;
