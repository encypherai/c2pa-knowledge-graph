@prefix c2pa: <https://c2pa.org/ontology/> .
@prefix dc1: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

c2pa: a owl:Ontology ;
    rdfs:label "C2PA Ontology"@en ;
    dc1:date "2021-12-24"^^xsd:date ;
    rdfs:comment "OWL ontology generated from the C2PA specification source files. Entities, properties, and relationships are derived primarily from CDDL schemas, supplemented by JSON Schema and AsciiDoc documentation."@en ;
    owl:versionIRI <https://c2pa.org/ontology/v1.0/> ;
    owl:versionInfo "1.0" .

c2pa:ActionItemsMap.actors a owl:ObjectProperty ;
    rdfs:label "actors"@en ;
    rdfs:comment "An array of the creators that undertook this action"@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range c2pa:ActorMap ;
    c2pa:relationshipType "has_many" .

c2pa:ActorMap.credentials a owl:DatatypeProperty ;
    rdfs:label "credentials"@en ;
    rdfs:domain c2pa:ActorMap ;
    rdfs:range xsd:string .

c2pa:AssertionMetadataMap.reviewRating a owl:ObjectProperty ;
    rdfs:label "reviewRating"@en ;
    rdfs:comment "Ratings given to the assertion (may be empty)"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range c2pa:RatingMap ;
    c2pa:relationshipType "has_many" .

c2pa:BmffHashMap.merkle a owl:ObjectProperty ;
    rdfs:label "merkle"@en ;
    rdfs:comment "A set of Merkle tree rows and the associated data required to enable verification of a single 'mdat' box, multiple 'mdat' boxes, and/or individual fragment files within the asset."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range c2pa:MerkleMap ;
    c2pa:relationshipType "has_many" .

c2pa:BmffMerkleMap.hashes a owl:DatatypeProperty ;
    rdfs:label "hashes"@en ;
    rdfs:comment "An ordered array representing the set of additional hashes required to reach a hash in the Merkle tree specified in the manifest from leaf-most (peer of this node) to root-most (child of node in manifest).  Note that this array may not be present, e.g. if the manifest itself contains the leaf-most row of the Merkle tree.  Null hashes are not included in this array.  The algorithm used shall be determined using the `alg` field from the corresponding entry in the `merkle` field array in the BMFF hash structure."@en ;
    rdfs:domain c2pa:BmffMerkleMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.redacted_assertions a owl:DatatypeProperty ;
    rdfs:label "redacted_assertions"@en ;
    rdfs:comment "List of hashed URI references to the assertions of ingredient manifests being redacted"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:DataHashMap.exclusions a owl:ObjectProperty ;
    rdfs:label "exclusions"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hash in this assertion, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken the `alg` value of the enclosing structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range c2pa:ExclusionRangeMap ;
    c2pa:relationshipType "has_many" .

c2pa:ExclusionsMap.data a owl:ObjectProperty ;
    rdfs:label "data"@en ;
    rdfs:comment "(optional) The data in the leafmost box at the specified offset must be identical to the specified data for the box to be excluded from the hash."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range c2pa:DataMap ;
    c2pa:relationshipType "has_many" .

c2pa:ExclusionsMap.subset a owl:ObjectProperty ;
    rdfs:label "subset"@en ;
    rdfs:comment "(optional) Only this portion of the excluded box shall be excluded from the hash.  Each entry in the array must have a monotonically increasing offset.  No subset within the array may overlap.  The last entry may have a length of zero; this indicates that the remainder of the box from that offset onward is excluded."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range c2pa:SubsetMap ;
    c2pa:relationshipType "has_many" .

c2pa:GeneratorHintsMap.Sec_CH_UA a owl:DatatypeProperty ;
    rdfs:label "Sec-CH-UA"@en ;
    rdfs:domain c2pa:GeneratorHintsMap ;
    rdfs:range xsd:string .

c2pa:GraphTypeChoice a owl:Class ;
    rdfs:label "GraphTypeChoice"@en ;
    owl:sameAs <https://c2pa.org/ontology/$graph-type-choice> ;
    c2pa:extensible true .

c2pa:NilOrStrTypeChoice a owl:Class ;
    rdfs:label "NilOrStrTypeChoice"@en ;
    c2pa:extensible true .

c2pa:ReverseSchema a owl:Class ;
    rdfs:label "ReverseSchema"@en ;
    owl:sameAs c2pa:reverse-schema .

c2pa:ReverseTypeChoice a owl:Class ;
    rdfs:label "ReverseTypeChoice"@en ;
    owl:sameAs <https://c2pa.org/ontology/$reverse-type-choice> ;
    c2pa:extensible true .

c2pa:SourceMap.actors a owl:ObjectProperty ;
    rdfs:label "actors"@en ;
    rdfs:comment "array of hashed_uri references to W3C Verifiable Credentials"@en ;
    rdfs:domain c2pa:SourceMap ;
    rdfs:range c2pa:ActorMap ;
    c2pa:relationshipType "has_many" .

c2pa:ActionChoice.c2pa_converted a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.converted"@en .

c2pa:ActionChoice.c2pa_copied a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.copied"@en .

c2pa:ActionChoice.c2pa_created a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.created"@en .

c2pa:ActionChoice.c2pa_cropped a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.cropped"@en .

c2pa:ActionChoice.c2pa_edited a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.edited"@en .

c2pa:ActionChoice.c2pa_filtered a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.filtered"@en .

c2pa:ActionChoice.c2pa_formatted a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.formatted"@en .

c2pa:ActionChoice.c2pa_managed a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.managed"@en .

c2pa:ActionChoice.c2pa_placed a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.placed"@en .

c2pa:ActionChoice.c2pa_printed a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.printed"@en .

c2pa:ActionChoice.c2pa_produced a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.produced"@en .

c2pa:ActionChoice.c2pa_published a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.published"@en .

c2pa:ActionChoice.c2pa_repackaged a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.repackaged"@en .

c2pa:ActionChoice.c2pa_resized a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.resized"@en .

c2pa:ActionChoice.c2pa_saved a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.saved"@en .

c2pa:ActionChoice.c2pa_transcoded a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.transcoded"@en .

c2pa:ActionChoice.c2pa_version_updated a owl:NamedIndividual,
        c2pa:ActionChoice ;
    rdfs:label "c2pa.version_updated"@en .

c2pa:ActionItemsMap.changed a owl:DatatypeProperty ;
    rdfs:label "changed"@en ;
    rdfs:comment "A semicolon-delimited list of the parts of the resource that were changed since the previous event history. If not present, presumed to be undefined. When tracking changes and the scope of the changed components is unknown, it should be assumed that anything might have changed."@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range xsd:string .

c2pa:ActionItemsMap.instanceID a owl:ObjectProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "The value of the xmpMM:InstanceID property for the modified (output) resource"@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range c2pa:Buuid .

c2pa:ActionItemsMap.parameters a owl:ObjectProperty ;
    rdfs:label "parameters"@en ;
    rdfs:comment "Additional parameters of the action. These will often vary by the type of action"@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range c2pa:ParametersMap ;
    c2pa:relationshipType "has_one" .

c2pa:ActionItemsMap.softwareAgent a owl:DatatypeProperty ;
    rdfs:label "softwareAgent"@en ;
    rdfs:comment "The software agent that performed the action."@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range xsd:string .

c2pa:ActionItemsMap.when a owl:DatatypeProperty ;
    rdfs:label "when"@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range xsd:dateTime .

c2pa:ActionsMap.actions a owl:ObjectProperty ;
    rdfs:label "actions"@en ;
    rdfs:comment "list of actions"@en ;
    rdfs:domain c2pa:ActionsMap ;
    rdfs:range c2pa:ActionItemsMap ;
    c2pa:relationshipType "has_many" .

c2pa:ActionsMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:ActionsMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:ActorMap.identifier a owl:DatatypeProperty ;
    rdfs:label "identifier"@en ;
    rdfs:domain c2pa:ActorMap ;
    rdfs:range xsd:string .

c2pa:AssertionMetadataMap.dataSource a owl:ObjectProperty ;
    rdfs:label "dataSource"@en ;
    rdfs:comment "A description of the source of the assertion data, selected from a predefined list"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range c2pa:SourceMap ;
    c2pa:relationshipType "has_one" .

c2pa:AssertionMetadataMap.dateTime a owl:DatatypeProperty ;
    rdfs:label "dateTime"@en ;
    rdfs:comment "The ISO 8601 date-time string when the assertion was created/generated"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range xsd:dateTime .

c2pa:AssertionMetadataMap.reference a owl:ObjectProperty ;
    rdfs:label "reference"@en ;
    rdfs:comment "hashed_uri reference to another assertion that this review is about"@en ;
    rdfs:domain c2pa:AssertionMetadataMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:BmffHashMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hashes in this Merkle tree, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken the `alg` value of the enclosing structure as defined by that structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range xsd:string .

c2pa:BmffHashMap.exclusions a owl:ObjectProperty ;
    rdfs:label "exclusions"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute this hash, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken from an enclosing structure as defined by that structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range c2pa:ExclusionsMap ;
    c2pa:relationshipType "has_many" .

c2pa:BmffHashMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "For non-fragmented MP4, this shall be the hash of the entire BMFF file excluding boxes listed in the exclusions array; if the Merkle field is present, this hash also excludes all 'mdat' boxes.  For fragmented MP4, this field is required to be absent."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:BmffHashMap.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "optional) a human-readable description of what this hash covers."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range xsd:string .

c2pa:BmffHashMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "(optional) a file or http(s) URL to where the bytes that are being hashed lived.  This is useful for cases where the data lives in a different file chunk or side-car than the claim."@en ;
    rdfs:domain c2pa:BmffHashMap ;
    rdfs:range xsd:anyURI .

c2pa:CameraInfoMap.crs_ColorNoiseReduction a owl:ObjectProperty ;
    rdfs:label "crs:ColorNoiseReduction"@en ;
    rdfs:comment "Color Noise Reduction setting. Range 0 to 100"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:ColourNoiseReductionRange .

c2pa:CameraInfoMap.crs_HasCrop a owl:DatatypeProperty ;
    rdfs:label "crs:HasCrop"@en ;
    rdfs:comment "When true, image has a cropping rectangle"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range xsd:boolean .

c2pa:CameraInfoMap.crs_LuminanceSmoothing a owl:ObjectProperty ;
    rdfs:label "crs:LuminanceSmoothing"@en ;
    rdfs:comment "Luminance Smoothing setting. Range 0 to 100"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:LuminanceRange .

c2pa:CameraInfoMap.crs_Saturation a owl:ObjectProperty ;
    rdfs:label "crs:Saturation"@en ;
    rdfs:comment "Saturation setting. Range -100 to 100"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:SaturationRange .

c2pa:CameraInfoMap.crs_Sharpness a owl:ObjectProperty ;
    rdfs:label "crs:Sharpness"@en ;
    rdfs:comment "Sharpness setting. Range 0 to 100"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:SharpnessRange .

c2pa:CameraInfoMap.crs_WhiteBalance a owl:ObjectProperty ;
    rdfs:label "crs:WhiteBalance"@en ;
    rdfs:comment "White Balance setting"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:WhiteBalanceSettingChoice .

c2pa:CameraInfoMap.exif_ColorSpace a owl:ObjectProperty ;
    rdfs:label "exif:ColorSpace"@en ;
    rdfs:comment "EXIF tag 40961, 0xA001. Color space information:1 = sRGB, 65535 = uncalibrated"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:ColorSpaceChoice .

c2pa:CameraInfoMap.exif_DigitalZoomRatio a owl:ObjectProperty ;
    rdfs:label "exif:DigitalZoomRatio"@en ;
    rdfs:comment "EXIF tag 41988, 0xA404. Indicates the digital zoom ratio when the image was shot. 0 = digital zoom not used"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:TaggedDigitalZoomType .

c2pa:CameraInfoMap.exif_LensMake a owl:ObjectProperty ;
    rdfs:label "exif:LensMake"@en ;
    rdfs:comment "EXIF tag 42035, 0xA433. The lens manufacturer"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:TaggedLensMakeType .

c2pa:CameraInfoMap.exif_LensModel a owl:ObjectProperty ;
    rdfs:label "exif:LensModel"@en ;
    rdfs:comment "EXIF tag 42036, 0xA434. The lens's model name and model number as an ASCII string"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:TaggedLensModelType .

c2pa:CameraInfoMap.exif_LensSpecification a owl:ObjectProperty ;
    rdfs:label "exif:LensSpecification"@en ;
    rdfs:comment "EXIF tag 42034, 0xA432. This tag notes minimum focal length, maximum focal length, minimum F number in the minimum focal length, and minimum F number in the maximum focal length, which are specification information for the lens that was used in photography. When the minimum F number is unknown, the notation is 0/0"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:TaggedLensSpecType .

c2pa:CameraInfoMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:CameraInfoMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:ClaimMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute all data hash assertions listed in this claim unless otherwise overridden, taken from the C2PA data hash algorithm identifier registry. This provides the value for the 'alg' field in data-hash and hashed-uri structures contained in this claim"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.alg_soft a owl:DatatypeProperty ;
    rdfs:label "alg_soft"@en ;
    rdfs:comment "A string identifying the algorithm used to compute all soft binding assertions listed in this claim unless otherwise overridden, taken from the C2PA soft binding algorithm identifier registry.\""@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.assertions a owl:ObjectProperty ;
    rdfs:label "assertions"@en ;
    rdfs:comment "media type of the asset"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_many" .

c2pa:ClaimMap.claim_generator_hints a owl:ObjectProperty ;
    rdfs:label "claim_generator_hints"@en ;
    rdfs:comment "A human readable string naming the claim_generator"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range c2pa:GeneratorHintsMap ;
    c2pa:relationshipType "has_one" .

c2pa:ClaimMap.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "name of the asset,"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:CloudDataMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:ColorSpaceChoice a owl:Class ;
    rdfs:label "ColorSpaceChoice"@en ;
    c2pa:extensible true .

c2pa:ContextTypeChoice a owl:Class ;
    rdfs:label "ContextTypeChoice"@en ;
    owl:sameAs <https://c2pa.org/ontology/$context-type-choice> ;
    c2pa:extensible true .

c2pa:DataHashMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:string .

c2pa:DataHashMap.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "(optional) a human-readable description of what this hash cover"@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:string .

c2pa:DataHashMap.pad2 a owl:DatatypeProperty ;
    rdfs:label "pad2"@en ;
    rdfs:comment "optional zero-filled byte string used for filling up space"@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:DataHashMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "(optional) a file or http(s) URL to where the bytes that are being hashed can be found."@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:anyURI .

c2pa:DepthMeasChoice.OpticRay a owl:NamedIndividual,
        c2pa:DepthMeasChoice ;
    rdfs:label "OpticRay"@en .

c2pa:DepthMeasChoice.OpticalAxis a owl:NamedIndividual,
        c2pa:DepthMeasChoice ;
    rdfs:label "OpticalAxis"@en .

c2pa:DepthmapGdepthMap.GDepth_Confidence a owl:ObjectProperty ;
    rdfs:label "GDepth:Confidence"@en ;
    rdfs:comment "The base64 encoded confidence image. Please see GDepth encoding page at developers.google.com. The confidence map should have the same size as the depthmap"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:Base64StringType .

c2pa:DepthmapGdepthMap.GDepth_ConfidenceMime a owl:ObjectProperty ;
    rdfs:label "GDepth:ConfidenceMime"@en ;
    rdfs:comment "The mime type for the base64 string describing the confidence image content, e.g. 'image/png'.\","@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:ConfidenceMimeType .

c2pa:DepthmapGdepthMap.GDepth_ImageHeight a owl:DatatypeProperty ;
    rdfs:label "GDepth:ImageHeight"@en ;
    rdfs:comment "The height in pixels of the original color image associated to this depthmap. This is NOT the depthmap height. If present, apps must update this property when scaling, cropping or rotating the color image. Clients use this property to verify the integrity of the depthmap w.r.t. the color image"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:decimal .

c2pa:DepthmapGdepthMap.GDepth_ImageWidth a owl:DatatypeProperty ;
    rdfs:label "GDepth:ImageWidth"@en ;
    rdfs:comment "The width in pixels of the original color image associated to this depthmap. This is NOT the depthmap width. If present, apps must update this property when scaling, cropping or rotating the color image. Clients use this property to verify the integrity of the depthmap w.r.t. the color image"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:decimal .

c2pa:DepthmapGdepthMap.GDepth_Manufacturer a owl:DatatypeProperty ;
    rdfs:label "GDepth:Manufacturer"@en ;
    rdfs:comment "The manufacturer of the device that created this depthmap"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:string .

c2pa:DepthmapGdepthMap.GDepth_MeasureType a owl:ObjectProperty ;
    rdfs:label "GDepth:MeasureType"@en ;
    rdfs:comment "The type of depth measurement. Current valid values are 'OpticalAxis' and 'OpticRay"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:DepthMeasType .

c2pa:DepthmapGdepthMap.GDepth_Model a owl:DatatypeProperty ;
    rdfs:label "GDepth:Model"@en ;
    rdfs:comment "The model of the device that created this depthmap"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:string .

c2pa:DepthmapGdepthMap.GDepth_Software a owl:DatatypeProperty ;
    rdfs:label "GDepth:Software"@en ;
    rdfs:comment "The software that created this depthmap"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:string .

c2pa:DepthmapGdepthMap.GDepth_Units a owl:ObjectProperty ;
    rdfs:label "GDepth:Units"@en ;
    rdfs:comment "The units of the depthmap, e.g. 'm' for meters or 'mm' for millimeters"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:UnitType .

c2pa:DepthmapGdepthMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:EntityTypeChoice a owl:Class ;
    rdfs:label "EntityTypeChoice"@en ;
    owl:sameAs <https://c2pa.org/ontology/$entity-type-choice> ;
    c2pa:extensible true .

c2pa:ExclusionsMap.exact a owl:DatatypeProperty ;
    rdfs:label "exact"@en ;
    rdfs:comment "(optional) indicates that flags must be an exact match.  If not specified, defaults to true.  Shall only be specified for a box that inherits from FullBox and when flags is also specified."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range xsd:boolean .

c2pa:ExclusionsMap.flags a owl:ObjectProperty ;
    rdfs:label "flags"@en ;
    rdfs:comment "(optional) byte string of exactly 3 bytes.  The 24-bit flags that must be set in a leafmost box for the box to be excluded from the hash.  Shall only be specified for a box that inherits from FullBox."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range c2pa:FlagT .

c2pa:ExclusionsMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "(optional) Length that a leafmost box must have to exclude from the hash."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:ExclusionsMap.version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "(optional) Version that must be set in a leafmost box for the box to be excluded from the hash.  Shall only be specified for a box that inherits from FullBox."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:FormatChoice.RangeInverse a owl:NamedIndividual,
        c2pa:FormatChoice ;
    rdfs:label "RangeInverse"@en .

c2pa:FormatChoice.RangeLinear a owl:NamedIndividual,
        c2pa:FormatChoice ;
    rdfs:label "RangeLinear"@en .

c2pa:GraphType a owl:Class ;
    rdfs:label "GraphType"@en ;
    owl:sameAs c2pa:graph-type .

c2pa:HashedUriMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute all hashes in this claim, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken from an enclosing structure as defined by that structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:HashedUriMap ;
    rdfs:range xsd:string .

c2pa:ImageTypeChoice a owl:Class ;
    rdfs:label "ImageTypeChoice"@en ;
    owl:sameAs <https://c2pa.org/ontology/$image-type-choice> ;
    c2pa:extensible true .

c2pa:IngredientMap.c2pa_manifest a owl:ObjectProperty ;
    rdfs:label "c2pa_manifest"@en ;
    rdfs:comment "hashed_uri reference to the C2PA Manifest of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMap.documentID a owl:DatatypeProperty ;
    rdfs:label "documentID"@en ;
    rdfs:comment "value of the ingredient's `xmpMM:DocumentID`"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range xsd:string .

c2pa:IngredientMap.thumbnail a owl:ObjectProperty ;
    rdfs:label "thumbnail"@en ;
    rdfs:comment "hashed_uri reference to an ingredient thumbnail"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMap.validationStatus a owl:ObjectProperty ;
    rdfs:label "validationStatus"@en ;
    rdfs:comment "validation status of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:StatusMap ;
    c2pa:relationshipType "has_one" .

c2pa:LanguageTypeChoice a owl:Class ;
    rdfs:label "LanguageTypeChoice"@en ;
    c2pa:extensible true .

c2pa:MerkleMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hashes in this Merkle tree, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken the `alg` value of the enclosing structure as defined by that structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:string .

c2pa:MerkleMap.hashes a owl:DatatypeProperty ;
    rdfs:label "hashes"@en ;
    rdfs:comment "An ordered array representing a single row of the Merkle tree which may be the leaf-most row, root row, or any intermediate row.  The depth of the row is implied by (shall be computed from) the number of items in this array."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:string .

c2pa:MerkleMap.initHash a owl:DatatypeProperty ;
    rdfs:label "initHash"@en ;
    rdfs:comment "For fragmented MP4, this field is required to be present and shall be the hash of the initialization segment for chunks hashed by this Merkle tree.  For non-fragmented MP4, this field is required to be absent."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:base64Binary .

c2pa:MimeChoice.image_jpeg a owl:NamedIndividual,
        c2pa:MimeChoice ;
    rdfs:label "image/jpeg"@en .

c2pa:MimeChoice.image_png a owl:NamedIndividual,
        c2pa:MimeChoice ;
    rdfs:label "image/png"@en .

c2pa:ParametersMap.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
