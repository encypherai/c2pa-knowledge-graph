c2pa:hashedExtUriMap.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "IANA media type of the data (optional)"@en ;
    rdfs:domain c2pa:hashedExtUriMap ;
