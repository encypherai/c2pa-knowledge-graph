            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ClaimMapV2.instanceID ] ;
    owl:sameAs c2pa:claim-map-v2 .

c2pa:RegionMap a owl:Class ;
    rdfs:label "RegionMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
