c2pa:Rvals a owl:Class ;
    rdfs:label "Rvals"@en ;
    rdfs:comment "CBOR version of rVals and related structures based on JSON schema in https://www.etsi.org/deliver/etsi_ts/119100_119199/11918201/01.01.01_60/ts_11918201v010101p.pdf section 5.3.5.2"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:Rvals.ocspVals ] ;
    owl:sameAs c2pa:rVals .

c2pa:Rvals.ocspVals a owl:DatatypeProperty ;
    rdfs:label "ocspVals"@en ;
    rdfs:domain c2pa:Rvals ;
    rdfs:range xsd:string .

c2pa:SegmentInfoMap.manifestUri a owl:ObjectProperty ;
    rdfs:label "manifestUri"@en ;
    rdfs:comment "optional hashed-ext-uri-map to where manifest can be retrieved"@en ;
    rdfs:domain c2pa:SegmentInfoMap ;
    rdfs:range c2pa:HashedExtUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:SessionKeysData a owl:Class ;
    rdfs:label "SessionKeysData"@en ;
    rdfs:comment "Data structure to supply session keys used for live-video validation"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:SessionKeysData.keys ] ;
    owl:sameAs c2pa:session-keys-data .

c2pa:SessionKeysData.keys a owl:ObjectProperty ;
    rdfs:label "keys"@en ;
    rdfs:comment "one or more session keys"@en ;
    rdfs:domain c2pa:SessionKeysData ;
    rdfs:range c2pa:SessionKey ;
    c2pa:relationshipType "has_many" .

c2pa:ShapeChoice.circle a owl:NamedIndividual,
        c2pa:ShapeChoice ;
    rdfs:label "circle"@en .

c2pa:ShapeChoice.polygon a owl:NamedIndividual,
        c2pa:ShapeChoice ;
    rdfs:label "polygon"@en .

c2pa:ShapeChoice.rectangle a owl:NamedIndividual,
        c2pa:ShapeChoice ;
    rdfs:label "rectangle"@en .

c2pa:ShapeMap.height a owl:DatatypeProperty ;
    rdfs:label "height"@en ;
    rdfs:comment "height for rectangles"@en ;
