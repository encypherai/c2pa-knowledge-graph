    rdfs:domain c2pa:assertions ;
    rdfs:range c2pa:hashBmffAssertion ;
    c2pa:relationshipType "has_one" .

c2pa:assertions.c2pa_hash_boxes a owl:ObjectProperty ;
    rdfs:label "c2pa.hash.boxes"@en ;
    rdfs:domain c2pa:assertions ;
    rdfs:range c2pa:hashBoxesAssertion ;
