c2pa:ingredientAssertionV3.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "Unique identifier, e.g. value of the ingredient's xmpMM:InstanceID"@en ;
    rdfs:domain c2pa:ingredientAssertionV3 ;
