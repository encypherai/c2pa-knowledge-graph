c2pa:signature a owl:Class ;
    rdfs:label "signature"@en ;
    rdfs:comment "Decoded claim signature (algorithm, certificate, optional timestamp). CrJSON decoding of Claim Signature box; no CDDL rule in INTERNAL/cddl."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
