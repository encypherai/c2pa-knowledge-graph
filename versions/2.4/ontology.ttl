        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ingredientAssertionV2.description ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ingredientAssertionV2.data ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ingredientAssertionV2.dc_title ],
        [ a owl:Restriction ;
