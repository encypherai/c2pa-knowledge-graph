c2pa:hashedExtUriMap.size a owl:DatatypeProperty ;
    rdfs:label "size"@en ;
    rdfs:comment "Number of bytes of data (optional)"@en ;
    rdfs:domain c2pa:hashedExtUriMap ;
    rdfs:range xsd:integer .

c2pa:hashedUriMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "Hash algorithm identifier; if absent, taken from enclosing structure"@en ;
    rdfs:domain c2pa:hashedUriMap ;
    rdfs:range xsd:string .

