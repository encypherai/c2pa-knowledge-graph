c2pa:assertions.c2pa_hash_data a owl:ObjectProperty ;
    rdfs:label "c2pa.hash.data"@en ;
    rdfs:domain c2pa:assertions ;
    rdfs:range c2pa:hashDataAssertion ;
    c2pa:relationshipType "has_one" .

c2pa:assertions.c2pa_hash_multi_asset a owl:ObjectProperty ;
