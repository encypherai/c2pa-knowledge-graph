c2pa:CameraInfoMap a owl:Class ;
    rdfs:label "CameraInfoMap"@en ;
    rdfs:comment "Assertion that describes information from the capture device at the point of capture"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.crs_LuminanceSmoothing ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.exif_LensSpecification ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.crs_WhiteBalance ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.exif_ColorSpace ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.crs_Sharpness ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.crs_HasCrop ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.exif_LensMake ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.crs_Saturation ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.metadata ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.crs_ColorNoiseReduction ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.exif_DigitalZoomRatio ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CameraInfoMap.exif_LensModel ] ;
    owl:sameAs c2pa:camera-info-map .

c2pa:DepthmapGdepthMap a owl:Class ;
    rdfs:label "DepthmapGdepthMap"@en ;
    rdfs:comment "Assertion that encodes a GDepth-formatted 3D depth map of the captured scene"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Far ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Far ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_ConfidenceMime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Units ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Format ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Model ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Confidence ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Near ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Format ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Mime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Near ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Software ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Data ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_MeasureType ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Data ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.metadata ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_ImageWidth ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Mime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Manufacturer ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_ImageHeight ] ;
    owl:sameAs c2pa:depthmap-gdepth-map .

c2pa:ActionChoice a owl:Class ;
    rdfs:label "ActionChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:ActionChoice.c2pa_converted c2pa:ActionChoice.c2pa_copied c2pa:ActionChoice.c2pa_created c2pa:ActionChoice.c2pa_cropped c2pa:ActionChoice.c2pa_edited c2pa:ActionChoice.c2pa_filtered c2pa:ActionChoice.c2pa_formatted c2pa:ActionChoice.c2pa_version_updated c2pa:ActionChoice.c2pa_printed c2pa:ActionChoice.c2pa_published c2pa:ActionChoice.c2pa_managed c2pa:ActionChoice.c2pa_produced c2pa:ActionChoice.c2pa_resized c2pa:ActionChoice.c2pa_saved c2pa:ActionChoice.c2pa_transcoded c2pa:ActionChoice.c2pa_repackaged c2pa:ActionChoice.c2pa_placed ) ] .

c2pa:StatusCode a owl:Class ;
    rdfs:label "StatusCode"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:StatusCode.claimSignature_validated c2pa:StatusCode.signingCredential_trusted c2pa:StatusCode.timeStamp_trusted c2pa:StatusCode.assertion_hashedURI_match c2pa:StatusCode.assertion_dataHash_match c2pa:StatusCode.assertion_bmffHash_match c2pa:StatusCode.assertion_accessible c2pa:StatusCode.claim_missing c2pa:StatusCode.claim_multiple c2pa:StatusCode.claim_hardBindings_missing c2pa:StatusCode.ingredient_hashedURI_mismatch c2pa:StatusCode.claimSignature_missing c2pa:StatusCode.claimSignature_mismatch c2pa:StatusCode.manifest_multipleParents c2pa:StatusCode.manifest_update_invalid c2pa:StatusCode.manifest_update_wrongParents c2pa:StatusCode.signingCredential_untrusted c2pa:StatusCode.signingCredential_invalid c2pa:StatusCode.signingCredential_revoked c2pa:StatusCode.signingCredential_expired c2pa:StatusCode.timeStamp_mismatch c2pa:StatusCode.timeStamp_untrusted c2pa:StatusCode.timeStamp_outsideValidity c2pa:StatusCode.assertion_hashedURI_mismatch c2pa:StatusCode.assertion_missing c2pa:StatusCode.assertion_undeclared c2pa:StatusCode.assertion_inaccessible c2pa:StatusCode.assertion_notRedacted c2pa:StatusCode.assertion_selfRedacted c2pa:StatusCode.assertion_action_redacted c2pa:StatusCode.assertion_dataHash_mismatch c2pa:StatusCode.assertion_bmffHash_mismatch c2pa:StatusCode.assertion_cloud-data_hardBinding c2pa:StatusCode.assertion_cloud-data_actions c2pa:StatusCode.algorithm_unsupported ) ] .

