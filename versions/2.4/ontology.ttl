c2pa:FrameMap.end a owl:DatatypeProperty ;
    rdfs:label "end"@en ;
    rdfs:comment "end time (or end of asset if not present). Exclusive by default, see endInclusivity for override behaviour."@en ;
    rdfs:domain c2pa:FrameMap ;
    rdfs:range xsd:integer .

c2pa:FrameMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "start time (or beginning of asset if not present). Inclusive."@en ;
    rdfs:domain c2pa:FrameMap ;
    rdfs:range xsd:integer .

c2pa:GeneratorInfoMap.icon a owl:DatatypeProperty ;
    rdfs:label "icon"@en ;
    rdfs:comment "hashed URI to the icon (either embedded or remote)"@en ;
    rdfs:domain c2pa:GeneratorInfoMap ;
    rdfs:range rdfs:Literal .

c2pa:GeneratorInfoMap.operating_system a owl:DatatypeProperty ;
    rdfs:label "operating_system"@en ;
    rdfs:comment "A human readable string of the operating system the claim generator is running on"@en ;
    rdfs:domain c2pa:GeneratorInfoMap ;
    rdfs:range xsd:string .

c2pa:GeneratorInfoMap.specVersion a owl:DatatypeProperty ;
    rdfs:label "specVersion"@en ;
    rdfs:comment "The version of the specification used to produce this claim (SemVer)"@en ;
    rdfs:domain c2pa:GeneratorInfoMap ;
    rdfs:range xsd:string ;
    owl:deprecated true .

c2pa:GeneratorInfoMap.version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "A human readable string of the product's version"@en ;
    rdfs:domain c2pa:GeneratorInfoMap ;
    rdfs:range xsd:string .

c2pa:GenericRepresentation.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:domain c2pa:GenericRepresentation ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:GraphType a owl:Class ;
    rdfs:label "GraphType"@en ;
    owl:sameAs c2pa:graph-type .

c2pa:HashedExtUriMap.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "IANA media type of the data"@en ;
    rdfs:domain c2pa:HashedExtUriMap ;
    rdfs:range xsd:string .

c2pa:HashedExtUriMap.size a owl:ObjectProperty ;
    rdfs:label "size"@en ;
    rdfs:comment "Number of bytes of data"@en ;
    rdfs:domain c2pa:HashedExtUriMap ;
    rdfs:range c2pa:SizeType .

c2pa:HashedExternalReferenceMap.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "human-readable description of the referenced data"@en ;
    rdfs:domain c2pa:HashedExternalReferenceMap ;
    rdfs:range xsd:string .

c2pa:HashedExternalReferenceMap.label a owl:DatatypeProperty ;
    rdfs:label "label"@en ;
    rdfs:comment "label for the referenced assertion, if relevant (e.g., c2pa.metadata)"@en ;
    rdfs:domain c2pa:HashedExternalReferenceMap ;
    rdfs:range xsd:string .

c2pa:HashedExternalReferenceMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:HashedExternalReferenceMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:HashedUriMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute all hashes in this claim, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken from an enclosing structure as defined by that structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:HashedUriMap ;
    rdfs:range xsd:string .

c2pa:IngredientMap.c2pa_manifest a owl:ObjectProperty ;
    rdfs:label "c2pa_manifest"@en ;
    rdfs:comment "hashed_uri reference to the C2PA Manifest of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMap.documentID a owl:DatatypeProperty ;
    rdfs:label "documentID"@en ;
    rdfs:comment "value of the ingredient's `xmpMM:DocumentID`"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range xsd:string .

c2pa:IngredientMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMap.thumbnail a owl:ObjectProperty ;
    rdfs:label "thumbnail"@en ;
    rdfs:comment "hashed_uri reference to an ingredient thumbnail"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMapV2.c2pa_manifest a owl:ObjectProperty ;
    rdfs:label "c2pa_manifest"@en ;
    rdfs:comment "hashed_uri reference to the C2PA Manifest of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMapV2.data a owl:DatatypeProperty ;
    rdfs:label "data"@en ;
    rdfs:comment "hashed_uri reference to an embedded data assertion or a hashed_ext_uri to external data"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range rdfs:Literal .

c2pa:IngredientMapV2.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Additional description of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV2.documentID a owl:DatatypeProperty ;
    rdfs:label "documentID"@en ;
    rdfs:comment "value of the ingredient's `xmpMM:DocumentID`"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV2.informational_URI a owl:DatatypeProperty ;
    rdfs:label "informational_URI"@en ;
    rdfs:comment "URI to an informational page about the ingredient or its data"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV2.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "unique identifier, such as the value of the ingredient's `xmpMM:InstanceID`"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV2.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMapV2.thumbnail a owl:ObjectProperty ;
    rdfs:label "thumbnail"@en ;
    rdfs:comment "hashed_uri reference to an ingredient thumbnail"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMapV3.activeManifest a owl:ObjectProperty ;
    rdfs:label "activeManifest"@en ;
    rdfs:comment "hashed_uri to the box corresponding to the active manifest of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMapV3.claimSignature a owl:ObjectProperty ;
    rdfs:label "claimSignature"@en ;
    rdfs:comment "hashed_uri to the Claim Signature box in the C2PA Manifest of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMapV3.data a owl:DatatypeProperty ;
    rdfs:label "data"@en ;
    rdfs:comment "hashed_uri reference to an embedded data assertion or a hashed_ext_uri to external data"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range rdfs:Literal .

c2pa:IngredientMapV3.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "Media Type of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV3.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "name of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV3.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Additional description of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV3.digitalSourceType a owl:DatatypeProperty ;
    rdfs:label "digitalSourceType"@en ;
    rdfs:comment "One of the source types defined at https://cv.iptc.org/newscodes/digitalsourcetype/ or in this specification. Cannot be combined with `activeManifest`."@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV3.informationalURI a owl:DatatypeProperty ;
    rdfs:label "informationalURI"@en ;
    rdfs:comment "URI to an informational page about the ingredient or its data"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV3.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "unique identifier, such as the value of the ingredient's `xmpMM:InstanceID`"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV3.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMapV3.softBindingsMatched a owl:DatatypeProperty ;
    rdfs:label "softBindingsMatched"@en ;
    rdfs:comment "Whether soft bindings were matched"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range xsd:boolean .

c2pa:IngredientMapV3.thumbnail a owl:ObjectProperty ;
    rdfs:label "thumbnail"@en ;
    rdfs:comment "hashed_uri reference to an ingredient thumbnail"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMapV3.validationResults a owl:ObjectProperty ;
    rdfs:label "validationResults"@en ;
    rdfs:comment "Results from the claim generator performing full validation on the ingredient asset"@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range c2pa:ValidationResultsMap ;
    c2pa:relationshipType "has_one" .

c2pa:LanguageTypeChoice a owl:Class ;
    rdfs:label "LanguageTypeChoice"@en ;
    c2pa:extensible true .

c2pa:LivevideoSegmentMapManifestid a owl:Class ;
    rdfs:label "LivevideoSegmentMapManifestid"@en ;
    rdfs:comment "when continuityMethod == c2pa.manifestId, additional fields include:"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:LivevideoSegmentMapManifestid.previousManifestId ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:LivevideoSegmentMapManifestid.previousManifestId ] ;
    owl:sameAs c2pa:livevideo-segment-map-manifestId .

c2pa:MerkleMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hashes in this Merkle tree, taken from the C2PA hash algorithm identifier list. If this field is absent, the hash algorithm is taken from the `alg` value of the enclosing structure as defined by that structure. If both are present, the field in this structure is used. If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:string .

c2pa:MerkleMap.fixedBlockSize a owl:DatatypeProperty ;
    rdfs:label "fixedBlockSize"@en ;
    rdfs:comment "For non-fragmented MP4 assets where the mdat box is validated piecewise, this field can be present. This field is the non-negative size in bytes of a given leaf node in the Merkle tree. For fragmented MP4, this field is not present."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:integer .

c2pa:MerkleMap.hashes a owl:DatatypeProperty ;
    rdfs:label "hashes"@en ;
    rdfs:comment "An ordered array representing a single row of the Merkle tree, which may be the leaf-most row, root row, or any intermediate row. Any null nodes are excluded. The depth of the row is implied by (is computed from) the number of items in this array."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:string .

c2pa:MerkleMap.initHash a owl:DatatypeProperty ;
    rdfs:label "initHash"@en ;
    rdfs:comment "For fragmented MP4 assets that are split across multiple files, this field is required to be present and is the hash of the entire initialization segment file for chunks hashed by this Merkle tree excluding boxes listed in the exclusions array.  For fragmented MP4 assets that are stored as a single flat MP4 file, this field is required to be present and is the hash of all bytes preceding the first 'moof' box excluding boxes listed in the exclusions array.  For non-fragmented MP4, this field is required to be absent."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:base64Binary .

c2pa:MimeChoice.image_jpeg a owl:NamedIndividual,
        c2pa:MimeChoice ;
    rdfs:label "image/jpeg"@en .

c2pa:MimeChoice.image_png a owl:NamedIndividual,
        c2pa:MimeChoice ;
    rdfs:label "image/png"@en .

c2pa:MultiAssetHashMap a owl:Class ;
    rdfs:label "MultiAssetHashMap"@en ;
    rdfs:comment "There exist a number of file formats that are composed of multiple parts, where each part is itself a valid file format, such as when multiple individual images are aggregated into a single file. Some examples include:"@en ;
    owl:sameAs c2pa:multi-asset-hash-map .

c2pa:NptTimeMap.end a owl:DatatypeProperty ;
    rdfs:label "end"@en ;
    rdfs:comment "end time (or end of asset if not present). Exclusive by default, see endInclusivity for override behaviour."@en ;
    rdfs:domain c2pa:NptTimeMap ;
    rdfs:range xsd:string ;
    c2pa:pattern "^(?:\\d+(?:\\.\\d*)?|[\\d]+\\:[0-5]?\\d\\:[0-5]?\\d(?:\\.\\d*)?)$" .

c2pa:NptTimeMap.endInclusivity a owl:DatatypeProperty ;
    rdfs:label "endInclusivity"@en ;
    rdfs:comment "if present and set to \"inclusive\", the end time is inclusive of that moment in time, otherwise it is exclusive (default)."@en ;
    rdfs:domain c2pa:NptTimeMap ;
    rdfs:range rdfs:Literal .

c2pa:NptTimeMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "start time (or beginning of asset if not present). Inclusive."@en ;
    rdfs:domain c2pa:NptTimeMap ;
    rdfs:range xsd:string ;
    c2pa:pattern "^(?:\\d+(?:\\.\\d*)?|[\\d]+\\:[0-5]?\\d\\:[0-5]?\\d(?:\\.\\d*)?)$" .

c2pa:NptTimeMap.type a owl:DatatypeProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "from a controlled list"@en ;
    rdfs:domain c2pa:NptTimeMap ;
    rdfs:range xsd:string .

c2pa:OriginalPreservationImageParams.embeddedOriginalPreservationImage a owl:ObjectProperty ;
    rdfs:label "embeddedOriginalPreservationImage"@en ;
    rdfs:comment "hashed URI reference to the embedded data assertion containing OPI, or to another assertion that is technically equivalent to an embedded data assertion (e.g., c2pa.thumbnail.claim)."@en ;
    rdfs:domain c2pa:OriginalPreservationImageParams ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:OriginalPreservationImageParams.multiAssetPartIndex a owl:DatatypeProperty ;
    rdfs:label "multiAssetPartIndex"@en ;
    rdfs:comment "The zero-based index of the element within the parts array of the corresponding c2pa.hash.multi-asset assertion that uniquely identifies the location of the OPI."@en ;
    rdfs:domain c2pa:OriginalPreservationImageParams ;
    rdfs:range xsd:integer .

c2pa:OriginalPreservationImageRepresentation.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:domain c2pa:OriginalPreservationImageRepresentation ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:ParametersMap.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Additional description of the action"@en ;
    rdfs:domain c2pa:ParametersMap ;
    rdfs:range xsd:string .

c2pa:ParametersMap.ingredient a owl:ObjectProperty ;
    rdfs:label "ingredient"@en ;
    rdfs:comment "A hashed-uri to the ingredient assertion that this action acts on"@en ;
    rdfs:domain c2pa:ParametersMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "belongs_to" .

c2pa:ParametersMapV2.multipleInstances a owl:DatatypeProperty ;
    rdfs:label "multipleInstances"@en ;
    rdfs:comment "was this action performed multiple times"@en ;
    rdfs:domain c2pa:ParametersMapV2 ;
    rdfs:range xsd:boolean .

c2pa:ParametersMapV2.redacted a owl:DatatypeProperty ;
    rdfs:label "redacted"@en ;
    rdfs:comment "A JUMBF URI to the redacted assertion, required when the action is `c2pa.redacted`"@en ;
    rdfs:domain c2pa:ParametersMapV2 ;
    rdfs:range xsd:string .

c2pa:ParametersMapV2.sourceLanguage a owl:DatatypeProperty ;
    rdfs:label "sourceLanguage"@en ;
    rdfs:comment "BCP-47 code of the source language of a `c2pa.translated` action"@en ;
    rdfs:domain c2pa:ParametersMapV2 ;
    rdfs:range xsd:string .

c2pa:ParametersMapV2.targetLanguage a owl:DatatypeProperty ;
    rdfs:label "targetLanguage"@en ;
    rdfs:comment "BCP-47 code of the target language of a `c2pa.translated` action"@en ;
    rdfs:domain c2pa:ParametersMapV2 ;
    rdfs:range xsd:string .

c2pa:PartHashMap.optional a owl:DatatypeProperty ;
    rdfs:label "optional"@en ;
    rdfs:comment "If the part is optional and can be discarded"@en ;
    rdfs:domain c2pa:PartHashMap ;
    rdfs:range xsd:boolean .

c2pa:RangeChoice.frame a owl:NamedIndividual,
        c2pa:RangeChoice ;
    rdfs:label "frame"@en .

c2pa:RangeChoice.identified a owl:NamedIndividual,
        c2pa:RangeChoice ;
    rdfs:label "identified"@en .

c2pa:RangeChoice.spatial a owl:NamedIndividual,
