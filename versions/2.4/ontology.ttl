c2pa:ActionItemMapV2.changes a owl:ObjectProperty ;
    rdfs:label "changes"@en ;
    rdfs:comment "A list of the regions of interest of the resource that were changed. If not present, presumed to be undefined."@en ;
    rdfs:domain c2pa:ActionItemMapV2 ;
    rdfs:range c2pa:RegionMap ;
    c2pa:relationshipType "has_many" .

c2pa:ActionItemMapV2.related a owl:ObjectProperty ;
    rdfs:label "related"@en ;
    rdfs:comment "List of related actions"@en ;
    rdfs:domain c2pa:ActionItemMapV2 ;
    rdfs:range c2pa:ActionItemMapV2 ;
    c2pa:relationshipType "has_many" .

