c2pa:ReviewCode a owl:Class ;
    rdfs:label "ReviewCode"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:ReviewCode.actions_unknownActionsPerformed c2pa:ReviewCode.actions_missing c2pa:ReviewCode.actions_possiblyMissing c2pa:ReviewCode.depthMap_sceneMismatch c2pa:ReviewCode.ingredient_modified c2pa:ReviewCode.ingredient_possiblyModified c2pa:ReviewCode.thumbnail_primaryMismatch c2pa:ReviewCode.stds_iptc_location_inaccurate c2pa:ReviewCode.stds_schema-org_CreativeWork_misattributed c2pa:ReviewCode.stds_schema-org_CreativeWork_missingAttribution ) ] .

c2pa:SourceType a owl:Class ;
    rdfs:label "SourceType"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:SourceType.signer c2pa:SourceType.claimGenerator_REE c2pa:SourceType.claimGenerator_TEE c2pa:SourceType.localProvider_REE c2pa:SourceType.localProvider_TEE c2pa:SourceType.remoteProvider_1stParty c2pa:SourceType.remoteProvider_3rdParty c2pa:SourceType.humanEntry c2pa:SourceType.humanEntry_anonymous c2pa:SourceType.humanEntry_identified ) ] .

c2pa:RoleChoice a owl:Class ;
