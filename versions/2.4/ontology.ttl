    rdfs:label "temporal"@en .

c2pa:RangeChoice.textual a owl:NamedIndividual,
        c2pa:RangeChoice ;
    rdfs:label "textual"@en .

c2pa:RangeMap.frame a owl:ObjectProperty ;
    rdfs:label "frame"@en ;
    rdfs:comment "a range identified by a series of frames or pages"@en ;
    rdfs:domain c2pa:RangeMap ;
    rdfs:range c2pa:FrameMap ;
    c2pa:relationshipType "has_one" .

c2pa:RangeMap.item a owl:ObjectProperty ;
    rdfs:label "item"@en ;
    rdfs:comment "description of the boundaries of an identified range"@en ;
    rdfs:domain c2pa:RangeMap ;
    rdfs:range c2pa:ItemMap ;
    c2pa:relationshipType "has_one" .

c2pa:RangeMap.shape a owl:ObjectProperty ;
    rdfs:label "shape"@en ;
    rdfs:comment "description of the shape of a spatial range"@en ;
    rdfs:domain c2pa:RangeMap ;
    rdfs:range c2pa:ShapeMap ;
    c2pa:relationshipType "has_one" .

c2pa:RangeMap.text a owl:ObjectProperty ;
    rdfs:label "text"@en ;
    rdfs:comment "description of the boundaries of a textual range"@en ;
    rdfs:domain c2pa:RangeMap ;
    rdfs:range c2pa:TextMap ;
    c2pa:relationshipType "has_one" .

c2pa:RangeMap.time a owl:ObjectProperty ;
    rdfs:label "time"@en ;
    rdfs:comment "description of the time boundaries of a temporal range"@en ;
    rdfs:domain c2pa:RangeMap ;
    rdfs:range c2pa:TimeMap .

c2pa:RatingMap.code a owl:ObjectProperty ;
    rdfs:label "code"@en ;
    rdfs:comment "A label-formatted string that describes the reason for the rating"@en ;
    rdfs:domain c2pa:RatingMap ;
    rdfs:range c2pa:ReviewCode .

c2pa:RatingMap.explanation a owl:DatatypeProperty ;
    rdfs:label "explanation"@en ;
    rdfs:comment "A human readable string explaining why the rating is what it is"@en ;
    rdfs:domain c2pa:RatingMap ;
    rdfs:range xsd:string .

c2pa:RegionMap.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "human readable description of the region"@en ;
    rdfs:domain c2pa:RegionMap ;
    rdfs:range xsd:string .

c2pa:RegionMap.identifier a owl:DatatypeProperty ;
    rdfs:label "identifier"@en ;
    rdfs:comment "a free-text string representing a machine-readable, unique to this assertion, identifier for the region."@en ;
    rdfs:domain c2pa:RegionMap ;
    rdfs:range xsd:string .

c2pa:RegionMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:RegionMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:RegionMap.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "a free-text string representing a human-readable name for the region which could be used in a user interface."@en ;
    rdfs:domain c2pa:RegionMap ;
    rdfs:range xsd:string .

c2pa:RegionMap.region a owl:ObjectProperty ;
    rdfs:label "region"@en ;
    rdfs:comment "definition of the range, one or more ranges"@en ;
    rdfs:domain c2pa:RegionMap ;
    rdfs:range c2pa:RangeMap ;
    c2pa:relationshipType "has_many" .

c2pa:RegionMap.role a owl:ObjectProperty ;
    rdfs:label "role"@en ;
    rdfs:comment "DEPRECATED"@en ;
    rdfs:domain c2pa:RegionMap ;
    rdfs:range c2pa:RoleChoice .

c2pa:RegionMap.type a owl:DatatypeProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "from a controlled list"@en ;
    rdfs:domain c2pa:RegionMap ;
    rdfs:range xsd:string .

