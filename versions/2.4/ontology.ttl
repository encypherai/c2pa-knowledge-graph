c2pa:manifest.claim_v2 a owl:ObjectProperty ;
    rdfs:label "claim.v2"@en ;
    rdfs:comment "Normalized claim (v2) per C2PA CDDL claim-map-v2; alternative to claim. A manifest SHALL contain either claim or claim.v2."@en ;
    rdfs:domain c2pa:manifest ;
    rdfs:range c2pa:claim ;
    c2pa:relationshipType "has_one" .

c2pa:manifestValidationResults.failure a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "failure"@en ;
    rdfs:domain c2pa:manifestValidationResults ;
    rdfs:range xsd:string,
        c2pa:validationStatusEntry ;
    c2pa:relationshipType "has_many" .

c2pa:manifestValidationResults.informational a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "informational"@en ;
    rdfs:domain c2pa:manifestValidationResults ;
    rdfs:range xsd:string,
        c2pa:validationStatusEntry ;
    c2pa:relationshipType "has_many" .

c2pa:manifestValidationResults.success a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "success"@en ;
    rdfs:domain c2pa:manifestValidationResults ;
    rdfs:range xsd:string,
        c2pa:validationStatusEntry ;
    c2pa:relationshipType "has_many" .

c2pa:parametersMapV1.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Additional description of the action"@en ;
    rdfs:domain c2pa:parametersMapV1 ;
    rdfs:range xsd:string .

c2pa:parametersMapV1.ingredient a owl:ObjectProperty ;
    rdfs:label "ingredient"@en ;
    rdfs:comment "Hashed URI to the ingredient assertion this action acts on"@en ;
    rdfs:domain c2pa:parametersMapV1 ;
    rdfs:range c2pa:hashedUriMap ;
    c2pa:relationshipType "belongs_to" .

c2pa:parametersMapV2.multipleInstances a owl:DatatypeProperty ;
    rdfs:label "multipleInstances"@en ;
    rdfs:comment "Whether this action was performed multiple times"@en ;
    rdfs:domain c2pa:parametersMapV2 ;
    rdfs:range xsd:boolean .

c2pa:parametersMapV2.redacted a owl:DatatypeProperty ;
    rdfs:label "redacted"@en ;
    rdfs:comment "JUMBF URI to the redacted assertion (required when action is c2pa.redacted)"@en ;
    rdfs:domain c2pa:parametersMapV2 ;
    rdfs:range xsd:string .

c2pa:parametersMapV2.sourceLanguage a owl:DatatypeProperty ;
    rdfs:label "sourceLanguage"@en ;
    rdfs:comment "BCP-47 code of the source language for c2pa.translated"@en ;
    rdfs:domain c2pa:parametersMapV2 ;
    rdfs:range xsd:string .

c2pa:parametersMapV2.targetLanguage a owl:DatatypeProperty ;
    rdfs:label "targetLanguage"@en ;
    rdfs:comment "BCP-47 code of the target language for c2pa.translated"@en ;
    rdfs:domain c2pa:parametersMapV2 ;
    rdfs:range xsd:string .

c2pa:partHashMap.optional a owl:DatatypeProperty ;
    rdfs:label "optional"@en ;
    rdfs:comment "If true, the part is optional and can be discarded"@en ;
    rdfs:domain c2pa:partHashMap ;
    rdfs:range xsd:boolean .

c2pa:ratingMap.code a owl:DatatypeProperty ;
    rdfs:label "code"@en ;
    rdfs:comment "Label-formatted reason for the rating; $review-code"@en ;
    rdfs:domain c2pa:ratingMap ;
    rdfs:range xsd:string ;
    c2pa:enumValues "actions.unknownActionsPerformed, actions.missing, actions.possiblyMissing, depthMap.sceneMismatch, ingredient.modified, ingredient.possiblyModified, thumbnail.primaryMismatch, stds.iptc.location.inaccurate, stds.schema-org.CreativeWork.misattributed, stds.schema-org.CreativeWork.missingAttribution" .

c2pa:ratingMap.explanation a owl:DatatypeProperty ;
    rdfs:label "explanation"@en ;
    rdfs:comment "Human-readable explanation for the rating"@en ;
    rdfs:domain c2pa:ratingMap ;
    rdfs:range xsd:string .

c2pa:signature.timeStampInfo a owl:ObjectProperty ;
    rdfs:label "timeStampInfo"@en ;
    rdfs:comment "Timestamp information (e.g. from TSA), when present"@en ;
    rdfs:domain c2pa:signature .

c2pa:softBindingAssertion.alg_params a owl:DatatypeProperty ;
    rdfs:label "alg-params"@en ;
    rdfs:comment "CBOR byte string (e.g. Base64 in JSON) describing parameters of the soft binding algorithm"@en ;
    rdfs:domain c2pa:softBindingAssertion ;
    rdfs:range xsd:string .

c2pa:softBindingAssertion.bindingMetadata a owl:ObjectProperty ;
    rdfs:label "bindingMetadata"@en ;
    rdfs:comment "Additional metadata of the soft binding"@en ;
    rdfs:domain c2pa:softBindingAssertion ;
    rdfs:range c2pa:softBindingMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:softBindingAssertion.blocks a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "blocks"@en ;
    rdfs:comment "One or more soft bindings across some or all of the asset's content"@en ;
    rdfs:domain c2pa:softBindingAssertion ;
    rdfs:range xsd:string,
        c2pa:softBindingBlockMap ;
    c2pa:relationshipType "has_many" .

c2pa:softBindingAssertion.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Human-readable description of what this hash covers"@en ;
    rdfs:domain c2pa:softBindingAssertion ;
    rdfs:range xsd:string .

c2pa:softBindingAssertion.pad a owl:DatatypeProperty ;
    rdfs:label "pad"@en ;
    rdfs:comment "Zero-filled byte string for filling space (typically Base64 in JSON)"@en ;
    rdfs:domain c2pa:softBindingAssertion ;
    rdfs:range xsd:string .

c2pa:softBindingAssertion.pad2 a owl:DatatypeProperty ;
    rdfs:label "pad2"@en ;
    rdfs:comment "Zero-filled byte string for filling space (typically Base64 in JSON)"@en ;
    rdfs:domain c2pa:softBindingAssertion ;
    rdfs:range xsd:string .

c2pa:softBindingAssertion.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "Unused and deprecated"@en ;
    rdfs:domain c2pa:softBindingAssertion ;
    rdfs:range xsd:anyURI .

c2pa:softBindingMetadataMap.contact a owl:DatatypeProperty ;
    rdfs:label "contact"@en ;
    rdfs:comment "Contact information for the implementation or author of the binding or algorithm"@en ;
    rdfs:domain c2pa:softBindingMetadataMap ;
    rdfs:range xsd:string .

c2pa:softBindingMetadataMap.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Additional description of the implementation or author of the binding or algorithm"@en ;
    rdfs:domain c2pa:softBindingMetadataMap ;
    rdfs:range xsd:string .

c2pa:softBindingMetadataMap.informationalUrl a owl:DatatypeProperty ;
    rdfs:label "informationalUrl"@en ;
    rdfs:comment "Web page with more details about the implementation or author of the binding or algorithm"@en ;
    rdfs:domain c2pa:softBindingMetadataMap ;
    rdfs:range xsd:string .

c2pa:softBindingScopeMap.extent a owl:DatatypeProperty ;
    rdfs:label "extent"@en ;
    rdfs:comment "Deprecated. CBOR byte string (e.g. Base64) describing the part of content over which the binding was computed"@en ;
    rdfs:domain c2pa:softBindingScopeMap ;
    rdfs:range xsd:string .

c2pa:softBindingScopeMap.region a owl:ObjectProperty ;
    rdfs:label "region"@en ;
    rdfs:comment "Region of interest (region-map)"@en ;
    rdfs:domain c2pa:softBindingScopeMap ;
    rdfs:range c2pa:RegionMap ;
    c2pa:relationshipType "has_one" .

c2pa:softBindingScopeMap.timespan a owl:ObjectProperty ;
    rdfs:label "timespan"@en ;
    rdfs:comment "Time range over which the soft binding value has been computed"@en ;
    rdfs:domain c2pa:softBindingScopeMap ;
    rdfs:range c2pa:softBindingTimespanMap ;
    c2pa:relationshipType "has_one" .

c2pa:softwareAgent.icon a owl:ObjectProperty ;
    rdfs:label "icon"@en ;
    rdfs:comment "Icon representing the software/hardware"@en ;
    rdfs:domain c2pa:softwareAgent ;
    rdfs:range c2pa:hashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:softwareAgent.operating_system a owl:DatatypeProperty ;
    rdfs:label "operating_system"@en ;
    rdfs:comment "Operating system the software runs on"@en ;
    rdfs:domain c2pa:softwareAgent ;
    rdfs:range xsd:string .

c2pa:softwareAgent.version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "Version of the software"@en ;
    rdfs:domain c2pa:softwareAgent ;
    rdfs:range xsd:string .

c2pa:sourceMap.details a owl:DatatypeProperty ;
    rdfs:label "details"@en ;
    rdfs:comment "Human-readable details about the source, e.g. URL of the remote server"@en ;
    rdfs:domain c2pa:sourceMap ;
    rdfs:range xsd:string .

c2pa:statusCodes.failure a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "failure"@en ;
    rdfs:domain c2pa:statusCodes ;
    rdfs:range xsd:string,
        c2pa:validationStatusEntry ;
    c2pa:relationshipType "has_many" .

c2pa:statusCodes.informational a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "informational"@en ;
    rdfs:domain c2pa:statusCodes ;
    rdfs:range xsd:string,
        c2pa:validationStatusEntry ;
    c2pa:relationshipType "has_many" .

c2pa:statusCodes.success a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "success"@en ;
    rdfs:domain c2pa:statusCodes ;
    rdfs:range xsd:string,
        c2pa:validationStatusEntry ;
    c2pa:relationshipType "has_many" .

c2pa:thumbnailAssertion.mimeType a owl:DatatypeProperty ;
    rdfs:label "mimeType"@en ;
    rdfs:comment "MIME type of thumbnail"@en ;
    rdfs:domain c2pa:thumbnailAssertion ;
    rdfs:range xsd:string .

c2pa:thumbnailAssertion.thumbnailType a owl:DatatypeProperty ;
    rdfs:label "thumbnailType"@en ;
    rdfs:comment "Thumbnail type (0=claim, 1=ingredient)"@en ;
    rdfs:domain c2pa:thumbnailAssertion ;
    rdfs:range xsd:integer .

c2pa:validationResults.specVersion a owl:DatatypeProperty ;
    rdfs:label "specVersion"@en ;
    rdfs:comment "The version of the specification against which the validation was performed (SemVer formatted string)"@en ;
    rdfs:domain c2pa:validationResults ;
    rdfs:range xsd:string ;
    c2pa:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$" .

c2pa:validationResults.trustListUri a owl:DatatypeProperty ;
    rdfs:label "trustListUri"@en ;
    rdfs:comment "URI to the trust list that was used to validate certificates"@en ;
    rdfs:domain c2pa:validationResults ;
    rdfs:range xsd:anyURI .

c2pa:validationStatusEntry.explanation a owl:DatatypeProperty ;
    rdfs:label "explanation"@en ;
    rdfs:comment "Human-readable explanation"@en ;
    rdfs:domain c2pa:validationStatusEntry ;
    rdfs:range xsd:string .

c2pa:validationStatusEntry.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "JUMBF URI where status applies"@en ;
    rdfs:domain c2pa:validationStatusEntry ;
    rdfs:range xsd:string .

c2pa:ActionItemMapV2.action a owl:ObjectProperty ;
    rdfs:label "action"@en ;
    rdfs:comment "time-stamp of when the action occurred."@en ;
    rdfs:domain c2pa:ActionItemMapV2 ;
    rdfs:range c2pa:ActionChoice .

c2pa:ActionItemsMap.action a owl:ObjectProperty ;
    rdfs:label "action"@en ;
    rdfs:comment "time-stamp of when the action occurred."@en ;
    rdfs:domain c2pa:ActionItemsMap ;
    rdfs:range c2pa:ActionChoice .

c2pa:ActionTemplateMapV2.action a owl:DatatypeProperty ;
    rdfs:label "action"@en ;
    rdfs:comment "time-stamp of when the action occurred."@en ;
    rdfs:domain c2pa:ActionTemplateMapV2 ;
    rdfs:range rdfs:Literal .

c2pa:ActionsMap a owl:Class ;
    rdfs:label "ActionsMap"@en ;
    rdfs:comment "An actions assertion provides information on edits and other actions taken that affect the asset's content. There will be an array of actions - each action declaring _what_ took place on the asset and (optionally) _when_ it took place, along with possible other information such as what software performed the action. Except where noted in , the order of actions in this array is unspecified, and does not imply the order in which actions were performed."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ActionsMap.metadata ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ActionsMap.actions ] ;
    owl:sameAs c2pa:actions-map .

c2pa:AraReferenceBlockMap.reference a owl:ObjectProperty ;
    rdfs:label "reference"@en ;
    rdfs:comment "Human readable description of the location."@en ;
    rdfs:domain c2pa:AraReferenceBlockMap ;
    rdfs:range c2pa:AraReferenceUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:AraReferenceUriMap a owl:Class ;
    rdfs:label "AraReferenceUriMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AraReferenceUriMap.uri ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AraReferenceUriMap.uri ] ;
    owl:sameAs c2pa:ara-reference-uri-map .

c2pa:AraReferenceUriMap.uri a owl:DatatypeProperty ;
    rdfs:label "uri"@en ;
    rdfs:comment "URI reference a location where a copy of the asset may be obtained from"@en ;
    rdfs:domain c2pa:AraReferenceUriMap ;
    rdfs:range xsd:string .

c2pa:AssetRefMap a owl:Class ;
    rdfs:label "AssetRefMap"@en ;
    rdfs:comment "The asset reference assertion (ARA) describes where a copy of the asset may be obtained."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssetRefMap.references ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssetRefMap.metadata ] ;
    owl:sameAs c2pa:asset-ref-map .

c2pa:AssetTypeMap.type a owl:ObjectProperty ;
    rdfs:label "type"@en ;
    rdfs:domain c2pa:AssetTypeMap ;
    rdfs:range c2pa:AssetTypeChoice .

c2pa:BmffMerkleMap.localId a owl:DatatypeProperty ;
    rdfs:label "localId"@en ;
    rdfs:comment "A local id indicating Merkle tree."@en ;
    rdfs:domain c2pa:BmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:BmffMerkleMap.location a owl:DatatypeProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "Zero-based index into the leaf-most Merkle tree row corresponding to this 'mdat' box or portion of this 'mdat' box"@en ;
    rdfs:domain c2pa:BmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:BmffMerkleMap.uniqueId a owl:DatatypeProperty ;
    rdfs:label "uniqueId"@en ;
    rdfs:comment "1-based unique id to determine which Merkle tree validates a given mdat box"@en ;
    rdfs:domain c2pa:BmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:BoxExclusionsMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "Number of bytes of data to exclude"@en ;
    rdfs:domain c2pa:BoxExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:BoxExclusionsMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "Starting byte offset (from the start of the box) of the range"@en ;
    rdfs:domain c2pa:BoxExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:BoxHashMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "byte string of the hash value"@en ;
    rdfs:domain c2pa:BoxHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:BoxMap a owl:Class ;
    rdfs:label "BoxMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:BoxMap.alg ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:BoxMap.boxes ] ;
    owl:sameAs c2pa:box-map .

c2pa:ClaimMap.claim_generator a owl:DatatypeProperty ;
    rdfs:label "claim_generator"@en ;
    rdfs:comment "A User-Agent string formatted as per http://tools.ietf.org/html/rfc7231#section-5.5.3, for including the name and version of the claims generator that created the claim"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "uniquely identifies a specific version of an asset"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMap.signature a owl:DatatypeProperty ;
    rdfs:label "signature"@en ;
    rdfs:comment "JUMBF URI reference to the signature of this claim"@en ;
    rdfs:domain c2pa:ClaimMap ;
    rdfs:range xsd:string .

c2pa:ClaimMapV2.claim_generator_info a owl:ObjectProperty ;
    rdfs:label "claim_generator_info"@en ;
    rdfs:comment "JUMBF URI reference to the signature of this claim"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range c2pa:GeneratorInfoMap ;
    c2pa:relationshipType "has_one" .

c2pa:ClaimMapV2.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "uniquely identifies a specific version of an asset"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range xsd:string .

c2pa:ClaimMapV2.signature a owl:DatatypeProperty ;
    rdfs:label "signature"@en ;
    rdfs:comment "JUMBF URI reference to the signature of this claim"@en ;
    rdfs:domain c2pa:ClaimMapV2 ;
    rdfs:range xsd:string .

c2pa:CloudDataMap.label a owl:DatatypeProperty ;
    rdfs:label "label"@en ;
    rdfs:comment "label for the cloud-based assertion (eg.c2pa.actions)"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range xsd:string .

c2pa:CloudDataMap.location a owl:ObjectProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "http(s) URL to where the cloud-hosted assertion can be found"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range c2pa:HashedExtUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:CloudDataMap.size a owl:ObjectProperty ;
    rdfs:label "size"@en ;
    rdfs:comment "Number of bytes of data"@en ;
    rdfs:domain c2pa:CloudDataMap ;
    rdfs:range c2pa:SizeType .

c2pa:CollectionDataHashMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:domain c2pa:CollectionDataHashMap ;
    rdfs:range xsd:string .

<https://c2pa.org/ontology/CommonSchema.@container> a owl:ObjectProperty ;
    rdfs:label "@container"@en ;
    rdfs:comment "Used to set the default container type for a term"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range c2pa:ContainerGroupChoice .

<https://c2pa.org/ontology/CommonSchema.@id> a owl:DatatypeProperty ;
    rdfs:label "@id"@en ;
    rdfs:comment "Used to uniquely identify things that are being described in the document with IRIs or blank node identifiers"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range xsd:anyURI .

<https://c2pa.org/ontology/CommonSchema.@language> a owl:ObjectProperty ;
    rdfs:label "@language"@en ;
    rdfs:comment "Used to specify the language for a particular string value or the default language of a JSON-LD document"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range c2pa:LanguageTypeChoice .

<https://c2pa.org/ontology/CommonSchema.@type> a owl:ObjectProperty ;
    rdfs:label "@type"@en ;
    rdfs:comment "Used to set the data type of a node or typed value"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range c2pa:TypeTypeChoice .

<https://c2pa.org/ontology/CommonSchema.@value> a owl:ObjectProperty ;
    rdfs:label "@value"@en ;
    rdfs:comment "Used to specify the data that is associated with a particular property in the graph"@en ;
    rdfs:domain c2pa:CommonSchema ;
    rdfs:range c2pa:ValueTypeChoice .

<https://c2pa.org/ontology/ContentCredentialsJSONcrJSONDocumentSchema.@context> a owl:DatatypeProperty ;
    rdfs:label "@context"@en ;
    rdfs:comment "JSON-LD context defining namespaces and vocabularies"@en ;
    rdfs:domain c2pa:ContentCredentialsJSONcrJSONDocumentSchema ;
    rdfs:range rdfs:Literal .

c2pa:ContentCredentialsJSONcrJSONDocumentSchema.jsonGenerator a owl:ObjectProperty ;
    rdfs:label "jsonGenerator"@en ;
    rdfs:comment "Information about the tool used to generate this JSON"@en ;
    rdfs:domain c2pa:ContentCredentialsJSONcrJSONDocumentSchema ;
    rdfs:range c2pa:jsonGenerator ;
    c2pa:relationshipType "has_one" .

c2pa:ContextSchema a owl:Class ;
    rdfs:label "ContextSchema"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://c2pa.org/ontology/ContextSchema.@context> ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://c2pa.org/ontology/ContextSchema.@context> ] ;
    owl:sameAs c2pa:context-schema .

<https://c2pa.org/ontology/ContextSchema.@context> a owl:ObjectProperty ;
    rdfs:label "@context"@en ;
    rdfs:comment "Used to express an ordered set of data"@en ;
    rdfs:domain c2pa:ContextSchema ;
    rdfs:range c2pa:ContextTypeChoice ;
    c2pa:relationshipType "has_one" .

c2pa:CoordinateMap.x a owl:DatatypeProperty ;
    rdfs:label "x"@en ;
    rdfs:comment "coordinate along the x-axis"@en ;
    rdfs:domain c2pa:CoordinateMap ;
    rdfs:range xsd:decimal .

c2pa:CoordinateMap.y a owl:DatatypeProperty ;
    rdfs:label "y"@en ;
    rdfs:comment "coordinate along the y-axis"@en ;
    rdfs:domain c2pa:CoordinateMap ;
    rdfs:range xsd:decimal .

c2pa:DataBoxMap.data a owl:DatatypeProperty ;
    rdfs:label "data"@en ;
    rdfs:comment "arbitrary text/binary data"@en ;
    rdfs:domain c2pa:DataBoxMap ;
    rdfs:range xsd:base64Binary .

c2pa:DataBoxMap.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "IANA media type of the data"@en ;
    rdfs:domain c2pa:DataBoxMap ;
    rdfs:range xsd:string .

c2pa:DataHashMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "byte string of the hash value"@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:DataHashMap.pad a owl:DatatypeProperty ;
    rdfs:label "pad"@en ;
    rdfs:comment "zero-filled byte string used for filling up space"@en ;
    rdfs:domain c2pa:DataHashMap ;
    rdfs:range xsd:base64Binary .

c2pa:DataMap.offset a owl:DatatypeProperty ;
    rdfs:label "offset"@en ;
    rdfs:comment "Each entry in a map is a Merkle tree row and the associated data required to enable validation of a single"@en ;
    rdfs:domain c2pa:DataMap ;
    rdfs:range xsd:integer .

c2pa:DataMap.value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:domain c2pa:DataMap ;
    rdfs:range xsd:base64Binary .

c2pa:DepthMeasChoice a owl:Class ;
    rdfs:label "DepthMeasChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:DepthMeasChoice.OpticalAxis c2pa:DepthMeasChoice.OpticRay ) ] .

c2pa:DepthmapGdepthMap.GDepth_Data a owl:ObjectProperty ;
    rdfs:label "GDepth:Data"@en ;
    rdfs:comment "The base64 encoded depth image. See GDepth encoding page at developers.google.com. The depthmap will be stretched-to-fit the corresponding color image"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:Base64StringType .

c2pa:DepthmapGdepthMap.GDepth_Far a owl:DatatypeProperty ;
    rdfs:label "GDepth:Far"@en ;
    rdfs:comment "The far value of the depthmap in depth units"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:decimal .

c2pa:DepthmapGdepthMap.GDepth_Format a owl:ObjectProperty ;
    rdfs:label "GDepth:Format"@en ;
    rdfs:comment "The format that describes how to convert the depthmap data into a valid float-point depthmap. Current valid values are 'RangeInverse' and 'RangeLinear'"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:FormatType .

c2pa:DepthmapGdepthMap.GDepth_Mime a owl:ObjectProperty ;
    rdfs:label "GDepth:Mime"@en ;
    rdfs:comment "The mime type for the base64 string describing the depth image content, e.g. 'image/jpeg' or 'image/png'\","@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range c2pa:MimeType .

c2pa:DepthmapGdepthMap.GDepth_Near a owl:DatatypeProperty ;
    rdfs:label "GDepth:Near"@en ;
    rdfs:comment "The near value of the depthmap in depth units"@en ;
    rdfs:domain c2pa:DepthmapGdepthMap ;
    rdfs:range xsd:decimal .

c2pa:EndorsementTargetMap.endorseeCredential a owl:ObjectProperty ;
    rdfs:label "endorseeCredential"@en ;
    rdfs:comment "A DER-encoded SubjectPublicKeyInfo containing the public key"@en ;
    rdfs:domain c2pa:EndorsementTargetMap ;
    rdfs:range c2pa:PublicCredential ;
    c2pa:relationshipType "has_one" .

c2pa:EndorsementTargetMap.notValidAfter a owl:DatatypeProperty ;
    rdfs:label "notValidAfter"@en ;
    rdfs:comment "The date-time that this endorsement expires and is no longer valid"@en ;
    rdfs:domain c2pa:EndorsementTargetMap ;
    rdfs:range xsd:dateTime .

c2pa:EndorsementTargetMap.notValidBefore a owl:DatatypeProperty ;
    rdfs:label "notValidBefore"@en ;
    rdfs:comment "The date-time that this endorsement valid from, before this time it is not valid"@en ;
    rdfs:domain c2pa:EndorsementTargetMap ;
    rdfs:range xsd:dateTime .

c2pa:EnvironmentalSustainabilityMeasurementMap.value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:domain c2pa:EnvironmentalSustainabilityMeasurementMap ;
    rdfs:range xsd:decimal .

c2pa:ExclusionRangeMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "Number of bytes of data to exclude"@en ;
    rdfs:domain c2pa:ExclusionRangeMap ;
    rdfs:range xsd:integer .

c2pa:ExclusionRangeMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "Starting byte of the range"@en ;
    rdfs:domain c2pa:ExclusionRangeMap ;
    rdfs:range xsd:integer .

c2pa:ExclusionsMap.xpath a owl:DatatypeProperty ;
    rdfs:label "xpath"@en ;
    rdfs:comment "Location of box(es) to exclude from the hash starting from the root node as an xpath formatted string of version https://www.w3.org/TR/xpath-10/ with highly constrained syntax."@en ;
    rdfs:domain c2pa:ExclusionsMap ;
    rdfs:range xsd:string .

c2pa:ExternalReferenceMap.location a owl:ObjectProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "specifies the location and type of the remote data"@en ;
    rdfs:domain c2pa:ExternalReferenceMap ;
    rdfs:range c2pa:UnhashedExtUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:FontDesignerMap.person a owl:ObjectProperty ;
    rdfs:label "person"@en ;
    rdfs:comment "The person who designed the font."@en ;
    rdfs:domain c2pa:FontDesignerMap ;
    rdfs:range c2pa:FontEntityMap ;
    c2pa:relationshipType "has_one" .

c2pa:FontEntityMap.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "The name of the person or foundry."@en ;
    rdfs:domain c2pa:FontEntityMap ;
    rdfs:range xsd:string .

c2pa:FontInfoMap.copyrightNotice a owl:DatatypeProperty ;
    rdfs:label "copyrightNotice"@en ;
    rdfs:comment "The copyright associated with this font."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range xsd:string .

c2pa:FontInfoMap.familyName a owl:DatatypeProperty ;
    rdfs:label "familyName"@en ;
    rdfs:comment "The Font Family."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range xsd:string .

c2pa:FontInfoMap.format a owl:ObjectProperty ;
    rdfs:label "format"@en ;
    rdfs:comment "The format of this font."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:FontFormatChoice .

c2pa:FontInfoMap.fullName a owl:DatatypeProperty ;
    rdfs:label "fullName"@en ;
    rdfs:comment "The full name of the font."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range xsd:string .

c2pa:FontInfoMap.postScriptName a owl:DatatypeProperty ;
    rdfs:label "postScriptName"@en ;
    rdfs:comment "Characters from ASCII 33-126 except the following: [](){}<>/%"@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range xsd:string ;
    c2pa:pattern "^(?!.*[\\\\[\\\\]\\\\(\\\\)\\\\{\\\\}<>\\\\/%])[!-~]{1,63}$" .

c2pa:FontInfoMap.style a owl:ObjectProperty ;
    rdfs:label "style"@en ;
    rdfs:comment "The style of the font, e.g. italic or regular."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:FontStyle .

c2pa:FontInfoMap.weight a owl:ObjectProperty ;
    rdfs:label "weight"@en ;
    rdfs:comment "The weight of the font with name and value."@en ;
    rdfs:domain c2pa:FontInfoMap ;
    rdfs:range c2pa:FontWeightMap ;
    c2pa:relationshipType "has_one" .

c2pa:FontUnicodeRangeMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "Inclusive start"@en ;
    rdfs:domain c2pa:FontUnicodeRangeMap ;
    rdfs:range xsd:integer .

c2pa:FontUnicodeRangeMap.stop a owl:DatatypeProperty ;
    rdfs:label "stop"@en ;
    rdfs:comment "Inclusive end"@en ;
    rdfs:domain c2pa:FontUnicodeRangeMap ;
    rdfs:range xsd:integer .

c2pa:FontWeightMap.class a owl:ObjectProperty ;
    rdfs:label "class"@en ;
    rdfs:comment "The descriptive name of the weight class, e.g. bold or thin."@en ;
    rdfs:domain c2pa:FontWeightMap ;
    rdfs:range c2pa:FontWeightClass .

c2pa:FontWeightMap.value a owl:ObjectProperty ;
    rdfs:label "value"@en ;
    rdfs:comment "The value of the weight."@en ;
    rdfs:domain c2pa:FontWeightMap ;
    rdfs:range c2pa:FontWeightRange .

c2pa:FormatChoice a owl:Class ;
    rdfs:label "FormatChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:FormatChoice.RangeInverse c2pa:FormatChoice.RangeLinear ) ] .

c2pa:GeneratorInfoMap.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "A human readable string naming the claim generator"@en ;
    rdfs:domain c2pa:GeneratorInfoMap ;
    rdfs:range xsd:string .

c2pa:GenericRepresentation.parameters a owl:ObjectProperty ;
    rdfs:label "parameters"@en ;
    rdfs:domain c2pa:GenericRepresentation .

c2pa:GenericRepresentation.type a owl:DatatypeProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:GenericRepresentation ;
    rdfs:range xsd:string ;
    c2pa:pattern "([\\\\da-zA-Z_-]+\\\\.)+[\\\\da-zA-Z_-]+" .

c2pa:HashedExtUriMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the cryptographic hash algorithm used to compute the hash on this URI's data, taken from the C2PA hash algorithm identifier list. Unlike alg fields in other types, this field is mandatory here."@en ;
    rdfs:domain c2pa:HashedExtUriMap ;
    rdfs:range xsd:string .

c2pa:HashedExtUriMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "byte string containing the hash value"@en ;
    rdfs:domain c2pa:HashedExtUriMap ;
    rdfs:range xsd:base64Binary .

c2pa:HashedExtUriMap.url a owl:ObjectProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "http/https URI reference"@en ;
    rdfs:domain c2pa:HashedExtUriMap ;
    rdfs:range c2pa:ExtUrlType .

c2pa:HashedExternalReferenceMap.location a owl:ObjectProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "specifies the location and type of the remote data"@en ;
    rdfs:domain c2pa:HashedExternalReferenceMap ;
    rdfs:range c2pa:HashedExtUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:HashedUriMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "byte string containing the hash value"@en ;
    rdfs:domain c2pa:HashedUriMap ;
    rdfs:range xsd:base64Binary .

c2pa:HashedUriMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "JUMBF URI reference"@en ;
    rdfs:domain c2pa:HashedUriMap ;
    rdfs:range xsd:string .

c2pa:IngredientDeltaValidationResultMap.ingredientAssertionURI a owl:DatatypeProperty ;
    rdfs:label "ingredientAssertionURI"@en ;
    rdfs:comment "JUMBF URI reference to the ingredient assertion"@en ;
    rdfs:domain c2pa:IngredientDeltaValidationResultMap ;
    rdfs:range xsd:string .

c2pa:IngredientDeltaValidationResultMap.validationDeltas a owl:ObjectProperty ;
    rdfs:label "validationDeltas"@en ;
    rdfs:comment "Validation results for the ingredient's active manifest"@en ;
    rdfs:domain c2pa:IngredientDeltaValidationResultMap ;
    rdfs:range c2pa:StatusCodesMap ;
    c2pa:relationshipType "has_one" .

c2pa:IngredientMap.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "Media Type of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range xsd:string .

c2pa:IngredientMap.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "name of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range xsd:string .

c2pa:IngredientMap.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "unique identifier, such as the value of the ingredient's `xmpMM:InstanceID`"@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range xsd:string .

c2pa:IngredientMap.relationship a owl:ObjectProperty ;
    rdfs:label "relationship"@en ;
    rdfs:comment "The relationship of this ingredient to the asset it is an ingredient of."@en ;
    rdfs:domain c2pa:IngredientMap ;
    rdfs:range c2pa:RelationChoice .

c2pa:IngredientMapV2.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "Media Type of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV2.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "name of the ingredient"@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range xsd:string .

c2pa:IngredientMapV2.relationship a owl:ObjectProperty ;
    rdfs:label "relationship"@en ;
    rdfs:comment "The relationship of this ingredient to the asset it is an ingredient of."@en ;
    rdfs:domain c2pa:IngredientMapV2 ;
    rdfs:range c2pa:RelationChoice .

c2pa:IngredientMapV3.relationship a owl:ObjectProperty ;
    rdfs:label "relationship"@en ;
    rdfs:comment "The relationship of this ingredient to the asset it is an ingredient of."@en ;
    rdfs:domain c2pa:IngredientMapV3 ;
    rdfs:range c2pa:RelationChoice .

c2pa:ItemMap.identifier a owl:DatatypeProperty ;
    rdfs:label "identifier"@en ;
    rdfs:comment "a free-text string representing a machine-readable, unique to this assertion, identifier for the region."@en ;
    rdfs:domain c2pa:ItemMap ;
    rdfs:range xsd:string .

c2pa:ItemMap.value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:comment "the value of the identifier, e.g. a value of \"2\" for an identifier of \"track_id\" would imply track 2 of the asset"@en ;
    rdfs:domain c2pa:ItemMap ;
    rdfs:range xsd:string .

c2pa:JsonldSchemaMap.common a owl:ObjectProperty ;
    rdfs:label "common"@en ;
    rdfs:comment "Used to define common things"@en ;
    rdfs:domain c2pa:JsonldSchemaMap ;
    rdfs:range c2pa:CommonSchema ;
    c2pa:relationshipType "has_one" .

c2pa:JsonldSchemaMap.context a owl:ObjectProperty ;
    rdfs:label "context"@en ;
    rdfs:comment "Used to define the short-hand names that are used throughout a JSON-LD document"@en ;
    rdfs:domain c2pa:JsonldSchemaMap ;
    rdfs:range c2pa:ContextSchema ;
    c2pa:relationshipType "has_one" .

c2pa:JsonldSchemaMap.graph a owl:ObjectProperty ;
    rdfs:label "graph"@en ;
    rdfs:comment "Used to express a graph"@en ;
    rdfs:domain c2pa:JsonldSchemaMap ;
    rdfs:range c2pa:GraphType ;
    c2pa:relationshipType "has_one" .

c2pa:LivevideoSegmentMap.continuityMethod a owl:DatatypeProperty ;
    rdfs:label "continuityMethod"@en ;
    rdfs:comment "method used to ensure continuity between segments"@en ;
    rdfs:domain c2pa:LivevideoSegmentMap ;
    rdfs:range xsd:string .

c2pa:LivevideoSegmentMap.sequenceNumber a owl:DatatypeProperty ;
    rdfs:label "sequenceNumber"@en ;
    rdfs:comment "monotonically increasing sequence number for each segment"@en ;
    rdfs:domain c2pa:LivevideoSegmentMap ;
    rdfs:range xsd:integer .

c2pa:LivevideoSegmentMap.streamId a owl:DatatypeProperty ;
    rdfs:label "streamId"@en ;
    rdfs:comment "A unique \"streamId\" identifying the live video stream"@en ;
    rdfs:domain c2pa:LivevideoSegmentMap ;
    rdfs:range xsd:string .

c2pa:LivevideoSegmentMapManifestid.previousManifestId a owl:DatatypeProperty ;
    rdfs:label "previousManifestId"@en ;
    rdfs:comment "<<manifest-identifier>> of the previous segment's C2PA Manifest"@en ;
    rdfs:domain c2pa:LivevideoSegmentMapManifestid ;
    rdfs:range xsd:string .

c2pa:LocalizationDataEntry a owl:Class ;
    rdfs:label "LocalizationDataEntry"@en ;
    owl:sameAs <https://c2pa.org/ontology/$localization-data-entry> ;
    c2pa:extensible true .

c2pa:LocatorMap a owl:Class ;
    rdfs:label "LocatorMap"@en ;
    rdfs:comment "this is a special CDDL map of choices (meaning that only one of the following can be present) The byte offset & length of the part within the file An XPath to the BMFF box of the part"@en ;
    owl:sameAs c2pa:locator-map .

c2pa:MerkleMap.count a owl:DatatypeProperty ;
    rdfs:label "count"@en ;
    rdfs:comment "Number of leaf nodes in the Merkle tree.  Null nodes are not included in this count."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:integer .

c2pa:MerkleMap.localId a owl:DatatypeProperty ;
    rdfs:label "localId"@en ;
    rdfs:comment "A local id indicating Merkle tree."@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:integer .

c2pa:MerkleMap.uniqueId a owl:DatatypeProperty ;
    rdfs:label "uniqueId"@en ;
    rdfs:domain c2pa:MerkleMap ;
    rdfs:range xsd:integer .

c2pa:MimeChoice a owl:Class ;
    rdfs:label "MimeChoice"@en ;
    owl:equivalentClass [ owl:oneOf ( c2pa:MimeChoice.image_jpeg c2pa:MimeChoice.image_png ) ] .

c2pa:OriginalPreservationImageRepresentation.parameters a owl:ObjectProperty ;
    rdfs:label "parameters"@en ;
    rdfs:domain c2pa:OriginalPreservationImageRepresentation ;
    rdfs:range c2pa:OriginalPreservationImageParams ;
    c2pa:relationshipType "has_one" .

c2pa:OriginalPreservationImageRepresentation.type a owl:DatatypeProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:OriginalPreservationImageRepresentation ;
    rdfs:range xsd:string .

c2pa:PartHashMap.hashAssertion a owl:ObjectProperty ;
    rdfs:label "hashAssertion"@en ;
    rdfs:comment "hashed_uri to the hash assertion of the part"@en ;
    rdfs:domain c2pa:PartHashMap ;
    rdfs:range c2pa:HashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:PartHashMap.location a owl:ObjectProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "Location of the part within the file (byte range or BMFF box path)"@en ;
    rdfs:domain c2pa:PartHashMap ;
    rdfs:range c2pa:LocatorMap ;
    c2pa:relationshipType "has_one" .

c2pa:PublicCredential a owl:Class ;
    rdfs:label "PublicCredential"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://c2pa.org/ontology/PublicCredential.$credential_type> ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://c2pa.org/ontology/PublicCredential.$credential_type> ] ;
    owl:sameAs c2pa:public-credential .

<https://c2pa.org/ontology/PublicCredential.$credential_type> a owl:DatatypeProperty ;
    rdfs:label "$credential-type"@en ;
    rdfs:domain c2pa:PublicCredential ;
    rdfs:range rdfs:Literal .

c2pa:RangeMap.type a owl:ObjectProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "from a controlled list"@en ;
    rdfs:domain c2pa:RangeMap ;
    rdfs:range c2pa:RangeChoice .

c2pa:RatingMap.value a owl:ObjectProperty ;
    rdfs:label "value"@en ;
    rdfs:comment "Rating from 1 (worst) to 5 (best)"@en ;
    rdfs:domain c2pa:RatingMap ;
    rdfs:range c2pa:IntRange .

c2pa:SegmentInfoMap.bmffHash a owl:ObjectProperty ;
    rdfs:label "bmffHash"@en ;
    rdfs:comment "C2PA c2pa.hash.bmff.v3"@en ;
    rdfs:domain c2pa:SegmentInfoMap ;
    rdfs:range c2pa:BmffHashMap ;
    c2pa:relationshipType "has_one" .

c2pa:SegmentInfoMap.manifestId a owl:DatatypeProperty ;
    rdfs:label "manifestId"@en ;
    rdfs:comment "shall be as described in <<manifest-identifier>>"@en ;
    rdfs:domain c2pa:SegmentInfoMap ;
    rdfs:range xsd:string .

c2pa:SegmentInfoMap.sequenceNumber a owl:DatatypeProperty ;
    rdfs:label "sequenceNumber"@en ;
    rdfs:comment "monotonically increasing sequence number for each segment"@en ;
    rdfs:domain c2pa:SegmentInfoMap ;
    rdfs:range xsd:integer .

c2pa:SessionKey.createdAt a owl:DatatypeProperty ;
    rdfs:label "createdAt"@en ;
    rdfs:comment "CBOR tag 0 (RFC 3339 date-time)"@en ;
    rdfs:domain c2pa:SessionKey ;
    rdfs:range xsd:base64Binary .

c2pa:SessionKey.key a owl:ObjectProperty ;
    rdfs:label "key"@en ;
    rdfs:comment "session key used to sign the `verifiable-segment-info-map`, note: semantics need to require kid in COSE_Key"@en ;
    rdfs:domain c2pa:SessionKey ;
    rdfs:range c2pa:CoseKey .

c2pa:SessionKey.minSequenceNumber a owl:DatatypeProperty ;
    rdfs:label "minSequenceNumber"@en ;
    rdfs:comment "minimum sequence number that can be signed with this key"@en ;
    rdfs:domain c2pa:SessionKey ;
    rdfs:range xsd:integer .

c2pa:SessionKey.signerBinding a owl:ObjectProperty ;
    rdfs:label "signerBinding"@en ;
    rdfs:comment "A signature of the Signer's end-entity certificate, using the session key `key`, enabling verification that the session key is associated with this Signer"@en ;
    rdfs:domain c2pa:SessionKey ;
    rdfs:range c2pa:CoseSign1 .

c2pa:SessionKey.validityPeriod a owl:DatatypeProperty ;
    rdfs:label "validityPeriod"@en ;
    rdfs:comment "seconds from createdAt, key is valid for this period between createdAt and createdAt + validityPeriod"@en ;
    rdfs:domain c2pa:SessionKey ;
    rdfs:range xsd:integer .

c2pa:ShapeMap.origin a owl:ObjectProperty ;
    rdfs:label "origin"@en ;
    rdfs:comment "starting/origin coordinate of the shape."@en ;
    rdfs:domain c2pa:ShapeMap ;
    rdfs:range c2pa:CoordinateMap ;
    c2pa:relationshipType "has_one" .

c2pa:ShapeMap.type a owl:ObjectProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "from a controlled list"@en ;
    rdfs:domain c2pa:ShapeMap ;
    rdfs:range c2pa:ShapeChoice .

c2pa:ShapeMap.unit a owl:ObjectProperty ;
    rdfs:label "unit"@en ;
    rdfs:comment "either \"pixel\" or \"percent\""@en ;
    rdfs:domain c2pa:ShapeMap ;
    rdfs:range c2pa:UnitChoice .

c2pa:SoftBindingBlockMap.scope a owl:ObjectProperty ;
    rdfs:label "scope"@en ;
    rdfs:comment "CBOR byte string describing, in algorithm specific format, the value of the soft binding computed over this block of digital content\""@en ;
    rdfs:domain c2pa:SoftBindingBlockMap ;
    rdfs:range c2pa:SoftBindingScopeMap ;
    c2pa:relationshipType "has_one" .

c2pa:SoftBindingBlockMap.value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:comment "CBOR byte string (e.g. Base64 in JSON), in algorithm-specific format, for the soft binding value over this block"@en ;
    rdfs:domain c2pa:SoftBindingBlockMap ;
    rdfs:range xsd:base64Binary .

c2pa:SoftBindingMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "A string identifying the soft binding algorithm and version of that algorithm used to compute the value, taken from the C2PA soft binding algorithm list. If this field is absent, the algorithm is taken from the `alg_soft` value of the enclosing structure. If both are present, the field in this structure is used.  If no value is present in any of these places, this structure is invalid; there is no default."@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range xsd:string .

c2pa:SoftBindingTimespanMap.end a owl:DatatypeProperty ;
    rdfs:label "end"@en ;
    rdfs:comment "End of the time range (as milliseconds from media start) over which the soft binding value has been computed."@en ;
    rdfs:domain c2pa:SoftBindingTimespanMap ;
    rdfs:range xsd:integer .

c2pa:SoftBindingTimespanMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "Start of the time range (as milliseconds from media start) over which the soft binding value has been computed."@en ;
    rdfs:domain c2pa:SoftBindingTimespanMap ;
    rdfs:range xsd:integer .

c2pa:SourceMap.type a owl:ObjectProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "A value from among the enumerated list indicating whether the source of the assertion is a claim generator running in a rich execution environment (REE), a claim generator running in a trusted execution environment (TEE), a local data provider in REE (e.g. the location API from a mobile operating system), a local data running in a TEE (e.g. a trusted location trusted app from a chipset vendor), a remote data provider such as a server (e.g. Google's geolocation API service), or entry by a human."@en ;
    rdfs:domain c2pa:SourceMap ;
    rdfs:range c2pa:SourceType .

c2pa:StatusMap.code a owl:ObjectProperty ;
    rdfs:label "code"@en ;
    rdfs:domain c2pa:StatusMap ;
    rdfs:range c2pa:StatusCode .

c2pa:SubsetMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "(optional) Length that a leafmost box must have to exclude from the hash."@en ;
    rdfs:domain c2pa:SubsetMap ;
    rdfs:range xsd:integer .

c2pa:SubsetMap.offset a owl:DatatypeProperty ;
    rdfs:label "offset"@en ;
    rdfs:comment "Each entry in a map is a Merkle tree row and the associated data required to enable validation of a single"@en ;
    rdfs:domain c2pa:SubsetMap ;
    rdfs:range xsd:integer .

c2pa:TextMap a owl:Class ;
    rdfs:label "TextMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:TextMap.selectors ] ;
    owl:sameAs c2pa:text-map .

c2pa:TextSelectorMap.fragment a owl:DatatypeProperty ;
    rdfs:label "fragment"@en ;
    rdfs:comment "fragment identifier, as per RFC3023 or ISO 32000-2, Annex O"@en ;
    rdfs:domain c2pa:TextSelectorMap ;
    rdfs:range xsd:string .

c2pa:TextSelectorRangeMap.selector a owl:ObjectProperty ;
    rdfs:label "selector"@en ;
    rdfs:comment "start (or only) text selector"@en ;
    rdfs:domain c2pa:TextSelectorRangeMap ;
    rdfs:range c2pa:TextSelectorMap ;
    c2pa:relationshipType "has_one" .

<https://c2pa.org/ontology/TimeStampMap.$$time_stamp_entry> a owl:DatatypeProperty ;
    rdfs:label "$$time-stamp-entry"@en ;
    rdfs:domain c2pa:TimeStampMap ;
    rdfs:range xsd:base64Binary .

c2pa:TrainingMiningMapEntry.use a owl:ObjectProperty ;
    rdfs:label "use"@en ;
    rdfs:comment "information about the use of `constrained`"@en ;
    rdfs:domain c2pa:TrainingMiningMapEntry ;
    rdfs:range c2pa:TrainingMiningChoice .

c2pa:Tsttoken a owl:Class ;
    rdfs:label "Tsttoken"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:Tsttoken.val ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:Tsttoken.val ] ;
    owl:sameAs c2pa:tstToken .

c2pa:Tsttoken.val a owl:DatatypeProperty ;
    rdfs:label "val"@en ;
    rdfs:domain c2pa:Tsttoken ;
    rdfs:range xsd:base64Binary .

c2pa:UnhashedExtUriMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "URI reference"@en ;
    rdfs:domain c2pa:UnhashedExtUriMap ;
    rdfs:range xsd:string .

c2pa:UriHashedDataMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "byte string containing the hash value"@en ;
    rdfs:domain c2pa:UriHashedDataMap ;
    rdfs:range xsd:base64Binary .

c2pa:UriHashedDataMap.uri a owl:ObjectProperty ;
    rdfs:label "uri"@en ;
    rdfs:comment "relative URI reference"@en ;
    rdfs:domain c2pa:UriHashedDataMap ;
    rdfs:range c2pa:RelativeUrlType .

c2pa:WallClockTimeMap.type a owl:DatatypeProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "from a controlled list"@en ;
    rdfs:domain c2pa:WallClockTimeMap ;
    rdfs:range xsd:string .

c2pa:actionItemV1.action a owl:DatatypeProperty ;
    rdfs:label "action"@en ;
    rdfs:comment "Action type (e.g., c2pa.created, c2pa.edited, c2pa.converted); $action-choice"@en ;
    rdfs:domain c2pa:actionItemV1 ;
    rdfs:range xsd:string .

c2pa:actionItemV2.action a owl:DatatypeProperty ;
    rdfs:label "action"@en ;
    rdfs:comment "Action type; $action-choice"@en ;
    rdfs:domain c2pa:actionItemV2 ;
    rdfs:range xsd:string .

c2pa:actionTemplateV2.action a owl:DatatypeProperty ;
    rdfs:label "action"@en ;
    rdfs:comment "Action type or \"*\" for templates; $action-choice / \"*\""@en ;
    rdfs:domain c2pa:actionTemplateV2 ;
    rdfs:range xsd:string .

c2pa:bmffDataMap.offset a owl:DatatypeProperty ;
    rdfs:label "offset"@en ;
    rdfs:comment "Relative byte offset in the leafmost box"@en ;
    rdfs:domain c2pa:bmffDataMap ;
    rdfs:range xsd:integer .

c2pa:bmffDataMap.value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:comment "Byte string (e.g. Base64 in JSON) that must match at the offset"@en ;
    rdfs:domain c2pa:bmffDataMap ;
    rdfs:range xsd:string .

c2pa:bmffExclusionsMap.xpath a owl:DatatypeProperty ;
    rdfs:label "xpath"@en ;
    rdfs:comment "Location of box(es) to exclude (XPath from root node)"@en ;
    rdfs:domain c2pa:bmffExclusionsMap ;
    rdfs:range xsd:string .

c2pa:bmffMerkleMap.count a owl:DatatypeProperty ;
    rdfs:label "count"@en ;
    rdfs:comment "Number of leaf nodes in the Merkle tree (null nodes not included)"@en ;
    rdfs:domain c2pa:bmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:bmffMerkleMap.localId a owl:DatatypeProperty ;
    rdfs:label "localId"@en ;
    rdfs:comment "Local id indicating Merkle tree"@en ;
    rdfs:domain c2pa:bmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:bmffMerkleMap.uniqueId a owl:DatatypeProperty ;
    rdfs:label "uniqueId"@en ;
    rdfs:comment "1-based unique id to determine which Merkle tree validates a given mdat box"@en ;
    rdfs:domain c2pa:bmffMerkleMap ;
    rdfs:range xsd:integer .

c2pa:bmffSubsetMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "Number of bytes in this subset"@en ;
    rdfs:domain c2pa:bmffSubsetMap ;
    rdfs:range xsd:integer .

c2pa:bmffSubsetMap.offset a owl:DatatypeProperty ;
    rdfs:label "offset"@en ;
    rdfs:comment "Relative byte offset within the excluded box"@en ;
    rdfs:domain c2pa:bmffSubsetMap ;
    rdfs:range xsd:integer .

c2pa:boxExclusionsMap.length a owl:DatatypeProperty ;
    rdfs:label "length"@en ;
    rdfs:comment "Number of bytes of data to exclude (uint)"@en ;
    rdfs:domain c2pa:boxExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:boxExclusionsMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "Starting byte offset from the start of the box (uint)"@en ;
    rdfs:domain c2pa:boxExclusionsMap ;
    rdfs:range xsd:integer .

c2pa:boxHashMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "Hash value (byte string; in JSON typically Base64-encoded with b64' prefix)"@en ;
    rdfs:domain c2pa:boxHashMap ;
    rdfs:range xsd:string .

c2pa:certificateInfo.issuer a owl:ObjectProperty ;
    rdfs:label "issuer"@en ;
    rdfs:domain c2pa:certificateInfo ;
    rdfs:range c2pa:distinguishedName ;
    c2pa:relationshipType "has_one" .

c2pa:certificateInfo.serialNumber a owl:DatatypeProperty ;
    rdfs:label "serialNumber"@en ;
    rdfs:comment "Certificate serial number"@en ;
    rdfs:domain c2pa:certificateInfo ;
    rdfs:range xsd:string .

c2pa:certificateInfo.subject a owl:ObjectProperty ;
    rdfs:label "subject"@en ;
    rdfs:domain c2pa:certificateInfo ;
    rdfs:range c2pa:distinguishedName ;
    c2pa:relationshipType "has_one" .

c2pa:certificateInfo.validity a owl:ObjectProperty ;
    rdfs:label "validity"@en ;
    rdfs:domain c2pa:certificateInfo .

c2pa:claim.claim_generator_info a owl:ObjectProperty ;
    rdfs:label "claim_generator_info"@en ;
    rdfs:comment "The claim generator of this claim (single generator-info map)"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range c2pa:softwareAgent ;
    c2pa:relationshipType "has_one" .

c2pa:claim.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "Uniquely identifies a specific version of an asset"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range xsd:string .

c2pa:claim.signature a owl:DatatypeProperty ;
    rdfs:label "signature"@en ;
    rdfs:comment "JUMBF URI reference to the signature of this claim"@en ;
    rdfs:domain c2pa:claim ;
    rdfs:range xsd:string .

c2pa:claimV1.claim_generator a owl:DatatypeProperty ;
    rdfs:label "claim_generator"@en ;
    rdfs:comment "User-Agent string for the claim generator that created the claim (RFC 7231 §5.5.3)"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string .

c2pa:claimV1.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "Media type of the asset"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string .

c2pa:claimV1.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "Uniquely identifies a specific version of an asset"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string .

c2pa:claimV1.signature a owl:DatatypeProperty ;
    rdfs:label "signature"@en ;
    rdfs:comment "JUMBF URI reference to the signature of this claim"@en ;
    rdfs:domain c2pa:claimV1 ;
    rdfs:range xsd:string .

c2pa:hashDataAssertion.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "Base64-encoded hash value with b64' prefix"@en ;
    rdfs:domain c2pa:hashDataAssertion ;
    rdfs:range xsd:string .

c2pa:hashDataAssertion.pad a owl:DatatypeProperty ;
    rdfs:label "pad"@en ;
    rdfs:comment "Padding bytes"@en ;
    rdfs:domain c2pa:hashDataAssertion ;
    rdfs:range xsd:string .

c2pa:hashMultiAssetAssertion a owl:Class ;
    rdfs:label "hashMultiAssetAssertion"@en ;
    rdfs:comment "Multi-asset hash assertion (c2pa.hash.multi-asset). CDDL: multi-asset-hash.cddl multi-asset-hash-map."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:hashMultiAssetAssertion.parts ] .

c2pa:hashedExtUriMap.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "String identifying the cryptographic hash algorithm used to compute the hash on this URI's data, taken from the C2PA hash algorithm identifier list."@en ;
    rdfs:domain c2pa:hashedExtUriMap ;
    rdfs:range xsd:string .

c2pa:hashedExtUriMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "Base64-encoded with b64' prefix hash value of the external data"@en ;
    rdfs:domain c2pa:hashedExtUriMap ;
    rdfs:range xsd:string .

c2pa:hashedExtUriMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "HTTP/HTTPS URI reference to external data"@en ;
    rdfs:domain c2pa:hashedExtUriMap ;
    rdfs:range xsd:anyURI .

c2pa:hashedUriMap.hash a owl:DatatypeProperty ;
    rdfs:label "hash"@en ;
    rdfs:comment "Hash value (Base64-encoded with b64' prefix)"@en ;
    rdfs:domain c2pa:hashedUriMap ;
    rdfs:range xsd:string .

c2pa:hashedUriMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "JUMBF URI reference"@en ;
    rdfs:domain c2pa:hashedUriMap ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV1.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "Media type of the ingredient (format-string)"@en ;
    rdfs:domain c2pa:ingredientAssertionV1 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV1.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "Name of the ingredient (Dublin Core)"@en ;
    rdfs:domain c2pa:ingredientAssertionV1 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV1.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "Unique identifier, e.g. value of the ingredient's xmpMM:InstanceID"@en ;
    rdfs:domain c2pa:ingredientAssertionV1 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV1.relationship a owl:DatatypeProperty ;
    rdfs:label "relationship"@en ;
    rdfs:comment "Relationship of this ingredient to the asset; $relation-choice (parentOf, componentOf, inputTo)"@en ;
    rdfs:domain c2pa:ingredientAssertionV1 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV2.dc_format a owl:DatatypeProperty ;
    rdfs:label "dc:format"@en ;
    rdfs:comment "Media type of the ingredient (format-string)"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV2.dc_title a owl:DatatypeProperty ;
    rdfs:label "dc:title"@en ;
    rdfs:comment "Name of the ingredient (Dublin Core)"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV2.relationship a owl:DatatypeProperty ;
    rdfs:label "relationship"@en ;
    rdfs:comment "Relationship of this ingredient to the asset; $relation-choice"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV3.relationship a owl:DatatypeProperty ;
    rdfs:label "relationship"@en ;
    rdfs:comment "Relationship of this ingredient to the asset; $relation-choice"@en ;
    rdfs:domain c2pa:ingredientAssertionV3 ;
    rdfs:range xsd:string .

c2pa:ingredientDeltaValidationResult.ingredientAssertionURI a owl:DatatypeProperty ;
    rdfs:label "ingredientAssertionURI"@en ;
    rdfs:comment "JUMBF URI to the ingredient assertion"@en ;
    rdfs:domain c2pa:ingredientDeltaValidationResult ;
    rdfs:range xsd:string .

c2pa:ingredientDeltaValidationResult.validationDeltas a owl:ObjectProperty ;
    rdfs:label "validationDeltas"@en ;
    rdfs:domain c2pa:ingredientDeltaValidationResult ;
    rdfs:range c2pa:statusCodes ;
    c2pa:relationshipType "has_one" .

c2pa:jsonGenerator.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Name of the software"@en ;
    rdfs:domain c2pa:jsonGenerator ;
    rdfs:range xsd:string .

c2pa:jsonGenerator.version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:comment "Version of the software (SemVer 2.0: major.minor.patch with optional pre-release and build)"@en ;
    rdfs:domain c2pa:jsonGenerator ;
    rdfs:range xsd:string ;
    c2pa:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$" .

c2pa:manifest.assertions a owl:ObjectProperty ;
    rdfs:label "assertions"@en ;
    rdfs:comment "Assertions contained within the manifest, keyed by the assertion's label"@en ;
    rdfs:domain c2pa:manifest .

c2pa:manifest.label a owl:DatatypeProperty ;
    rdfs:label "label"@en ;
    rdfs:comment "Manifest label or URN identifier"@en ;
    rdfs:domain c2pa:manifest ;
    rdfs:range xsd:string .

c2pa:manifest.signature a owl:ObjectProperty ;
    rdfs:label "signature"@en ;
    rdfs:domain c2pa:manifest ;
    rdfs:range c2pa:signature ;
    c2pa:relationshipType "has_one" .

c2pa:manifest.validationResults a owl:ObjectProperty ;
    rdfs:label "validationResults"@en ;
    rdfs:comment "Validation status codes for this manifest (success, informational, failure) and when validation was performed"@en ;
    rdfs:domain c2pa:manifest ;
    rdfs:range c2pa:manifestValidationResults ;
    c2pa:relationshipType "has_one" .

c2pa:manifestValidationResults.specVersion a owl:DatatypeProperty ;
    rdfs:label "specVersion"@en ;
    rdfs:comment "The version of the specification against which the validation was performed (SemVer formatted string)"@en ;
    rdfs:domain c2pa:manifestValidationResults ;
    rdfs:range xsd:string ;
    c2pa:pattern "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$" .

c2pa:manifestValidationResults.validationTime a owl:DatatypeProperty ;
    rdfs:label "validationTime"@en ;
    rdfs:comment "Time when the validation was performed; RFC 3339 format"@en ;
    rdfs:domain c2pa:manifestValidationResults ;
    rdfs:range xsd:dateTime .

c2pa:partHashMap.hashAssertion a owl:ObjectProperty ;
    rdfs:label "hashAssertion"@en ;
    rdfs:comment "Hashed URI to the hash assertion for the part (e.g. c2pa.hash.data.part, c2pa.hash.data.part__2). Byte offsets in that assertion are relative to the part."@en ;
    rdfs:domain c2pa:partHashMap ;
    rdfs:range c2pa:hashedUriMap ;
    c2pa:relationshipType "has_one" .

c2pa:partHashMap.location a owl:ObjectProperty ;
    rdfs:label "location"@en ;
    rdfs:comment "Location of the part within the file (byte range or BMFF box path)"@en ;
    rdfs:domain c2pa:partHashMap ;
    rdfs:range c2pa:LocatorMap ;
    c2pa:relationshipType "has_one" .

c2pa:ratingMap.value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:comment "Rating from 1 (worst) to 5 (best)"@en ;
    rdfs:domain c2pa:ratingMap ;
    rdfs:range xsd:integer .

c2pa:signature.algorithm a owl:DatatypeProperty ;
    rdfs:label "algorithm"@en ;
    rdfs:comment "Algorithm used for signing (e.g., SHA256withECDSA)"@en ;
    rdfs:domain c2pa:signature ;
    rdfs:range xsd:string .

c2pa:signature.certificateInfo a owl:ObjectProperty ;
    rdfs:label "certificateInfo"@en ;
    rdfs:domain c2pa:signature ;
    rdfs:range c2pa:certificateInfo ;
    c2pa:relationshipType "has_one" .

c2pa:softBindingAssertion.alg a owl:DatatypeProperty ;
    rdfs:label "alg"@en ;
    rdfs:comment "Soft binding algorithm and version from C2PA soft binding algorithm list. If absent, taken from enclosing alg_soft."@en ;
    rdfs:domain c2pa:softBindingAssertion ;
    rdfs:range xsd:string .

c2pa:softBindingBlockMap.scope a owl:ObjectProperty ;
    rdfs:label "scope"@en ;
    rdfs:comment "Scope of the digital content over which the soft binding is computed"@en ;
    rdfs:domain c2pa:softBindingBlockMap ;
    rdfs:range c2pa:softBindingScopeMap ;
    c2pa:relationshipType "has_one" .

c2pa:softBindingBlockMap.value a owl:DatatypeProperty ;
    rdfs:label "value"@en ;
    rdfs:comment "CBOR byte string (e.g. Base64 in JSON), in algorithm-specific format, for the soft binding value over this block"@en ;
    rdfs:domain c2pa:softBindingBlockMap ;
    rdfs:range xsd:string .

c2pa:softBindingTimespanMap.end a owl:DatatypeProperty ;
    rdfs:label "end"@en ;
    rdfs:comment "End of the time range in milliseconds from media start (uint)"@en ;
    rdfs:domain c2pa:softBindingTimespanMap ;
    rdfs:range xsd:integer .

c2pa:softBindingTimespanMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "Start of the time range in milliseconds from media start (uint)"@en ;
    rdfs:domain c2pa:softBindingTimespanMap ;
    rdfs:range xsd:integer .

c2pa:softwareAgent.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Name of the software"@en ;
    rdfs:domain c2pa:softwareAgent ;
    rdfs:range xsd:string .

c2pa:sourceMap.type a owl:DatatypeProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "Source type; $source-type"@en ;
    rdfs:domain c2pa:sourceMap ;
    rdfs:range xsd:string ;
    c2pa:enumValues "signer, claimGenerator.REE, claimGenerator.TEE, localProvider.REE, localProvider.TEE, remoteProvider.1stParty, remoteProvider.3rdParty, humanEntry, humanEntry.anonymous, humanEntry.identified" .

c2pa:validationResults.activeManifest a owl:ObjectProperty ;
    rdfs:label "activeManifest"@en ;
    rdfs:comment "Validation status codes for the active manifest. Present when ingredient is a C2PA asset."@en ;
    rdfs:domain c2pa:validationResults ;
    rdfs:range c2pa:statusCodes ;
    c2pa:relationshipType "has_one" .

c2pa:validationStatusEntry.code a owl:DatatypeProperty ;
    rdfs:label "code"@en ;
    rdfs:comment "Validation status code"@en ;
    rdfs:domain c2pa:validationStatusEntry ;
    rdfs:range xsd:string .

c2pa:AraReferenceBlockMap a owl:Class ;
    rdfs:label "AraReferenceBlockMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AraReferenceBlockMap.description ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AraReferenceBlockMap.reference ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AraReferenceBlockMap.reference ] ;
    owl:sameAs c2pa:ara-reference-block-map .

c2pa:AssetTypes a owl:Class ;
    rdfs:label "AssetTypes"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssetTypes.dc_format ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:AssetTypes.metadata ] ;
    owl:sameAs c2pa:asset-types .

c2pa:CollectionDataHashMap a owl:Class ;
    rdfs:label "CollectionDataHashMap"@en ;
    rdfs:comment "In workflows where it is known in advance that the C2PA Manifest will refer to a collection of assets, instead of a single asset, the collection data hash assertion shall be used as the method to specify the hard bindings (i.e., cryptographic hashes) for the assets in the collection."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CollectionDataHashMap.zip_central_directory_hash ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CollectionDataHashMap.alg ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CollectionDataHashMap.alg ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:CollectionDataHashMap.uris ] ;
    owl:sameAs <https://c2pa.org/ontology/$collection-data-hash-map> ;
    c2pa:extensible true .

c2pa:ContentCredentialsJSONcrJSONDocumentSchema a owl:Class ;
    rdfs:label "ContentCredentialsJSONcrJSONDocumentSchema"@en ;
    rdfs:comment "JSON Schema for Content Credentials JSON (crJSON) documents. crJSON does not include asset_info, content, or metadata."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ContentCredentialsJSONcrJSONDocumentSchema.jsonGenerator ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:ContentCredentialsJSONcrJSONDocumentSchema.jsonGenerator ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://c2pa.org/ontology/ContentCredentialsJSONcrJSONDocumentSchema.@context> ],
        [ a owl:Restriction ;
