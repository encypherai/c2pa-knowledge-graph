        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:DepthmapGdepthMap.GDepth_Manufacturer ] ;
    owl:sameAs c2pa:depthmap-gdepth-map .

c2pa:IngredientMapV3 a owl:Class ;
    rdfs:label "IngredientMapV3"@en ;
    rdfs:comment "Version 3 (v3) of the ingredient assertion Assertion that describes an ingredient used in the asset"@en ;
