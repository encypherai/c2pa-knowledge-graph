            owl:onProperty c2pa:PartHashMap.optional ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty c2pa:PartHashMap.location ] ;
    owl:sameAs c2pa:part-hash-map .

c2pa:RatingMap a owl:Class ;
    rdfs:label "RatingMap"@en ;
    rdfs:comment "Rating of an assertion item. CDDL: assertion-metadata-common.cddl rating-map."@en ;
