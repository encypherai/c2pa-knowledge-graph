c2pa:ingredientAssertionV2.documentID a owl:DatatypeProperty ;
    rdfs:label "documentID"@en ;
    rdfs:comment "Value of the ingredient's xmpMM:DocumentID"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV2.informational_URI a owl:DatatypeProperty ;
    rdfs:label "informational_URI"@en ;
    rdfs:comment "URI to an informational page about the ingredient or its data"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV2.instanceID a owl:DatatypeProperty ;
    rdfs:label "instanceID"@en ;
    rdfs:comment "Unique identifier, e.g. value of the ingredient's xmpMM:InstanceID"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range xsd:string .

c2pa:ingredientAssertionV2.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range c2pa:assertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:ingredientAssertionV2.thumbnail a owl:ObjectProperty ;
    rdfs:label "thumbnail"@en ;
    rdfs:comment "Hashed URI reference to a thumbnail in an embedded data assertion"@en ;
    rdfs:domain c2pa:ingredientAssertionV2 ;
    rdfs:range c2pa:hashedUriMap ;
