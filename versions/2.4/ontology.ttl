    rdfs:range xsd:decimal .

c2pa:ShapeMap.inside a owl:DatatypeProperty ;
    rdfs:label "inside"@en ;
    rdfs:comment "inside or outside the shape, default is `true`"@en ;
    rdfs:domain c2pa:ShapeMap ;
    rdfs:range xsd:boolean .

c2pa:ShapeMap.width a owl:DatatypeProperty ;
    rdfs:label "width"@en ;
    rdfs:comment "width for rectangles, diameter for circles (ignored for polygons)"@en ;
    rdfs:domain c2pa:ShapeMap ;
    rdfs:range xsd:decimal .

c2pa:SoftBindingMap.alg_params a owl:DatatypeProperty ;
    rdfs:label "alg-params"@en ;
    rdfs:comment "(optional) CBOR byte string describing parameters of the soft binding algorithm."@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range xsd:base64Binary .

c2pa:SoftBindingMap.bindingMetadata a owl:ObjectProperty ;
    rdfs:label "bindingMetadata"@en ;
    rdfs:comment "(optional) Additional metadata of the soft binding. Useful for binding-specific information"@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range c2pa:SoftBindingMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:SoftBindingMap.blocks a owl:ObjectProperty ;
    rdfs:label "blocks"@en ;
    rdfs:comment "zero-filled byte string used for filling up space"@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range c2pa:SoftBindingBlockMap ;
    c2pa:relationshipType "has_many" .

c2pa:SoftBindingMap.metadata a owl:ObjectProperty ;
    rdfs:label "metadata"@en ;
    rdfs:comment "additional information about the assertion"@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range c2pa:AssertionMetadataMap ;
    c2pa:relationshipType "has_one" .

c2pa:SoftBindingMap.name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "(optional) a human-readable description of what this hash covers"@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range xsd:string .

c2pa:SoftBindingMap.pad a owl:DatatypeProperty ;
    rdfs:label "pad"@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range xsd:base64Binary .

c2pa:SoftBindingMap.pad2 a owl:DatatypeProperty ;
    rdfs:label "pad2"@en ;
    rdfs:comment "zero-filled byte string used for filling up space"@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range xsd:base64Binary .

c2pa:SoftBindingMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "Unused and deprecated."@en ;
    rdfs:domain c2pa:SoftBindingMap ;
    rdfs:range xsd:anyURI .

c2pa:SoftBindingMetadataMap.contact a owl:DatatypeProperty ;
    rdfs:label "contact"@en ;
    rdfs:comment "Contact information for the implementation or author of the binding or the algorithm,"@en ;
    rdfs:domain c2pa:SoftBindingMetadataMap ;
    rdfs:range xsd:string .

c2pa:SoftBindingMetadataMap.description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:comment "Additional description of the implementation or author of the binding or the algorithm"@en ;
    rdfs:domain c2pa:SoftBindingMetadataMap ;
    rdfs:range xsd:string .

c2pa:SoftBindingMetadataMap.informationalUrl a owl:DatatypeProperty ;
    rdfs:label "informationalUrl"@en ;
    rdfs:comment "A web page containing more details about the implementation or author of the binding or the algorithm."@en ;
    rdfs:domain c2pa:SoftBindingMetadataMap ;
    rdfs:range xsd:string .

c2pa:SoftBindingScopeMap.extent a owl:DatatypeProperty ;
    rdfs:label "extent"@en ;
    rdfs:comment "deprecated, CBOR byte string describing, in algorithm specific format,  the part of the digital content over which the soft binding value has been computed\""@en ;
    rdfs:domain c2pa:SoftBindingScopeMap ;
    rdfs:range xsd:base64Binary .

c2pa:SoftBindingScopeMap.region a owl:ObjectProperty ;
    rdfs:label "region"@en ;
    rdfs:comment "Region of interest (region-map)"@en ;
    rdfs:domain c2pa:SoftBindingScopeMap ;
    rdfs:range c2pa:RegionMap ;
    c2pa:relationshipType "has_one" .

c2pa:SoftBindingScopeMap.timespan a owl:ObjectProperty ;
    rdfs:label "timespan"@en ;
    rdfs:comment "CBOR object defined in regions-of-interest.cddl"@en ;
    rdfs:domain c2pa:SoftBindingScopeMap ;
    rdfs:range c2pa:SoftBindingTimespanMap ;
    c2pa:relationshipType "has_one" .

c2pa:SourceMap.details a owl:DatatypeProperty ;
    rdfs:label "details"@en ;
    rdfs:comment "A human readable string giving details about the source of the assertion data, e.g. the URL of the remote server that provided the data"@en ;
    rdfs:domain c2pa:SourceMap ;
    rdfs:range xsd:string .

c2pa:SourceType.claimGenerator_REE a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "claimGenerator.REE"@en .

c2pa:SourceType.claimGenerator_TEE a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "claimGenerator.TEE"@en .

c2pa:SourceType.humanEntry a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "humanEntry"@en .

c2pa:SourceType.humanEntry_anonymous a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "humanEntry.anonymous"@en .

c2pa:SourceType.humanEntry_identified a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "humanEntry.identified"@en .

c2pa:SourceType.localProvider_REE a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "localProvider.REE"@en .

c2pa:SourceType.localProvider_TEE a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "localProvider.TEE"@en .

c2pa:SourceType.remoteProvider_1stParty a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "remoteProvider.1stParty"@en .

c2pa:SourceType.remoteProvider_3rdParty a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "remoteProvider.3rdParty"@en .

c2pa:SourceType.signer a owl:NamedIndividual,
        c2pa:SourceType ;
    rdfs:label "signer"@en .

c2pa:StatusMap.explanation a owl:DatatypeProperty ;
    rdfs:label "explanation"@en ;
    rdfs:comment "A human readable string explaining the status"@en ;
    rdfs:domain c2pa:StatusMap ;
    rdfs:range xsd:string .

c2pa:StatusMap.success a owl:DatatypeProperty ;
    rdfs:label "success"@en ;
    rdfs:comment "DEPRECATED. Does the code reflect success (true) or failure (false)"@en ;
    rdfs:domain c2pa:StatusMap ;
    rdfs:range xsd:boolean .

c2pa:StatusMap.url a owl:DatatypeProperty ;
    rdfs:label "url"@en ;
    rdfs:comment "JUMBF URI reference to the JUMBF box to which this status code applies"@en ;
    rdfs:domain c2pa:StatusMap ;
    rdfs:range xsd:string .

c2pa:SustainabilityMeasurementMethod a owl:Class ;
    rdfs:label "SustainabilityMeasurementMethod"@en ;
    c2pa:extensible true .

c2pa:TextMap.selectors a owl:ObjectProperty ;
    rdfs:label "selectors"@en ;
    rdfs:comment "array of (possibly discontinuous) ranges of text"@en ;
    rdfs:domain c2pa:TextMap ;
    rdfs:range c2pa:TextSelectorRangeMap ;
    c2pa:relationshipType "has_many" .

c2pa:TextSelectorMap.end a owl:DatatypeProperty ;
    rdfs:label "end"@en ;
    rdfs:comment "end time (or end of asset if not present). Exclusive by default, see endInclusivity for override behaviour."@en ;
    rdfs:domain c2pa:TextSelectorMap ;
    rdfs:range xsd:integer .

c2pa:TextSelectorMap.start a owl:DatatypeProperty ;
    rdfs:label "start"@en ;
    rdfs:comment "start time (or beginning of asset if not present). Inclusive."@en ;
    rdfs:domain c2pa:TextSelectorMap ;
    rdfs:range xsd:integer .

c2pa:TextSelectorRangeMap.end a owl:ObjectProperty ;
    rdfs:label "end"@en ;
    rdfs:comment "end time (or end of asset if not present). Exclusive by default, see endInclusivity for override behaviour."@en ;
    rdfs:domain c2pa:TextSelectorRangeMap ;
    rdfs:range c2pa:TextSelectorMap ;
    c2pa:relationshipType "has_one" .

c2pa:TimeStampMap a owl:Class ;
    rdfs:label "TimeStampMap"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://c2pa.org/ontology/TimeStampMap.$$time_stamp_entry> ],
        [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <https://c2pa.org/ontology/TimeStampMap.$$time_stamp_entry> ] ;
    owl:sameAs <https://c2pa.org/ontology/$time-stamp-map> ;
    c2pa:extensible true .

